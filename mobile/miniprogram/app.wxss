/* ── Panel Frame (pf) ─ 面板边框组件系统 ────────────────────────
   用法: <panel-frame> content </panel-frame>
   组件内部自动渲染 8 个 fb-* 边框元素
   ──────────────────────────────────────────────────────────── */

/* fb-* 边框段基础定位（全局可用） */
.fb          { position: absolute; z-index: 2; }
.fb-top      { top: 0;    left: 10rpx; right: 10rpx; height: 1.5rpx; }
.fb-bottom   { bottom: 0; left: 10rpx; right: 10rpx; height: 1.5rpx; }
.fb-left     { left: 0;   top: 10rpx;  bottom: 10rpx; width: 1.5rpx; }
.fb-right    { right: 0;  top: 10rpx;  bottom: 10rpx; width: 1.5rpx; }
.fb-ctl      { top: 10rpx;               left: 0;                    width: 14rpx; height: 1.5rpx; transform: rotate(-45deg); transform-origin: 0% 0%; }
.fb-ctr      { top: 0;                   left: calc(100% - 10rpx);   width: 14rpx; height: 1.5rpx; transform: rotate(45deg);  transform-origin: 0% 0%; }
.fb-cbl      { top: calc(100% - 10rpx);  left: 0;                    width: 14rpx; height: 1.5rpx; transform: rotate(45deg);  transform-origin: 0% 0%; }
.fb-cbr      { left: calc(100% - 10rpx); bottom: 0;                  width: 14rpx; height: 1.5rpx; transform: rotate(-45deg); transform-origin: 0% 100%; }

/* fc-inner 内角装饰线（全局可用） */
.fc-inner        { position: absolute; width: 10rpx; height: 2rpx; z-index: 1; }
.fc-inner.fc-tl  { top: 12rpx;               left: 6rpx;                  transform: rotate(-45deg); transform-origin: 0% 0%; }
.fc-inner.fc-tr  { top: 6rpx;                left: calc(100% - 12rpx);    transform: rotate(45deg);  transform-origin: 0% 0%; }
.fc-inner.fc-bl  { top: calc(100% - 12rpx);  left: 6rpx;                  transform: rotate(45deg);  transform-origin: 0% 0%; }
.fc-inner.fc-br  { left: calc(100% - 12rpx); bottom: 6rpx;                transform: rotate(-45deg); transform-origin: 0% 100%; }

/* panel-frame 根样式 */
.pf {
  position: relative;
  background: var(--aw-panel);
  padding: 24rpx;
  margin-top: 28rpx;
  backdrop-filter: blur(6px);
  box-shadow: var(--aw-panel-shadow, none);
  /* 裁掉四个角的矩形背景，与 fb-* 的 10rpx≈5px 斜角位置对齐 */
  clip-path: polygon(5px 0%, calc(100% - 5px) 0%, 100% 5px, 100% calc(100% - 5px), calc(100% - 5px) 100%, 5px 100%, 0% calc(100% - 5px), 0% 5px);
}

/* panel-frame 金色渐变边框（学参考图样式） */
.pf .fb-top, .pf .fb-bottom {
  height: 2rpx;
  background: linear-gradient(to right, #6b3e08 0%, #c8860a 18%, #f5cc52 42%, #fff4b0 50%, #f5cc52 58%, #c8860a 82%, #6b3e08 100%);
}
.pf .fb-left, .pf .fb-right {
  width: 2rpx;
  background: linear-gradient(to bottom, #6b3e08, #c8860a 35%, #c8860a 65%, #6b3e08);
}
.pf .fb-ctl, .pf .fb-ctr, .pf .fb-cbl, .pf .fb-cbr {
  height: 2rpx;
  background: #9a6010;
}
.pf .fc-inner { background: rgba(228, 194, 129, 0.65); }

/* ── Chamfer Frame (cf) ─ 双层斜切角边框系统 ──────────────────
   外层: clip-path + 边框色背景；内层: 面板色背景（覆盖内部）
   用法:  <view class="cf cf-md cf-gold">
            <view class="cf-in">content</view>
          </view>
   尺寸:  cf-sm(6px) / cf-md(8px) / cf-lg(10px)
   颜色:  cf-subtle(浅白) / cf-gold(主题边框色)
   ──────────────────────────────────────────────────────────── */
.cf        { padding: 1rpx; }
.cf-sm     { clip-path: polygon(6px 0%, calc(100% - 6px) 0%, 100% 6px, 100% calc(100% - 6px), calc(100% - 6px) 100%, 6px 100%, 0% calc(100% - 6px), 0% 6px); }
.cf-md     { clip-path: polygon(8px 0%, calc(100% - 8px) 0%, 100% 8px, 100% calc(100% - 8px), calc(100% - 8px) 100%, 8px 100%, 0% calc(100% - 8px), 0% 8px); }
.cf-lg     { clip-path: polygon(10px 0%, calc(100% - 10px) 0%, 100% 10px, 100% calc(100% - 10px), calc(100% - 10px) 100%, 10px 100%, 0% calc(100% - 10px), 0% 10px); }
.cf-subtle { background: rgba(255, 255, 255, 0.15); }
.cf-gold   { background: var(--aw-panel-border); }
.cf-bright {
  background: linear-gradient(to right, #7a4a06 0%, #c8860a 20%, #f5cc52 45%, #fff4b0 50%, #f5cc52 55%, #c8860a 80%, #7a4a06 100%);
  padding: 2rpx;
  filter: drop-shadow(0 0 4rpx rgba(200, 150, 20, 0.55));
}
/* 内层：各自携带内缩 1px 的 clip-path + 面板背景
   <button> 不受父 clip-path 影响，必须在元素本身设置 */
.cf-in    { background: var(--aw-panel); }
.cf-in-sm { background: var(--aw-panel); border-radius: 0 !important; clip-path: polygon(5px 0%, calc(100% - 5px) 0%, 100% 5px, 100% calc(100% - 5px), calc(100% - 5px) 100%, 5px 100%, 0% calc(100% - 5px), 0% 5px); }
.cf-in-md { background: var(--aw-panel); border-radius: 0 !important; clip-path: polygon(7px 0%, calc(100% - 7px) 0%, 100% 7px, 100% calc(100% - 7px), calc(100% - 7px) 100%, 7px 100%, 0% calc(100% - 7px), 0% 7px); }
.cf-in-lg { background: var(--aw-panel); border-radius: 0 !important; clip-path: polygon(9px 0%, calc(100% - 9px) 0%, 100% 9px, 100% calc(100% - 9px), calc(100% - 9px) 100%, 9px 100%, 0% calc(100% - 9px), 0% 9px); }

/* ── 邪恶铭刻 自定义字体 ─────────────────────────── */
@font-face {
  font-family: 'DDTitle';
  src: url('https://www.awalon.top/mp-assets/skins/dark-dungeon/fonts/title.woff2') format('woff2');
  font-weight: 700;
  font-style: normal;
}

/* ── 问号帮助按钮（mission-pills / mission-table 共用） ── */
.help-btn {
  flex-shrink: 0;
  margin-left: 8rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(228, 194, 129, 0.35);
  background: rgba(228, 194, 129, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
.help-btn-q {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(228, 194, 129, 0.6);
  line-height: 1;
  text-align: center;
}

/* ── 帮助浮层（fixed，position 不受 backdrop-filter 影响） ── */
.help-popup {
  display: none;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(16, 10, 4, 0.97);
  border: 1rpx solid rgba(200, 134, 10, 0.45);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  flex-direction: column;
  gap: 14rpx;
  z-index: 9999;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.75);
  min-width: 300rpx;
  max-width: 560rpx;
}
.help-popup-show {
  display: flex;
}

/* ── 底部浮层容器（action-panel / speak-panel 共用） ── */
.vote-bottom-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 0;
  pointer-events: none;
}

/* ── 皮肤专属视觉覆写 ─────────────────────────────────── */
@import '/styles/theme-dark-dungeon.wxss';
