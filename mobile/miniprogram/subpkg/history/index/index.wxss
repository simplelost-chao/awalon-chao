/* ─── PAGE ─── */
.page { min-height: 100vh; position: relative; background: var(--aw-bg); }
.bg, .mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; }
.bg { width: 100vw; height: 100vh; }
.mask { background: linear-gradient(180deg, rgba(6,8,16,0.72) 0%, rgba(8,10,20,0.88) 40%, rgba(6,8,16,0.96) 100%); }

/* ─── PVP/PVE TABS ─── */
.history-mode-tabs { display: flex; justify-content: center; gap: 32rpx; padding: 8rpx 0 16rpx; }
.history-mode-tab { font-size: 26rpx; color: rgba(255,255,255,0.4); padding: 8rpx 24rpx; border-bottom: 4rpx solid transparent; }
.history-mode-tab-active { color: rgba(216,176,107,0.9); border-bottom-color: rgba(216,176,107,0.7); }

/* light skins: hide dark bg image and remove dark overlay */
.theme-celestial .bg,
.theme-ink-wash .bg { display: none; }
.theme-celestial .mask,
.theme-ink-wash .mask { background: none; }

.sub-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: rgba(6, 8, 15, 0.92);
  border-bottom: 1rpx solid rgba(216, 176, 107, 0.14);
}
.sub-nav-inner {
  position: relative;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}
.sub-nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(216, 176, 107, 0.35);
  background: rgba(216, 176, 107, 0.08);
  flex-shrink: 0;
}
.sub-nav-back-arrow {
  font-size: 36rpx;
  color: rgba(216, 176, 107, 0.8);
  line-height: 1;
  margin-top: -2rpx;
}
.sub-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #f2e5c8;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  pointer-events: none;
}
.sub-nav-placeholder {
  width: 100rpx;
  flex-shrink: 0;
}


/* ─── CONTENT ─── */
.content { position: relative; z-index: 2; max-width: 760rpx; margin: 0 auto; padding: 0 24rpx 160rpx; }
.state-tip { position: relative; z-index: 2; text-align: center; color: rgba(210,220,240,0.4); font-size: 26rpx; padding-top: 80rpx; }

/* ─── RECORD LIST ─── */
.record-list { display: flex; flex-direction: column; gap: 18rpx; margin-top: 20rpx; }

/* ─── CARD ─── */
/* 外层：边框色背景 + 斜切角 clip-path */
.hc {
  position: relative;
  clip-path: polygon(8px 0%, calc(100% - 8px) 0%, 100% 8px, 100% calc(100% - 8px), calc(100% - 8px) 100%, 8px 100%, 0% calc(100% - 8px), 0% 8px);
  padding: 1.5rpx;
}
.hc-win  { background: rgba(70,210,130,0.60); }
.hc-lose { background: rgba(220,70,70,0.60); }
.hc-spec { background: linear-gradient(135deg, #8a6010, #c8a040 40%, #f5d060 50%, #c8a040 60%, #8a6010); }

/* 内层：面板渐变背景 + 内缩斜切角 */
.hc-inner {
  position: relative; overflow: hidden;
  clip-path: polygon(7px 0%, calc(100% - 7px) 0%, 100% 7px, 100% calc(100% - 7px), calc(100% - 7px) 100%, 7px 100%, 0% calc(100% - 7px), 0% 7px);
}
.hc-win  .hc-inner { background: linear-gradient(135deg, rgba(12,46,26,0.96) 0%, rgba(8,12,22,0.98) 55%); }
.hc-lose .hc-inner { background: linear-gradient(135deg, rgba(50,10,10,0.96) 0%, rgba(8,12,22,0.98) 55%); }
.hc-spec .hc-inner { background: linear-gradient(135deg, rgba(44,28,6,0.96)  0%, rgba(8,12,22,0.98) 55%); }

/* 左侧色条 */
.hc-inner::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4rpx; z-index: 1;
}
.hc-win  .hc-inner::before { background: linear-gradient(180deg, rgba(80,220,140,0.95), rgba(80,220,140,0.15)); }
.hc-lose .hc-inner::before { background: linear-gradient(180deg, rgba(220,80,80,0.95),  rgba(220,80,80,0.15)); }
.hc-spec .hc-inner::before { background: linear-gradient(180deg, rgba(216,176,107,0.9), rgba(216,176,107,0.12)); }

/* 局号水印 */
.hc-watermark {
  position: absolute; right: 16rpx; top: 50%; transform: translateY(-50%);
  font-size: 120rpx; font-weight: 700; line-height: 1;
  pointer-events: none; user-select: none; letter-spacing: -4rpx;
}
.hc-win  .hc-watermark { color: rgba(80,220,140,0.07); }
.hc-lose .hc-watermark { color: rgba(220,80,80,0.08); }
.hc-spec .hc-watermark { color: rgba(216,176,107,0.07); }

/* 卡片主体 */
.hc-body { padding: 24rpx 24rpx 20rpx 28rpx; position: relative; }

/* 顶行 */
.hc-top { display: flex; align-items: flex-start; gap: 20rpx; }

/* 头像 */
.hc-avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.15);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; overflow: hidden;
  background: rgba(20,26,44,0.9);
}
.hc-avatar-good {
  border-color: #4e9eff;
  box-shadow: 0 0 0 2rpx rgba(78,158,255,0.25), 0 0 20rpx rgba(78,158,255,0.3);
  background: rgba(14,30,58,0.95);
}
.hc-avatar-evil {
  border-color: #e05050;
  box-shadow: 0 0 0 2rpx rgba(220,80,80,0.22), 0 0 20rpx rgba(220,80,80,0.3);
  background: rgba(50,12,12,0.95);
}
.hc-avatar-spec {
  border-color: #c49840;
  box-shadow: 0 0 0 2rpx rgba(216,176,107,0.2), 0 0 16rpx rgba(216,176,107,0.22);
  background: rgba(44,32,8,0.95);
}

.hc-avatar-img  { width: 100%; height: 100%; border-radius: 50%; }
.hc-avatar-emoji { font-size: 48rpx; line-height: 1; }

/* 右侧信息 */
.hc-info { flex: 1; min-width: 0; }
.hc-head-row {
  display: flex; align-items: center; justify-content: space-between; gap: 10rpx;
  margin-bottom: 6rpx;
}
.hc-role-name {
  font-size: 28rpx; font-weight: 700;
  flex: 1; min-width: 0;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.hc-role-name-good { color: #7ac7ff; }
.hc-role-name-evil { color: #ff8a8a; }
.hc-role-name-spec { color: #d8b06b; }

/* 结果徽章 */
.hc-badge {
  flex-shrink: 0;
  display: flex; align-items: center; gap: 6rpx;
  padding: 5rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
}
.hc-badge-win  { background: rgba(80,220,140,0.12); border-color: rgba(80,220,140,0.35); }
.hc-badge-lose { background: rgba(220,80,80,0.12);  border-color: rgba(220,80,80,0.32); }
.hc-badge-spec { background: rgba(216,176,107,0.10); border-color: rgba(216,176,107,0.28); }
.hc-badge-dot { width: 8rpx; height: 8rpx; border-radius: 50%; }
.hc-badge-win  .hc-badge-dot { background: #50dc8c; }
.hc-badge-lose .hc-badge-dot { background: #ff6b6b; }
.hc-badge-spec .hc-badge-dot { background: #d8b06b; }
.hc-badge-txt { font-size: 22rpx; font-weight: 700; letter-spacing: 2rpx; }
.hc-badge-win  .hc-badge-txt { color: #50dc8c; }
.hc-badge-lose .hc-badge-txt { color: #ff8080; }
.hc-badge-spec .hc-badge-txt { color: #d8b06b; }

/* 元数据行 */
.hc-meta-row {
  display: flex; align-items: center; gap: 8rpx;
  line-height: 1;
}
.hc-meta {
  font-size: 22rpx; color: rgba(200,210,230,0.42);
  line-height: 1; display: block;
}
.hc-meta-sep {
  width: 6rpx; height: 6rpx; border-radius: 50%;
  background: rgba(255,255,255,0.18);
  flex-shrink: 0;
}

/* 底行 */
.hc-bottom {
  display: flex; align-items: center; flex-wrap: wrap; gap: 10rpx;
  margin-top: 18rpx; padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.055);
}

/* 角色 chip */
.hc-chip {
  display: flex; align-items: center; gap: 7rpx;
  padding: 5rpx 16rpx 5rpx 10rpx;
  border-radius: 999rpx; border: 1rpx solid transparent;
}
.hc-chip-good { background: rgba(78,158,255,0.10); border-color: rgba(78,158,255,0.22); }
.hc-chip-evil { background: rgba(220,80,80,0.10);  border-color: rgba(220,80,80,0.22); }
.hc-chip-spec { background: rgba(216,176,107,0.08); border-color: rgba(216,176,107,0.20); }
.hc-chip-dot { width: 8rpx; height: 8rpx; border-radius: 50%; }
.hc-chip-good .hc-chip-dot { background: #4e9eff; }
.hc-chip-evil .hc-chip-dot { background: #ff6060; }
.hc-chip-spec .hc-chip-dot { background: #d8b06b; }
.hc-chip-txt { font-size: 22rpx; font-weight: 700; letter-spacing: 1rpx; }
.hc-chip-good .hc-chip-txt { color: #7ac7ff; }
.hc-chip-evil .hc-chip-txt { color: #ff9090; }
.hc-chip-spec .hc-chip-txt { color: #d8b06b; }

/* 勋章 chip */
.hc-medal {
  display: flex; align-items: center; gap: 5rpx;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(216,176,107,0.06);
  border: 1rpx solid rgba(216,176,107,0.16);
}
.hc-medal-img  { width: 30rpx; height: 30rpx; }
.hc-medal-icon { font-size: 26rpx; line-height: 1; }
.hc-medal-name { font-size: 20rpx; color: rgba(216,176,107,0.72); }

/* 时间 */
.hc-time { margin-left: auto; font-size: 20rpx; color: rgba(200,210,230,0.3); white-space: nowrap; }

/* ─── 分页 ─── */
.pagination {
  padding: 20rpx 40rpx;
  display: flex; align-items: center; justify-content: center; gap: 48rpx;
  display: flex; align-items: center; justify-content: center; gap: 48rpx;
}
.page-arrow {
  width: 84rpx; height: 84rpx; border-radius: 50%;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(216,176,107,0.28);
  color: #d8b06b;
  font-size: 44rpx; line-height: 84rpx; text-align: center;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s, opacity 0.15s;
}
.page-arrow-disabled { opacity: 0.2; pointer-events: none; }
.page-indicator { display: flex; flex-direction: column; align-items: center; gap: 4rpx; min-width: 80rpx; }
.page-num { font-size: 38rpx; font-weight: 700; line-height: 1; color: #d8b06b; }
.page-label { font-size: 18rpx; letter-spacing: 4rpx; color: rgba(200,210,230,0.35); }
