/* ─── PAGE ─── */
.page { min-height: 100vh; position: relative; background: var(--aw-bg); }
.bg, .mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; }
.bg { width: 100vw; height: 100vh; }
.mask { background: linear-gradient(180deg, rgba(6,8,16,0.72) 0%, rgba(8,10,20,0.88) 40%, rgba(6,8,16,0.96) 100%); }

/* light skins: hide dark bg image and remove dark overlay */
.theme-celestial .bg,
.theme-ink-wash .bg { display: none; }
.theme-celestial .mask,
.theme-ink-wash .mask { background: none; }

.sub-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: rgba(6, 8, 15, 0.92);
  border-bottom: 1rpx solid rgba(216, 176, 107, 0.14);
}
.sub-nav-inner {
  position: relative;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}
.sub-nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(216, 176, 107, 0.35);
  background: rgba(216, 176, 107, 0.08);
  flex-shrink: 0;
}
.sub-nav-back-arrow {
  font-size: 36rpx;
  color: rgba(216, 176, 107, 0.8);
  line-height: 1;
  margin-top: -2rpx;
}
.sub-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #f2e5c8;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  pointer-events: none;
}
.sub-nav-placeholder {
  width: 100rpx;
  flex-shrink: 0;
}


/* ─── CONTENT ─── */
.content { position: relative; z-index: 2; max-width: 760rpx; margin: 0 auto; padding: 0 20rpx 60rpx; }

/* ─── PROFILE HEADER ─── */
.profile-header {
  display: flex; flex-direction: column; align-items: center;
  padding: 28rpx 24rpx 20rpx;
}
.profile-avatar-img {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 3rpx solid rgba(216,176,107,0.45);
  box-shadow: 0 0 24rpx rgba(216,176,107,0.15);
}
.profile-avatar-text {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, #d8b06b, #a88542);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; line-height: 120rpx; text-align: center;
  border: 3rpx solid rgba(216,176,107,0.45);
  box-shadow: 0 0 24rpx rgba(216,176,107,0.15);
}
.profile-nickname {
  color: #f2e5c8; font-size: 32rpx; font-weight: 800;
  letter-spacing: 3rpx; margin-top: 16rpx;
}
.profile-stats-row {
  display: flex; align-items: center; margin-top: 20rpx; width: 100%;
}
.profile-stat {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.profile-stat-sep {
  width: 1rpx; height: 48rpx; background: rgba(216,176,107,0.15); flex-shrink: 0;
}
.profile-stat-num {
  font-size: 44rpx; font-weight: 900; line-height: 1;
}
.profile-stat-unit { font-size: 24rpx; font-weight: 700; }
.profile-stat-blue { color: #4e9eff; text-shadow: 0 0 20rpx rgba(78,158,255,0.3); }
.profile-stat-green { color: #50dc8c; text-shadow: 0 0 20rpx rgba(80,220,140,0.3); }
.profile-stat-gold { color: #f2c84b; text-shadow: 0 0 20rpx rgba(242,200,75,0.3); }
.profile-stat-label {
  font-size: 18rpx; color: rgba(255,255,255,0.25); letter-spacing: 3rpx;
}

/* ─── MODE TABS (inline in profile panel) ─── */
.mode-tabs-inline {
  display: flex; border-top: 1rpx solid rgba(216,176,107,0.10);
}
.mode-tab-inline {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 0 14rpx;
}
.mode-tab-inline-active {
  background: rgba(216,176,107,0.10);
  border-bottom: 3rpx solid rgba(216,176,107,0.5);
}
.mode-tab-inline-text {
  font-size: 26rpx; font-weight: 800; letter-spacing: 2rpx;
  color: rgba(242,229,200,0.3);
}
.mode-tab-inline-active .mode-tab-inline-text {
  color: #f2e5c8;
}
.mode-tab-inline-sub {
  font-size: 18rpx; color: rgba(242,229,200,0.18); margin-top: 2rpx;
}
.mode-tab-inline-active .mode-tab-inline-sub {
  color: rgba(216,176,107,0.5);
}

/* ─── RECENT + STREAK (combined row) ─── */
.ov-recent-streak {
  padding: 20rpx 24rpx 0;
}
.ov-streak-inline {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  margin-bottom: 12rpx;
}
.ov-streak-text {
  font-size: 24rpx; font-weight: 800; letter-spacing: 1rpx;
}

/* ─── PANEL（loading 保留） ─── */
.panel {
  margin-top: 18rpx;
  border-radius: 20rpx;
  background: var(--aw-panel);
  border: 1rpx solid rgba(216,176,107,0.14);
  overflow: hidden;
}
.meta { display: block; margin: 16rpx; color: #cfd8ea; font-size: 22rpx; }

/* ─── 新面板 ─── */
.rs-section { padding: 0; margin-top: 18rpx; overflow: hidden; }
.rs-section-flush { padding: 0; }

/* ◆ 标题行 */
.rs-title-row {
  display: flex; align-items: center; gap: 10rpx;
  padding: 18rpx 20rpx 16rpx;
  border-bottom: 1rpx solid rgba(216,176,107,0.10);
}
.rs-title-line { flex: 1; height: 1rpx; background: linear-gradient(to right, transparent, rgba(216,176,107,0.35)); }
.rs-deco { color: rgba(216,176,107,0.55); font-size: 18rpx; flex-shrink: 0; }
.rs-title { color: #f2e5c8; font-size: 26rpx; font-weight: 700; letter-spacing: 3rpx; flex-shrink: 0; }
.rs-subtitle { color: rgba(216,176,107,0.45); font-size: 20rpx; flex-shrink: 0; }

/* ─── OVERVIEW STATS ROW ─── */
.ov-stats-row {
  display: flex; align-items: center;
  padding: 28rpx 24rpx 24rpx;
  gap: 0;
}
.ov-stat { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.ov-sep { width: 1rpx; height: 56rpx; background: rgba(216,176,107,0.15); flex-shrink: 0; }
.ov-num {
  font-size: 68rpx; font-weight: 900; line-height: 1; letter-spacing: -1rpx;
}
.ov-unit { font-size: 36rpx; font-weight: 700; letter-spacing: 0; }
.ov-num-blue { color: #4e9eff; text-shadow: 0 0 28rpx rgba(78,158,255,0.35); }
.ov-num-green { color: #50dc8c; text-shadow: 0 0 28rpx rgba(80,220,140,0.35); }
.ov-num-gold { color: #f2c84b; text-shadow: 0 0 28rpx rgba(242,200,75,0.35); }
.ov-num-red  { color: #e05050; text-shadow: 0 0 28rpx rgba(224,80,80,0.35); }
.ov-streak-num-row { display: flex; align-items: center; justify-content: center; gap: 8rpx; }
.ov-streak-icon {
  width: 32rpx; height: 32rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ov-streak-icon.ov-streak-win { background: rgba(242,200,75,0.18); }
.ov-streak-icon.ov-streak-lose { background: rgba(224,80,80,0.18); }
.ov-streak-arrow {
  width: 0; height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
}
.ov-streak-win .ov-streak-arrow {
  border-bottom: 10rpx solid #f2c84b;
}
.ov-streak-lose .ov-streak-arrow {
  border-top: 10rpx solid #e05050;
}
.ov-label { font-size: 20rpx; color: rgba(255,255,255,0.28); letter-spacing: 3rpx; }

/* ─── RECENT GAMES ─── */
.ov-recent {
  padding: 0 0 18rpx;
  display: flex; flex-direction: column; align-items: center;
}
.ov-recent-label { font-size: 20rpx; color: rgba(216,176,107,0.45); letter-spacing: 2rpx; margin-bottom: 10rpx; }
.recent-row {
  display: block;
  text-align: center;
  font-size: 26rpx;
  letter-spacing: 6rpx;
  color: #50dc8c;
}

/* ─── FACTION COMPARISON ─── */
.ov-faction { padding: 18rpx 24rpx 24rpx; border-top: 1rpx solid rgba(216,176,107,0.08); }
.ov-faction-pair { display: flex; align-items: center; justify-content: center; }
.ov-faction-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.ov-faction-sep { width: 1rpx; height: 72rpx; background: rgba(216,176,107,0.15); flex-shrink: 0; }
.ov-faction-name { font-size: 22rpx; font-weight: 800; letter-spacing: 3rpx; }
.ov-faction-name.good { color: #7ac7ff; }
.ov-faction-name.evil { color: #ff8a8a; }
.ov-faction-rate { font-size: 38rpx; font-weight: 900; line-height: 1; }
.ov-faction-rate.good { color: #4e9eff; }
.ov-faction-rate.evil { color: #e05050; }
.ov-faction-detail { font-size: 20rpx; }
.ov-faction-detail.good { color: rgba(78,158,255,0.45); }
.ov-faction-detail.evil { color: rgba(224,80,80,0.45); }


/* ─── ROLE GRID ─── */
.role-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.role-card {
  padding: 16rpx 10rpx 18rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  border-right: 1rpx solid rgba(255,255,255,0.05);
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
  position: relative;
}
.role-card:nth-child(2n) { border-right: none; }
.role-card:nth-last-child(1),
.role-card:nth-last-child(2) { border-bottom: none; }

/* Version B: 顶部细色条 */
.role-card-topbar {
  position: absolute; top: 0; left: 0; right: 0; height: 3rpx;
}
.role-card-topbar.good {
  background: linear-gradient(90deg, transparent, rgba(78,158,255,0.7) 50%, transparent);
}
.role-card-topbar.evil {
  background: linear-gradient(90deg, transparent, rgba(220,80,80,0.7) 50%, transparent);
}

/* 圆形胜率环 */
.gauge-wrap { position: relative; width: 130rpx; height: 130rpx; margin-top: 8rpx; }
.gauge-ring {
  position: absolute; top: 0; left: 0;
  width: 130rpx; height: 130rpx; border-radius: 50%;
}
.gauge-inner {
  position: absolute;
  top: 12rpx; left: 12rpx;
  width: 106rpx; height: 106rpx;
  border-radius: 50%;
  background: rgba(14,18,28,0.96);
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.gauge-img { width: 100rpx; height: 100rpx; border-radius: 50%; }
.gauge-emoji { font-size: 56rpx; line-height: 1; }

.rs-role-name { font-size: 22rpx; font-weight: 700; letter-spacing: 1rpx; text-align: center; }
.rs-role-name.good { color: #7ac7ff; }
.rs-role-name.evil { color: #ff8a8a; }

.rs-role-games { font-size: 19rpx; color: rgba(255,255,255,0.3); }

.rs-role-rate { font-size: 30rpx; font-weight: 900; line-height: 1; }
.rs-role-rate.rate-hi { color: #50dc8c; }
.rs-role-rate.rate-lo { color: #ff8080; }
.rs-role-rate.rate-zero { color: rgba(255,255,255,0.18); font-size: 24rpx; }

/* ─── MEDALS ─── */
.medal-section { padding: 16rpx 18rpx; }
.medal-section-sep { border-top: 1rpx solid rgba(255,255,255,0.06); }

.medal-section-title {
  display: block; font-size: 22rpx; font-weight: 700;
  letter-spacing: 2rpx; margin-bottom: 12rpx;
  padding-left: 10rpx;
}
.medal-section-title.good {
  color: #7ac7ff;
  border-left: 4rpx solid rgba(78,158,255,0.6);
}
.medal-section-title.evil {
  color: #ff8a8a;
  border-left: 4rpx solid rgba(220,80,80,0.6);
}

.medal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}
.medal-card {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  padding: 14rpx 6rpx;
  border-radius: 14rpx;
  background: rgba(216,176,107,0.05);
  border: 1rpx solid rgba(216,176,107,0.14);
  text-align: center;
}
.medal-card.medal-zero { opacity: 0.32; }

.medal-img { width: 56rpx; height: 56rpx; }
.medal-emoji { font-size: 40rpx; line-height: 1; }
.medal-name { font-size: 19rpx; color: rgba(242,229,200,0.75); line-height: 1.3; }
.medal-count { font-size: 24rpx; font-weight: 800; color: #d8b06b; }

/* ─── 雷达图 ─── */
.radar-faction-tabs { display: flex; justify-content: center; gap: 24rpx; margin: 16rpx 0 8rpx; }
.radar-tab { padding: 8rpx 32rpx; border-radius: 20rpx; font-size: 26rpx; color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.06); }
.radar-tab-active-good { color: #4e9eff; background: rgba(78,158,255,0.15); }
.radar-tab-active-evil { color: #dc5050; background: rgba(220,80,80,0.15); }
.radar-canvas-wrap { display: flex; justify-content: center; padding: 8rpx 0 16rpx; }
.radar-canvas { width: 640rpx; height: 640rpx; }
.radar-hint { text-align: center; padding: 0 0 16rpx; }
.radar-hint-text { font-size: 22rpx; color: rgba(255,255,255,0.25); }
.title-flip-row { text-align: right; padding: 0 24rpx 8rpx; }
.title-flip-btn { font-size: 22rpx; color: rgba(78,158,255,0.8); padding: 4rpx 16rpx; border: 1rpx solid rgba(78,158,255,0.3); border-radius: 16rpx; }

/* ─── 维度说明（内联展开） ─── */
.radar-tip-inline { padding: 8rpx 48rpx 20rpx; }
.tip-item { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.tip-item:last-child { border-bottom: none; }
.tip-name { font-size: 26rpx; color: rgba(216,176,107,0.9); width: 80rpx; flex-shrink: 0; font-weight: bold; text-align: center; }
.tip-desc { font-size: 24rpx; color: rgba(255,255,255,0.5); flex: 1; margin-left: 20rpx; }

/* ─── 搭档称号 ─── */
.title-scroll { white-space: nowrap; padding: 8rpx 0 16rpx; }
.title-cards { display: inline-flex; gap: 16rpx; padding: 0 20rpx; }
.title-card { display: inline-flex; flex-direction: column; align-items: center; width: 240rpx; padding: 20rpx 12rpx 16rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; border: 1rpx solid rgba(216,176,107,0.12); position: relative; overflow: hidden; }
.title-icon-bg { position: absolute; right: -10rpx; top: -10rpx; width: 120rpx; height: 120rpx; opacity: 0.08; pointer-events: none; }
.title-label { font-size: 22rpx; color: rgba(216,176,107,0.8); margin-bottom: 10rpx; letter-spacing: 1rpx; }
.title-avatar-img { width: 72rpx; height: 72rpx; border-radius: 50%; border: 2rpx solid rgba(216,176,107,0.3); }
.title-avatar-text { font-size: 36rpx; line-height: 72rpx; }
.title-nickname { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200rpx; }
.title-rate-row { display: flex; align-items: center; gap: 8rpx; margin-top: 8rpx; width: 200rpx; }
.title-rate-bar-wrap { flex: 1; height: 8rpx; background: rgba(255,255,255,0.08); border-radius: 4rpx; overflow: hidden; }
.title-rate-bar { height: 100%; border-radius: 4rpx; }
.rate-bar-high { background: linear-gradient(90deg, rgba(52,211,153,0.5), rgba(52,211,153,0.9)); }
.rate-bar-mid { background: linear-gradient(90deg, rgba(216,176,107,0.5), rgba(216,176,107,0.9)); }
.rate-bar-low { background: linear-gradient(90deg, rgba(220,80,80,0.5), rgba(220,80,80,0.9)); }
.title-rate-num { font-size: 22rpx; color: rgba(255,255,255,0.8); flex-shrink: 0; }
.title-games-inline { font-size: 20rpx; color: rgba(255,255,255,0.35); flex-shrink: 0; margin-left: 4rpx; }
.title-flip-card { display: inline-block; }
.title-card-back { border-color: rgba(220,80,80,0.2); }
.title-label-bad { color: rgba(220,80,80,0.8); }

/* ─── 搭档矩阵 ─── */
.partner-list { padding: 0 20rpx 16rpx; }
.partner-row { margin-bottom: 8rpx; background: rgba(255,255,255,0.03); border-radius: 12rpx; overflow: hidden; }
.partner-summary { display: flex; align-items: center; padding: 16rpx 20rpx; gap: 12rpx; }
.partner-avatar-img { width: 52rpx; height: 52rpx; border-radius: 50%; flex-shrink: 0; }
.partner-avatar-text { font-size: 28rpx; width: 52rpx; text-align: center; flex-shrink: 0; }
.partner-name { font-size: 26rpx; color: rgba(255,255,255,0.8); width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex-shrink: 0; }
.partner-games { font-size: 22rpx; color: rgba(255,255,255,0.4); width: 70rpx; text-align: center; flex-shrink: 0; }
.partner-bar-wrap { flex: 1; height: 12rpx; background: rgba(255,255,255,0.08); border-radius: 6rpx; overflow: hidden; }
.partner-bar { height: 100%; background: linear-gradient(90deg, rgba(78,158,255,0.6), rgba(78,158,255,0.9)); border-radius: 6rpx; transition: width 0.3s; }
.partner-rate { font-size: 24rpx; color: rgba(78,158,255,0.9); width: 80rpx; text-align: right; flex-shrink: 0; }

.partner-detail { padding: 8rpx 24rpx 16rpx 84rpx; }
.partner-detail-row { display: flex; justify-content: space-between; padding: 6rpx 0; }
.pd-label { font-size: 24rpx; color: rgba(255,255,255,0.45); }
.pd-value { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.partner-combos { margin-top: 8rpx; }
.combo-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 4rpx; }
.combo-tag { font-size: 20rpx; padding: 4rpx 12rpx; background: rgba(255,255,255,0.06); border-radius: 8rpx; color: rgba(255,255,255,0.5); }

/* ─── 搭档空状态 ─── */
.title-empty { color: rgba(255,255,255,0.3); font-size: 22rpx; }
.partner-empty-tip { padding: 24rpx 0 32rpx; text-align: center; }
.partner-empty-text { font-size: 24rpx; color: rgba(255,255,255,0.3); }

/* ─── Detail Tab ─── */
.detail-tabs { display: flex; justify-content: center; gap: 32rpx; padding: 24rpx 0 8rpx; }
.detail-tab { font-size: 28rpx; color: rgba(255,255,255,0.4); padding: 8rpx 24rpx; border-bottom: 4rpx solid transparent; }
.detail-tab-active { color: rgba(216,176,107,0.9); border-bottom-color: rgba(216,176,107,0.7); }
