<view class="page theme-{{skinId}}">
  <image class="bg" src="{{skinInGameBg}}" mode="aspectFill" />
  <view class="mask"></view>

  <view class="sub-nav" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="sub-nav-inner">
      <view class="sub-nav-back" bindtap="onBackHome"><text class="sub-nav-back-arrow">‹</text></view>
      <text class="sub-nav-title">我的主页</text>
      <view class="sub-nav-placeholder"></view>
    </view>
  </view>

  <view class="content" style="padding-top: {{navTotalHeight + 8}}px; padding-bottom: 120rpx;">

    <!-- ── 用户资料 + PVP/PVE 切换 ── -->
    <view class="pf rs-section">
      <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
      <view class="fb fb-left"></view><view class="fb fb-right"></view>
      <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
      <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
      <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
      <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>

      <view class="profile-header">
        <image class="profile-avatar-img" wx:if="{{avatarImage}}" src="{{avatarImage}}" mode="aspectFill" />
        <text class="profile-avatar-text" wx:else>{{avatarText}}</text>
        <text class="profile-nickname">{{profileNickname}}</text>
        <view class="profile-stats-row">
          <view class="profile-stat">
            <text class="profile-stat-num profile-stat-blue">{{roleStats.totalGames || 0}}</text>
            <text class="profile-stat-label">总对局</text>
          </view>
          <view class="profile-stat-sep"></view>
          <view class="profile-stat">
            <text class="profile-stat-num profile-stat-green">{{roleStats.overallWinRate || 0}}<text class="profile-stat-unit">%</text></text>
            <text class="profile-stat-label">胜率</text>
          </view>
          <view class="profile-stat-sep"></view>
          <view class="profile-stat">
            <text class="profile-stat-num profile-stat-gold">{{medalTotal || 0}}</text>
            <text class="profile-stat-label">勋章</text>
          </view>
        </view>
      </view>

      <view class="mode-toggle" bindtap="onToggleMode">
        <text class="mode-toggle-text">{{mode === 'pvp' ? 'PVP' : 'PVE'}}</text>
        <text class="mode-toggle-icon">⇄</text>
      </view>
    </view>

    <view class="panel" wx:if="{{loading}}">
      <text class="meta">加载中...</text>
    </view>
    <view class="panel" wx:if="{{!loading && !roleStats}}">
      <text class="meta">暂无统计数据</text>
    </view>

    <block wx:if="{{!loading && roleStats}}">

      <!-- ── 近期战绩 + 连胜 + 阵营对比 ── -->
      <view class="pf rs-section">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>

        <!-- 连胜/连败 + 近期战绩 -->
        <view class="ov-recent-streak">
          <view class="ov-streak-inline" wx:if="{{streakType}}">
            <view class="ov-streak-icon {{streakType === 'win' ? 'ov-streak-win' : 'ov-streak-lose'}}">
              <view class="ov-streak-arrow"></view>
            </view>
            <text class="ov-streak-text {{streakType === 'win' ? 'ov-num-gold' : 'ov-num-red'}}">{{streakType === 'win' ? '连胜' : '连败'}} {{streakCount}}</text>
          </view>
          <view class="ov-recent" wx:if="{{recentGames.length}}">
            <text class="ov-recent-label">近期战绩</text>
            <text class="recent-row">{{recentDotsText}}</text>
          </view>
        </view>

        <!-- 阵营对比 -->
        <view class="ov-faction">
          <view class="ov-faction-pair">
            <view class="ov-faction-col">
              <text class="ov-faction-name good">正义</text>
              <text class="ov-faction-rate good">{{goodSummary.winRate}}%</text>
              <text class="ov-faction-detail good">{{goodSummary.wins}}胜 / {{goodSummary.total}}局</text>
            </view>
            <view class="ov-faction-sep"></view>
            <view class="ov-faction-col">
              <text class="ov-faction-name evil">邪恶</text>
              <text class="ov-faction-rate evil">{{evilSummary.winRate}}%</text>
              <text class="ov-faction-detail evil">{{evilSummary.wins}}胜 / {{evilSummary.total}}局</text>
            </view>
          </view>
        </view>

        <!-- 趋势图 -->
        <view class="trend-wrap" wx:if="{{trendData}}">
          <canvas id="trendCanvas" type="2d" class="trend-canvas" style="width:320px;height:100px;"></canvas>
        </view>
      </view>

      <!-- ── 能力雷达 ── -->
      <view class="radar-faction-tabs" wx:if="{{radarData}}">
        <view class="radar-tab {{radarFaction === 'good' ? 'radar-tab-active' : ''}}" data-faction="good" bindtap="onSwitchRadar">正义</view>
        <view class="radar-tab {{radarFaction === 'evil' ? 'radar-tab-active' : ''}}" data-faction="evil" bindtap="onSwitchRadar">邪恶</view>
      </view>
      <view class="pf rs-section radar-section" wx:if="{{radarData}}">
        <view class="radar-help-btn" bindtap="onRadarHelp"><text class="help-btn-q">?</text></view>
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
        <view class="radar-canvas-wrap">
          <canvas id="radarCanvas" type="2d" class="radar-canvas" style="width:320px;height:320px;"></canvas>
        </view>
      </view>

      <!-- ── 搭档称号 ── -->
      <view class="pf rs-section partner-section">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
        <view class="rs-title-row">
          <view class="rs-title-line"></view>
          <text class="rs-deco">◆</text>
          <text class="rs-title">搭档称号</text>
          <view class="help-btn" bindtap="onPartnerHelp"><text class="help-btn-q">?</text></view>
          <text class="rs-deco">◆</text>
          <view class="rs-title-line"></view>
        </view>
        <scroll-view scroll-x class="title-scroll" wx:if="{{partnerTitles.length}}">
          <view class="title-cards">
            <view class="title-flip-card" wx:for="{{partnerTitles}}" wx:key="index" bindtap="onFlipTitle" data-idx="{{index}}">
              <!-- 用 flipped 控制显示正面还是反面 -->
              <block wx:if="{{!item.flipped}}">
                <view class="title-card title-card-front">
                  <image class="title-icon-bg" src="{{item.front.iconUrl}}" mode="aspectFit" />
                  <text class="title-label">{{item.front.label}}</text>
                  <block wx:if="{{item.front.nickname}}">
                    <image class="title-avatar-img" wx:if="{{item.front.avatarImage}}" src="{{item.front.avatarImage}}" mode="aspectFill" />
                    <text class="title-avatar-text" wx:else>{{item.front.avatarText}}</text>
                    <text class="title-nickname">{{item.front.nickname}}</text>
                    <view class="title-rate-row">
                      <view class="title-rate-bar-wrap">
                        <view class="title-rate-bar {{item.front.winRate >= 60 ? 'rate-bar-high' : item.front.winRate >= 40 ? 'rate-bar-mid' : 'rate-bar-low'}}" style="width:{{item.front.winRate}}%"></view>
                      </view>
                      <text class="title-rate-num">{{item.front.winRate}}%</text>
                      <text class="title-games-inline">{{item.front.games}}局</text>
                    </view>
                  </block>
                  <block wx:else>
                    <view class="title-avatar-empty">?</view>
                    <text class="title-nickname">未知</text>
                    <text class="title-empty-hint">需{{partnerMinGames}}局以上</text>
                    <view class="title-rate-placeholder"></view>
                  </block>
                </view>
              </block>
              <block wx:else>
                <view class="title-card title-card-back">
                  <image class="title-icon-bg" src="{{item.back.iconUrl}}" mode="aspectFit" />
                  <text class="title-label title-label-bad">{{item.back.label}}</text>
                  <block wx:if="{{item.back.nickname}}">
                    <image class="title-avatar-img" wx:if="{{item.back.avatarImage}}" src="{{item.back.avatarImage}}" mode="aspectFill" />
                    <text class="title-avatar-text" wx:else>{{item.back.avatarText}}</text>
                    <text class="title-nickname">{{item.back.nickname}}</text>
                    <view class="title-rate-row">
                      <view class="title-rate-bar-wrap">
                        <view class="title-rate-bar {{item.back.winRate >= 60 ? 'rate-bar-high' : item.back.winRate >= 40 ? 'rate-bar-mid' : 'rate-bar-low'}}" style="width:{{item.back.winRate}}%"></view>
                      </view>
                      <text class="title-rate-num">{{item.back.winRate}}%</text>
                      <text class="title-games-inline">{{item.back.games}}局</text>
                    </view>
                  </block>
                  <block wx:else>
                    <view class="title-avatar-empty">?</view>
                    <text class="title-nickname">未知</text>
                    <text class="title-empty-hint">需{{partnerMinGames}}局以上</text>
                    <view class="title-rate-placeholder"></view>
                  </block>
                </view>
              </block>
            </view>
          </view>
        </scroll-view>
        <view class="partner-empty-tip" wx:if="{{!partnerTitles.length}}">
          <text class="partner-empty-text">多和好友一起玩，就能看到搭档称号啦</text>
        </view>
      </view>

      <!-- ── 搭档数据（暂隐藏，待多人局数据充足后开放） ── -->

      <!-- ── Detail Tabs ── -->
      <view class="detail-tabs">
        <view class="detail-tab {{detailTab === 'roles' ? 'detail-tab-active' : ''}}" data-tab="roles" bindtap="onSwitchDetailTab">角色统计</view>
        <view class="detail-tab {{detailTab === 'medals' ? 'detail-tab-active' : ''}}" data-tab="medals" bindtap="onSwitchDetailTab">勋章墙</view>
      </view>

      <!-- ── 角色统计 (tab) ── -->
      <view class="pf rs-section rs-section-flush" wx:if="{{detailTab === 'roles'}}">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
        <view class="rs-title-row">
          <view class="rs-title-line"></view>
          <text class="rs-deco">◆</text>
          <text class="rs-title">角色统计</text>
          <text class="rs-deco">◆</text>
          <view class="rs-title-line"></view>
        </view>
        <view class="role-grid">
          <view class="role-card" wx:for="{{statsList}}" wx:key="role">
            <view class="role-card-topbar {{item.faction}}"></view>
            <view class="gauge-wrap">
              <view class="gauge-ring" style="background: conic-gradient({{item.faction==='good'?'rgba(78,158,255,0.88)':'rgba(220,80,80,0.88)'}} {{item.rateDeg}}deg, {{item.faction==='good'?'rgba(78,158,255,0.10)':'rgba(220,80,80,0.10)'}} 0deg)"></view>
              <view class="gauge-inner">
                <image class="gauge-img" wx:if="{{item.roleImage}}" src="{{item.roleImage}}" mode="aspectFill" />
                <text class="gauge-emoji" wx:else>🎭</text>
              </view>
            </view>
            <text class="rs-role-name {{item.faction}}">{{item.role}}</text>
            <text class="rs-role-games">{{item.total > 0 ? item.total+'局 / '+item.wins+'胜' : '未出场'}}</text>
            <text class="rs-role-rate {{item.total > 0 ? (item.winRate >= 50 ? 'rate-hi' : 'rate-lo') : 'rate-zero'}}">{{item.total > 0 ? item.winRate+'%' : '—'}}</text>
          </view>
        </view>
      </view>

      <!-- ── 勋章墙 (tab) ── -->
      <block wx:if="{{detailTab === 'medals'}}">
        <!-- 正义勋章 -->
        <view class="pf rs-section" wx:if="{{goodMedals.length}}">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
          <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
          <view class="rs-title-row">
            <view class="rs-title-line"></view>
            <text class="rs-deco">◆</text>
            <text class="rs-title">正义勋章</text>
            <text class="rs-deco">◆</text>
            <view class="rs-title-line"></view>
          </view>
          <view class="medal-section">
            <view class="medal-grid">
              <view class="medal-card {{item.total > 0 ? '' : 'medal-zero'}}" wx:for="{{goodMedals}}" wx:key="code" catchtap="onTapMedal" data-name="{{item.name}}" data-description="{{item.description}}">
                <image class="medal-img" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFit" />
                <text class="medal-emoji" wx:else>🏅</text>
                <text class="medal-name">{{item.name}}</text>
                <text class="medal-count">{{item.total}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 邪恶勋章 -->
        <view class="pf rs-section" wx:if="{{evilMedals.length}}">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
          <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
          <view class="rs-title-row">
            <view class="rs-title-line"></view>
            <text class="rs-deco">◆</text>
            <text class="rs-title">邪恶勋章</text>
            <text class="rs-deco">◆</text>
            <view class="rs-title-line"></view>
          </view>
          <view class="medal-section">
            <view class="medal-grid">
              <view class="medal-card {{item.total > 0 ? '' : 'medal-zero'}}" wx:for="{{evilMedals}}" wx:key="code" catchtap="onTapMedal" data-name="{{item.name}}" data-description="{{item.description}}">
                <image class="medal-img" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFit" />
                <text class="medal-emoji" wx:else>🏅</text>
                <text class="medal-name">{{item.name}}</text>
                <text class="medal-count">{{item.total}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 角色专属勋章 -->
        <view class="pf rs-section" wx:if="{{roleMedals.length}}">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
          <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
          <view class="rs-title-row">
            <view class="rs-title-line"></view>
            <text class="rs-deco">◆</text>
            <text class="rs-title">角色专属</text>
            <text class="rs-deco">◆</text>
            <view class="rs-title-line"></view>
          </view>
          <view class="medal-section">
            <view class="medal-grid">
              <view class="medal-card {{item.total > 0 ? '' : 'medal-zero'}}" wx:for="{{roleMedals}}" wx:key="code" catchtap="onTapMedal" data-name="{{item.name}}" data-description="{{item.description}}">
                <image class="medal-img" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFit" />
                <text class="medal-emoji" wx:else>🏅</text>
                <text class="medal-name">{{item.name}}</text>
                <text class="medal-count">{{item.total}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>

    </block>
  </view>

  <!-- ── 自定义帮助弹窗 ── -->
  <view class="help-overlay" wx:if="{{helpVisible}}" bindtap="onCloseHelp">
    <view class="help-dialog" catchtap="">
      <text class="help-title">{{helpTitle}}</text>
      <view class="help-item" wx:for="{{helpItems}}" wx:key="name">
        <text class="help-item-name">{{item.name}}</text>
        <text class="help-item-desc">{{item.desc}}</text>
      </view>
      <view class="help-close" bindtap="onCloseHelp">
        <text class="help-close-text">知道了</text>
      </view>
    </view>
  </view>

  <tab-bar active="mine" />
</view>
