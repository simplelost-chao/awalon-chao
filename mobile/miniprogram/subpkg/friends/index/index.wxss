/* ─── PAGE ─── */
.page { min-height: 100vh; position: relative; background: var(--aw-bg); }
.bg, .mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; }
.bg { width: 100vw; height: 100vh; }
.mask { background: linear-gradient(180deg, rgba(6,8,16,0.72) 0%, rgba(8,10,20,0.88) 40%, rgba(6,8,16,0.96) 100%); }

.theme-celestial .bg, .theme-ink-wash .bg { display: none; }
.theme-celestial .mask, .theme-ink-wash .mask { background: none; }

.sub-nav { position: fixed; left: 0; right: 0; top: 0; z-index: 20; background: rgba(6, 8, 15, 0.92); border-bottom: 1rpx solid rgba(216, 176, 107, 0.14); }
.sub-nav-inner { position: relative; height: 40px; display: flex; align-items: center; justify-content: space-between; padding: 0 8rpx; }
.sub-nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.sub-nav-back-arrow { font-size: 44rpx; color: rgba(216,176,107,0.7); font-weight: 300; }
.sub-nav-title { font-size: 32rpx; font-weight: 700; color: #f0e0b0; letter-spacing: 4rpx; text-align: center; flex: 1; }
.sub-nav-placeholder { width: 60rpx; }

.content { position: relative; z-index: 1; padding: 0 20rpx; }

/* ─── Friend sections ─── */
.friend-section { margin-top: 16rpx; padding: 16rpx 20rpx; overflow: hidden; }
.friend-section-title { display: block; font-size: 26rpx; font-weight: 700; color: rgba(216,176,107,0.85); margin-bottom: 12rpx; letter-spacing: 2rpx; }

.friend-request, .friend-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.friend-request:last-child, .friend-item:last-child { border-bottom: none; }

/* ─── 好友网格 ─── */
.friend-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.friend-card { width: calc(50% - 8rpx); }
.friend-card-inner {
  display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 12rpx 16rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(216,176,107,0.1);
  border-radius: 16rpx;
  position: relative;
}

/* 头像 + 在线指示灯 */
.friend-avatar-wrap { position: relative; margin-bottom: 8rpx; }
.friend-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; border: 2rpx solid rgba(216,176,107,0.25); }
.friend-avatar-text { font-size: 44rpx; width: 88rpx; height: 88rpx; line-height: 88rpx; text-align: center; display: block; }
.friend-dot { position: absolute; right: 2rpx; bottom: 2rpx; width: 20rpx; height: 20rpx; border-radius: 50%; border: 3rpx solid rgba(10,8,16,0.9); }
.friend-dot-on { background: #34d399; box-shadow: 0 0 8rpx rgba(52,211,153,0.6); }
.friend-dot-off { background: rgba(255,255,255,0.2); }

/* 昵称 + 状态 */
.friend-name { font-size: 26rpx; color: rgba(255,255,255,0.85); font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; text-align: center; }
.friend-status { font-size: 20rpx; margin-top: 4rpx; }
.friend-online { color: rgba(52,211,153,0.8); }
.friend-offline { color: rgba(255,255,255,0.25); }

/* 加入按钮 */
.friend-join-btn { margin-top: 10rpx; padding: 6rpx 20rpx; border-radius: 999rpx; background: rgba(78,158,255,0.12); border: 1rpx solid rgba(78,158,255,0.35); }
.friend-join-text { font-size: 20rpx; color: #4e9eff; }

/* 请求 */
.friend-request { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05); }
.friend-request:last-child { border-bottom: none; }
.friend-request .friend-avatar { width: 72rpx; height: 72rpx; }
.friend-request .friend-avatar-text { width: 72rpx; height: 72rpx; line-height: 72rpx; font-size: 36rpx; }
.friend-request .friend-info { flex: 1; min-width: 0; }
.friend-request .friend-name { text-align: left; }
.friend-request-actions { display: flex; gap: 12rpx; flex-shrink: 0; }
.friend-btn { padding: 8rpx 24rpx; border-radius: 999rpx; font-size: 22rpx; }
.friend-btn-accept { background: rgba(52,211,153,0.12); border: 1rpx solid rgba(52,211,153,0.35); color: #34d399; }
.friend-btn-reject { background: rgba(220,80,80,0.08); border: 1rpx solid rgba(220,80,80,0.25); color: rgba(220,80,80,0.7); }

.friend-empty { padding: 60rpx 0; text-align: center; }
.friend-empty-text { font-size: 24rpx; color: rgba(255,255,255,0.25); }
