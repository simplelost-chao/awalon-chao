/* ─── RESET & PAGE ─────────────────────────────────── */
.page {
  min-height: 100vh;
  position: relative;
  background: var(--aw-bg);
}

.bg, .mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg,
    rgba(6, 8, 16, 0.72) 0%,
    rgba(8, 10, 20, 0.88) 40%,
    rgba(6, 8, 16, 0.96) 100%);
}

@import '../../../styles/theme-overrides.wxss';
@import '../../../styles/round-table.wxss';

/* ─── SCROLL ───────────────────────────────────────── */
.replay-scroll {
  position: relative;
  z-index: 1;
  padding: 0 20rpx 180rpx;
  box-sizing: border-box;
}

/* ─── LOADING ───────────────────────────────────────── */
.panel {
  margin-top: 18rpx;
  padding: 32rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ─── 补充 round-table 组件依赖的样式（主页面才有） ─── */
.seat-avatar-img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
.seat-avatar { overflow: hidden !important; }
.seat-card image { max-width: 84rpx; max-height: 84rpx; }
.seat-avatar-empty-text { font-size: 36rpx; font-weight: 200; color: rgba(255,255,255,0.3); line-height: 1; }
.seat-av-team { border-color: rgba(80,230,140,1) !important; box-shadow: 0 0 0 4rpx rgba(60,200,110,0.35), 0 0 20rpx rgba(60,200,110,0.5); }
.seat-av-me { border-color: rgba(216,176,107,0.85) !important; }
.seat-name-team { color: #7df5aa !important; text-shadow: 0 0 12rpx rgba(60,200,110,0.9); }
.seat-no-team { background: rgba(50,200,120,0.85) !important; color: #fff !important; border-color: rgba(80,230,140,0.6) !important; }
.seat-status-badge { position: absolute; top: -8rpx; left: 50%; transform: translateX(-50%); z-index: 10; padding: 2rpx 12rpx; border-radius: 999rpx; font-size: 16rpx; white-space: nowrap; }
.seat-badge-voted { background: rgba(52,211,153,0.2); color: rgba(52,211,153,0.9); border: 1rpx solid rgba(52,211,153,0.3); }
.seat-badge-voting { background: rgba(220,80,80,0.2); color: rgba(220,80,80,0.9); border: 1rpx solid rgba(220,80,80,0.3); }

/* ─── STEP PANEL ───────────────────────────────────── */
.step-panel {
  padding: 20rpx;
  margin: 24rpx 4rpx 20rpx;
}

.step-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(216, 176, 107, 0.9);
  text-align: center;
  margin-bottom: 8rpx;
}

.step-title-end {
  font-size: 40rpx;
  font-weight: 900;
}

.step-title-good {
  color: rgba(78, 158, 255, 0.9);
}

.step-title-evil {
  color: rgba(220, 80, 80, 0.9);
}

.step-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  margin-bottom: 12rpx;
}

.step-sub-good {
  color: rgba(78, 158, 255, 0.8);
}

.step-sub-evil {
  color: rgba(220, 80, 80, 0.8);
}

.step-result {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-top: 12rpx;
}

/* ─── TEAM MEMBERS ─────────────────────────────────── */
.step-team {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: center;
}

.step-team-member {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.step-team-good {
  background: rgba(78, 158, 255, 0.12);
  color: rgba(78, 158, 255, 0.9);
  border: 1rpx solid rgba(78, 158, 255, 0.3);
}

.step-team-evil {
  background: rgba(220, 80, 80, 0.12);
  color: rgba(220, 80, 80, 0.9);
  border: 1rpx solid rgba(220, 80, 80, 0.3);
}

.step-team-merlin {
  background: rgba(167, 139, 250, 0.12);
  color: rgba(167, 139, 250, 0.9);
  border: 1rpx solid rgba(167, 139, 250, 0.3);
}

/* ─── VOTE / MISSION LIST ──────────────────────────── */
.step-vote-list {
  margin-top: 4rpx;
}

.step-vote-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  margin-bottom: 4rpx;
  border-radius: 8rpx;
}

.step-vote-good {
  background: rgba(78, 158, 255, 0.06);
}

.step-vote-evil {
  background: rgba(220, 80, 80, 0.06);
}

.step-vote-merlin {
  background: rgba(167, 139, 250, 0.06);
}

.step-vote-seat {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  width: 60rpx;
  flex-shrink: 0;
}

.step-vote-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: 1;
}

.step-vote-role {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.step-role-good {
  color: rgba(78, 158, 255, 0.8);
  background: rgba(78, 158, 255, 0.1);
}

.step-role-evil {
  color: rgba(220, 80, 80, 0.8);
  background: rgba(220, 80, 80, 0.1);
}

.step-role-merlin {
  color: rgba(167, 139, 250, 0.8);
  background: rgba(167, 139, 250, 0.1);
}

.step-vote-val {
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-approve {
  color: #34d399;
}

.step-reject {
  color: #f87171;
}

/* ─── STEP NAVIGATION ──────────────────────────────── */
.step-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(6, 8, 16, 0) 0%, rgba(6, 8, 16, 0.95) 30%);
  z-index: 10;
}

.step-btn {
  padding: 14rpx 32rpx;
  border: 2rpx solid rgba(216, 176, 107, 0.5);
  border-radius: 12rpx;
  background: rgba(216, 176, 107, 0.08);
}

.step-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(216, 176, 107, 0.9);
}

.step-btn-disabled {
  opacity: 0.3;
  border-color: rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.03);
}

.step-btn-disabled .step-btn-text {
  color: rgba(255, 255, 255, 0.3);
}

.step-progress {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 600;
}
