/* ─── RESET & PAGE ─────────────────────────────────── */
.page {
  min-height: 100vh;
  position: relative;
  background: var(--aw-bg);
}

.bg, .mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg,
    rgba(6, 8, 16, 0.72) 0%,
    rgba(8, 10, 20, 0.88) 40%,
    rgba(6, 8, 16, 0.96) 100%);
}

@import '../../../styles/theme-overrides.wxss';
@import '../../../styles/round-table.wxss';

/* ─── SCROLL ───────────────────────────────────────── */
.replay-scroll {
  position: fixed;
  left: 0; right: 0; bottom: 120rpx;
  z-index: 1;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* ─── LOADING ───────────────────────────────────────── */
.panel {
  margin-top: 18rpx;
  padding: 32rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ─── ROUND TABLE ──────────────────────────────────── */
.replay-table-wrap {
  position: relative;
  width: 440rpx;
  height: 440rpx;
  margin: 8rpx auto 0;
}

.replay-table-bg {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  opacity: 0.5;
}

/* ─── SEAT ─────────────────────────────────────────── */
.replay-seat {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  margin-left: -60rpx;
  margin-top: -50rpx;
}

/* ─── AVATAR WRAP ──────────────────────────────────── */
.replay-avatar-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: visible;
}

.replay-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.replay-avatar-good {
  border-color: rgba(78, 158, 255, 0.6);
}

.replay-avatar-evil {
  border-color: rgba(220, 80, 80, 0.6);
}

.replay-avatar-merlin {
  border-color: rgba(167, 139, 250, 0.6);
}

.replay-avatar-text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.08);
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.replay-avatar-text-good {
  border-color: rgba(78, 158, 255, 0.6);
  background: rgba(78, 158, 255, 0.1);
}

.replay-avatar-text-evil {
  border-color: rgba(220, 80, 80, 0.6);
  background: rgba(220, 80, 80, 0.1);
}

.replay-avatar-text-merlin {
  border-color: rgba(167, 139, 250, 0.6);
  background: rgba(167, 139, 250, 0.1);
}

/* ─── HIGHLIGHTS ───────────────────────────────────── */
.replay-in-team .replay-avatar,
.replay-in-team .replay-avatar-text {
  border-color: #34d399 !important;
  box-shadow: 0 0 16rpx rgba(52, 211, 153, 0.5);
}

.replay-is-leader .replay-avatar,
.replay-is-leader .replay-avatar-text {
  border-color: rgba(216, 176, 107, 0.9) !important;
  box-shadow: 0 0 16rpx rgba(216, 176, 107, 0.6);
}

/* ─── LABEL (vote/mission overlay) ─────────────────── */
.replay-label {
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 16rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}

.replay-label-approve {
  color: #fff;
  background: rgba(52, 211, 153, 0.85);
}

.replay-label-reject {
  color: #fff;
  background: rgba(248, 113, 113, 0.85);
}

.replay-label-success {
  color: #fff;
  background: rgba(52, 211, 153, 0.85);
}

.replay-label-fail {
  color: #fff;
  background: rgba(248, 113, 113, 0.85);
}

/* ─── SEAT INFO ────────────────────────────────────── */
.replay-seat-no {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 2rpx;
  line-height: 1.2;
}

.replay-seat-name {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.7);
  max-width: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.2;
}

.replay-role-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 2rpx;
}

.replay-role-img {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}

.replay-role-name {
  font-size: 16rpx;
  line-height: 1.2;
}

.replay-role-good {
  color: rgba(78, 158, 255, 0.8);
}

.replay-role-evil {
  color: rgba(220, 80, 80, 0.8);
}

.replay-role-merlin {
  color: rgba(167, 139, 250, 0.8);
}

/* ─── STEP SCROLL ──────────────────────────────────── */
.step-scroll {
  max-height: 420rpx;
  margin-top: 16rpx;
}

/* ─── STEP PANEL ───────────────────────────────────── */
.step-panel {
  padding: 20rpx;
  margin: 24rpx 4rpx 20rpx;
}

.step-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(216, 176, 107, 0.9);
  text-align: center;
  margin-bottom: 8rpx;
}

.step-title-end {
  font-size: 40rpx;
  font-weight: 900;
}

.step-title-good {
  color: rgba(78, 158, 255, 0.9);
}

.step-title-evil {
  color: rgba(220, 80, 80, 0.9);
}

.step-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  margin-bottom: 12rpx;
}

.step-sub-good {
  color: rgba(78, 158, 255, 0.8);
}

.step-sub-evil {
  color: rgba(220, 80, 80, 0.8);
}

.step-result {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-top: 12rpx;
}

/* ─── TEAM MEMBERS ─────────────────────────────────── */
.step-team {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: center;
}

.step-team-member {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.step-team-good {
  background: rgba(78, 158, 255, 0.12);
  color: rgba(78, 158, 255, 0.9);
  border: 1rpx solid rgba(78, 158, 255, 0.3);
}

.step-team-evil {
  background: rgba(220, 80, 80, 0.12);
  color: rgba(220, 80, 80, 0.9);
  border: 1rpx solid rgba(220, 80, 80, 0.3);
}

.step-team-merlin {
  background: rgba(167, 139, 250, 0.12);
  color: rgba(167, 139, 250, 0.9);
  border: 1rpx solid rgba(167, 139, 250, 0.3);
}

/* ─── VOTE / MISSION LIST ──────────────────────────── */
.step-vote-list {
  margin-top: 4rpx;
}

.step-vote-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  margin-bottom: 4rpx;
  border-radius: 8rpx;
}

.step-vote-good {
  background: rgba(78, 158, 255, 0.06);
}

.step-vote-evil {
  background: rgba(220, 80, 80, 0.06);
}

.step-vote-merlin {
  background: rgba(167, 139, 250, 0.06);
}

.step-vote-seat {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  width: 60rpx;
  flex-shrink: 0;
}

.step-vote-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: 1;
}

.step-vote-role {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.step-role-good {
  color: rgba(78, 158, 255, 0.8);
  background: rgba(78, 158, 255, 0.1);
}

.step-role-evil {
  color: rgba(220, 80, 80, 0.8);
  background: rgba(220, 80, 80, 0.1);
}

.step-role-merlin {
  color: rgba(167, 139, 250, 0.8);
  background: rgba(167, 139, 250, 0.1);
}

.step-vote-val {
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-approve {
  color: #34d399;
}

.step-reject {
  color: #f87171;
}

/* ─── STEP NAVIGATION ──────────────────────────────── */
.step-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(6, 8, 16, 0) 0%, rgba(6, 8, 16, 0.95) 30%);
  z-index: 10;
}

.step-btn {
  padding: 14rpx 32rpx;
  border: 2rpx solid rgba(216, 176, 107, 0.5);
  border-radius: 12rpx;
  background: rgba(216, 176, 107, 0.08);
}

.step-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(216, 176, 107, 0.9);
}

.step-btn-disabled {
  opacity: 0.3;
  border-color: rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.03);
}

.step-btn-disabled .step-btn-text {
  color: rgba(255, 255, 255, 0.3);
}

.step-progress {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 600;
}
