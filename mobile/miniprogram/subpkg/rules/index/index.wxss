/* ─── PAGE ─── */
.page { min-height: 100vh; position: relative; background: var(--aw-bg); }
.bg, .mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; }
.bg { width: 100vw; height: 100vh; }
.mask { background: linear-gradient(180deg, rgba(6,8,16,0.72) 0%, rgba(8,10,20,0.88) 40%, rgba(6,8,16,0.96) 100%); }
.theme-celestial .bg, .theme-ink-wash .bg { display: none; }
.theme-celestial .mask, .theme-ink-wash .mask { background: none; }

.content {
  position: relative; z-index: 2; height: 100vh; box-sizing: border-box;
  max-width: 760rpx; margin: 0 auto; padding: 0 20rpx 0;
  display: flex; flex-direction: column;
}
.tab-content {
  flex: 1; padding-bottom: 60rpx;
}

/* ─── Panel base ─── */
.rules-panel { margin-top: 18rpx; padding: 0; overflow: hidden; }

/* ─── Title row (reuse role-stats style) ─── */
.rs-title-row {
  display: flex; align-items: center; gap: 10rpx;
  padding: 18rpx 20rpx 16rpx;
  border-bottom: 1rpx solid rgba(216,176,107,0.10);
}
.rs-title-line { flex: 1; height: 1rpx; background: linear-gradient(to right, transparent, rgba(216,176,107,0.35)); }
.rs-deco { color: rgba(216,176,107,0.55); font-size: 18rpx; flex-shrink: 0; }
.rs-title { color: #f2e5c8; font-size: 26rpx; font-weight: 700; letter-spacing: 3rpx; flex-shrink: 0; }

/* ─── Tab bar ─── */
.tab-panel { margin-top: 10rpx; overflow: visible; }
.tab-bar {
  display: flex; border-top: 1rpx solid rgba(216,176,107,0.10);
  position: relative; z-index: 3;
}
.tab-item {
  flex: 1; text-align: center; padding: 18rpx 0 16rpx;
  font-size: 25rpx; font-weight: 700; letter-spacing: 2rpx;
  color: rgba(242,229,200,0.3);
}
.tab-active {
  color: #f2e5c8;
  background: rgba(216,176,107,0.10);
  border-bottom: 4rpx solid rgba(216,176,107,0.5);
}

/* ─── Intro ─── */
.intro-inner { padding: 22rpx 20rpx 20rpx; }
.intro-headline {
  display: block; color: #f2e5c8; font-size: 30rpx; font-weight: 800;
  letter-spacing: 2rpx; margin-bottom: 14rpx;
}
.intro-body {
  display: block; color: rgba(220,210,185,0.85); font-size: 25rpx; line-height: 1.8;
  margin-bottom: 18rpx;
}
.intro-tag-row { display: flex; gap: 12rpx; flex-wrap: wrap; }
.intro-tag {
  background: rgba(216,176,107,0.12); border: 1rpx solid rgba(216,176,107,0.30);
  border-radius: 999rpx; padding: 6rpx 20rpx; font-size: 22rpx; color: #d8b06b;
}

/* ─── Journey steps ─── */
.journey-list { padding: 10rpx 16rpx 18rpx; }
.journey-card {
  margin-top: 14rpx; padding: 16rpx;
  border-radius: 0; border: 1rpx solid rgba(216,176,107,0.12);
  background: rgba(216,176,107,0.04);
}
.journey-head { display: flex; align-items: center; gap: 14rpx; }
.journey-step {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #0f1320; font-size: 24rpx; font-weight: 900;
  background: linear-gradient(135deg, #f6deb0, #d7a45f); flex-shrink: 0;
}
.journey-title { color: #f2e5c8; font-size: 26rpx; font-weight: 700; letter-spacing: 1rpx; }
.journey-points { margin-top: 10rpx; }
.journey-point {
  margin-top: 8rpx; padding-left: 8rpx;
  color: rgba(210,220,238,0.85); font-size: 23rpx; line-height: 1.65;
}

/* ─── Win conditions ─── */
.win-section { padding: 14rpx 16rpx 18rpx; }
.win-row {
  margin-top: 12rpx; padding: 16rpx; border-radius: 0;
  display: flex; align-items: flex-start; gap: 14rpx;
}
.win-icon { font-size: 32rpx; line-height: 1; flex-shrink: 0; margin-top: 2rpx; }
.win-body { flex: 1; }
.win-label { display: block; font-size: 24rpx; font-weight: 700; color: #f2e5c8; margin-bottom: 6rpx; }
.win-desc { display: block; font-size: 23rpx; color: rgba(210,220,238,0.85); line-height: 1.6; }
.good-win { background: rgba(78,158,255,0.08); border: 1rpx solid rgba(78,158,255,0.18); }
.evil-win { background: rgba(220,80,80,0.08); border: 1rpx solid rgba(220,80,80,0.18); }

/* ─── Roles ─── */
.role-list { padding: 8rpx 16rpx 18rpx; }
.role-item {
  margin-top: 12rpx; padding: 14rpx 16rpx;
  border: 1rpx solid rgba(216,176,107,0.10);
  background: rgba(216,176,107,0.03);
}
.role-head { display: flex; align-items: center; gap: 10rpx; }
.role-avatar {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  border: 1rpx solid rgba(216,176,107,0.3);
}
.role-name {
  display: inline-block; font-size: 24rpx; font-weight: 700;
  padding: 4rpx 14rpx; border-radius: 999rpx;
}
.role-name.good { color: #eaf2ff; background: rgba(78,158,255,0.5); }
.role-name.evil { color: #fff; background: rgba(220,80,80,0.55); }
.role-desc {
  display: block; margin-top: 10rpx;
  color: rgba(210,220,238,0.85); font-size: 23rpx; line-height: 1.65;
}
.role-tip {
  display: block; margin-top: 8rpx; padding: 10rpx 12rpx;
  background: rgba(216,176,107,0.06); border-radius: 8rpx;
  color: rgba(216,176,107,0.7); font-size: 22rpx; line-height: 1.55;
}

/* ─── Mechanics ─── */
.mech-list { padding: 8rpx 16rpx 18rpx; }
.mech-item {
  margin-top: 14rpx; display: flex; align-items: flex-start; gap: 14rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(216,176,107,0.10);
  background: rgba(216,176,107,0.03);
}
.mech-icon { font-size: 36rpx; line-height: 1; flex-shrink: 0; margin-top: 2rpx; }
.mech-body { flex: 1; }
.mech-name { display: block; color: #f2e5c8; font-size: 24rpx; font-weight: 700; margin-bottom: 6rpx; }
.mech-desc { display: block; color: rgba(210,220,238,0.85); font-size: 23rpx; line-height: 1.6; }

/* ─── Beginner tips ─── */
.tip-panel { margin-bottom: 40rpx; }
.tip-list { padding: 10rpx 20rpx 18rpx; }
.tip-item {
  margin-top: 10rpx; padding-left: 10rpx;
  color: rgba(210,220,238,0.85); font-size: 23rpx; line-height: 1.65;
  border-left: 3rpx solid rgba(216,176,107,0.3);
  padding: 4rpx 0 4rpx 14rpx;
}

/* ─── Flow chart ─── */
.flow-chart { padding: 20rpx 16rpx 24rpx; }
.flow-row {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
}
.flow-node {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  padding: 12rpx 16rpx; border: 1rpx solid rgba(216,176,107,0.2);
  background: rgba(216,176,107,0.06); min-width: 100rpx;
}
.flow-node-start { border-color: rgba(78,158,255,0.3); background: rgba(78,158,255,0.08); }
.flow-node-repeat { border-color: rgba(216,176,107,0.3); border-style: dashed; }
.flow-icon { font-size: 28rpx; line-height: 1; }
.flow-label { font-size: 20rpx; color: #f2e5c8; font-weight: 700; }
.flow-arrow { color: rgba(216,176,107,0.5); font-size: 24rpx; flex-shrink: 0; }
.flow-return-row {
  display: flex; align-items: center; justify-content: center;
  margin: 8rpx 0; gap: 8rpx;
}
.flow-return-line { width: 40rpx; height: 1rpx; background: rgba(220,80,80,0.3); }
.flow-return-text { font-size: 18rpx; color: rgba(220,80,80,0.6); }
.flow-end-row { margin-top: 14rpx; }
.flow-end-line { width: 60%; margin: 0 auto; height: 1rpx; background: rgba(216,176,107,0.15); }
.flow-end-nodes {
  display: flex; justify-content: center; gap: 16rpx; margin-top: 12rpx;
}
.flow-end-node {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  padding: 10rpx 16rpx; border-radius: 0;
}
.good-end { border: 1rpx solid rgba(78,158,255,0.2); background: rgba(78,158,255,0.06); }
.evil-end { border: 1rpx solid rgba(220,80,80,0.2); background: rgba(220,80,80,0.06); }
.flow-end-label { font-size: 22rpx; font-weight: 700; color: #f2e5c8; }
.flow-end-sub { font-size: 18rpx; color: rgba(216,176,107,0.5); }
.flow-end-result { font-size: 18rpx; color: rgba(78,158,255,0.7); }

/* ─── Vision chart (role relationships) ─── */
.vision-chart {
  display: flex; align-items: flex-start; justify-content: center;
  padding: 20rpx 12rpx 24rpx; gap: 6rpx;
}
.vision-col {
  display: flex; flex-direction: column; align-items: center; gap: 10rpx;
  flex: 0 0 auto; min-width: 120rpx;
}
.vision-faction-label {
  font-size: 20rpx; font-weight: 800; letter-spacing: 2rpx; margin-bottom: 4rpx;
}
.vision-faction-label.good { color: #7ac7ff; }
.vision-faction-label.evil { color: #ff8a8a; }
.vision-role {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  padding: 8rpx 6rpx; border: 1rpx solid rgba(216,176,107,0.10);
  background: rgba(216,176,107,0.03); width: 110rpx;
}
.vision-role-isolated { border-style: dashed; opacity: 0.6; }
.vision-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; }
.vision-name { font-size: 20rpx; color: #f2e5c8; font-weight: 600; }
.vision-tag {
  font-size: 16rpx; color: rgba(220,80,80,0.7); background: rgba(220,80,80,0.1);
  padding: 2rpx 8rpx; border-radius: 999rpx;
}
.vision-arrows {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 14rpx; padding: 10rpx 0;
  flex: 0 0 auto; min-width: 160rpx;
}
.vision-arrow-item {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
}
.vision-arrow-line { font-size: 20rpx; font-weight: 700; letter-spacing: -2rpx; }
.vision-arrow-line.good-line { color: rgba(78,158,255,0.5); }
.vision-arrow-line.evil-line { color: rgba(220,80,80,0.5); }
.vision-arrow-desc {
  font-size: 17rpx; color: rgba(216,176,107,0.5); text-align: center; line-height: 1.4;
}

/* ─── Mission table ─── */
.mission-table-wrap { padding: 12rpx 16rpx 18rpx; }
.mt-header, .mt-row {
  display: flex; align-items: center;
}
.mt-header { border-bottom: 1rpx solid rgba(216,176,107,0.15); padding-bottom: 8rpx; }
.mt-row { padding: 8rpx 0; border-bottom: 1rpx solid rgba(216,176,107,0.06); }
.mt-cell {
  flex: 1; text-align: center; font-size: 22rpx; color: rgba(210,220,238,0.85);
}
.mt-cell-first {
  flex: 0 0 80rpx; text-align: left; color: #f2e5c8; font-weight: 700;
}
.mt-round { color: rgba(216,176,107,0.6); font-size: 20rpx; font-weight: 600; }
.mt-shield { color: #f2c84b; font-weight: 700; }
.mt-note {
  display: block; margin-top: 10rpx;
  font-size: 19rpx; color: rgba(242,200,75,0.5); line-height: 1.5;
}
