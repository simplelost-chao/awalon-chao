/* ─── RESET & PAGE ─────────────────────────────────── */
.page {
  min-height: 100vh;
  position: relative;
  background: var(--aw-bg);
}

.bg, .mask {
  position: fixed;
  inset: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg,
    rgba(6, 8, 16, 0.72) 0%,
    rgba(8, 10, 20, 0.88) 40%,
    rgba(6, 8, 16, 0.96) 100%);
}

@import '../../../styles/theme-overrides.wxss';


/* ─── CONTENT ───────────────────────────────────────── */
.content {
  position: relative;
  z-index: 2;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 0 20rpx 60rpx;
}

/* ─── PANEL (loading 状态保留) ──────────────────────── */
.panel {
  margin-top: 18rpx;
  padding: 0;
  border-radius: 20rpx;
  background: rgba(14, 18, 28, 0.90);
  border: 1rpx solid rgba(216, 176, 107, 0.14);
  overflow: hidden;
}

/* ─── 新面板：pf 覆盖 ────────────────────────────────── */
.hd-section { padding: 0; overflow: hidden; }

/* 组件间距包裹 */
.hd-comp-wrap { margin-top: 18rpx; }

/* ─── 标题行（◆ 居中风格）────────────────────────────── */
.hd-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 20rpx 16rpx;
  border-bottom: 1rpx solid rgba(216, 176, 107, 0.10);
}
.hd-title-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(to right, transparent, rgba(216, 176, 107, 0.35));
}
.hd-title-line-short { flex: 0 0 24rpx; }
.hd-deco {
  color: rgba(216, 176, 107, 0.55);
  font-size: 18rpx;
  flex-shrink: 0;
}
.hd-title {
  color: #f2e5c8;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  flex-shrink: 0;
}

/* ─── 生成复盘按钮（cf 双层斜切角） ─────────────────── */
.hd-gen-btn {
  margin: 16rpx 36rpx 20rpx;
  padding: 1.5rpx;
  clip-path: polygon(8px 0%, calc(100% - 8px) 0%, 100% 8px, 100% calc(100% - 8px), calc(100% - 8px) 100%, 8px 100%, 0% calc(100% - 8px), 0% 8px);
  background: linear-gradient(135deg, #8a6010, #c8a040 40%, #f5d060 50%, #c8a040 60%, #8a6010);
}
.hd-gen-btn-inner {
  clip-path: polygon(7px 0%, calc(100% - 7px) 0%, 100% 7px, 100% calc(100% - 7px), calc(100% - 7px) 100%, 7px 100%, 0% calc(100% - 7px), 0% 7px);
  background: rgba(20, 12, 2, 0.92);
  padding: 16rpx 40rpx;
  text-align: center;
}
.hd-gen-btn-txt {
  color: #d8b06b;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}
.hd-gen-btn-pending .hd-gen-btn-inner { background: rgba(20, 12, 2, 0.80); }
.hd-gen-btn-pending .hd-gen-btn-txt { color: rgba(216, 176, 107, 0.3); }

/* ─── 发言内容区 ─────────────────────────────────────── */
.section-body {
  padding: 16rpx 18rpx;
}

/* ─── META ──────────────────────────────────────────── */
.meta {
  display: block;
  margin: 16rpx;
  color: #cfd8ea;
  font-size: 22rpx;
}

/* ─── GAME HEADER CARD ──────────────────────────────── */
.ghc {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
}

/* ghc fb-* 颜色：win=绿 / lose=红 / neutral+spec=金 */
.ghc-result-win .fb-top, .ghc-result-win .fb-bottom {
  background: linear-gradient(to right, #0c3012 0%, #1a8040 18%, #40c870 42%, #80f0a8 50%, #40c870 58%, #1a8040 82%, #0c3012 100%);
}
.ghc-result-win .fb-left, .ghc-result-win .fb-right {
  background: linear-gradient(to bottom, #0c3012, #1a8040 35%, #1a8040 65%, #0c3012);
}
.ghc-result-win .fb-ctl, .ghc-result-win .fb-ctr,
.ghc-result-win .fb-cbl, .ghc-result-win .fb-cbr { background: #1a6030; }
.ghc-result-win .fc-inner { background: rgba(80, 220, 140, 0.6); }

.ghc-result-lose .fb-top, .ghc-result-lose .fb-bottom {
  background: linear-gradient(to right, #300808 0%, #882020 18%, #cc4040 42%, #ff8888 50%, #cc4040 58%, #882020 82%, #300808 100%);
}
.ghc-result-lose .fb-left, .ghc-result-lose .fb-right {
  background: linear-gradient(to bottom, #300808, #882020 35%, #882020 65%, #300808);
}
.ghc-result-lose .fb-ctl, .ghc-result-lose .fb-ctr,
.ghc-result-lose .fb-cbl, .ghc-result-lose .fb-cbr { background: #6b1818; }
.ghc-result-lose .fc-inner { background: rgba(220, 80, 80, 0.6); }

.ghc-result-neutral .fb-top, .ghc-result-neutral .fb-bottom,
.ghc-spec .fb-top, .ghc-spec .fb-bottom {
  background: linear-gradient(to right, #6b3e08 0%, #c8860a 18%, #f5cc52 42%, #fff4b0 50%, #f5cc52 58%, #c8860a 82%, #6b3e08 100%);
}
.ghc-result-neutral .fb-left, .ghc-result-neutral .fb-right,
.ghc-spec .fb-left, .ghc-spec .fb-right {
  background: linear-gradient(to bottom, #6b3e08, #c8860a 35%, #c8860a 65%, #6b3e08);
}
.ghc-result-neutral .fb-ctl, .ghc-result-neutral .fb-ctr,
.ghc-result-neutral .fb-cbl, .ghc-result-neutral .fb-cbr,
.ghc-spec .fb-ctl, .ghc-spec .fb-ctr,
.ghc-spec .fb-cbl, .ghc-spec .fb-cbr { background: #9a6010; }
.ghc-result-neutral .fc-inner,
.ghc-spec .fc-inner { background: rgba(228, 194, 129, 0.65); }

/* ── 阵营：控制光环 / 标签（不含背景）── */
.ghc-spec {
  background: linear-gradient(145deg, rgba(28,22,8,0.98) 0%, rgba(22,16,6,0.98) 60%, rgba(26,20,8,0.95) 100%);
  box-shadow: 0 0 0 1rpx rgba(216,176,107,0.18), 0 40rpx 120rpx rgba(160,120,40,0.15), inset 0 2rpx 0 rgba(255,220,120,0.06);
}

/* ── 结果：控制背景 / 水印 / 装饰条 ── */
.ghc-result-win {
  background: linear-gradient(145deg, rgba(6,30,16,0.98) 0%, rgba(4,22,10,0.98) 60%, rgba(8,28,14,0.95) 100%);
  box-shadow: 0 0 0 1rpx rgba(50,200,100,0.15), 0 40rpx 120rpx rgba(30,160,70,0.18), inset 0 2rpx 0 rgba(100,220,140,0.08);
}
.ghc-result-lose {
  background: linear-gradient(145deg, rgba(40,8,8,0.98) 0%, rgba(28,6,6,0.98) 60%, rgba(20,6,10,0.95) 100%);
  box-shadow: 0 0 0 1rpx rgba(220,60,60,0.15), 0 40rpx 120rpx rgba(200,30,30,0.18), inset 0 2rpx 0 rgba(255,120,120,0.06);
}
.ghc-result-neutral {
  background: linear-gradient(145deg, rgba(28,22,8,0.98) 0%, rgba(22,16,6,0.98) 60%, rgba(26,20,8,0.95) 100%);
  box-shadow: 0 0 0 1rpx rgba(216,176,107,0.18), 0 40rpx 120rpx rgba(160,120,40,0.15), inset 0 2rpx 0 rgba(255,220,120,0.06);
}


/* 大字水印 */
.ghc-watermark {
  position: absolute;
  right: -20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 200rpx;
  font-weight: 900;
  letter-spacing: -8rpx;
  line-height: 1;
  white-space: nowrap;
  pointer-events: none;
  user-select: none;
  opacity: 0.055;
}
.ghc-result-win .ghc-watermark { color: #32c864; }
.ghc-result-lose .ghc-watermark { color: #dc3c3c; }
.ghc-result-neutral .ghc-watermark,
.ghc-spec .ghc-watermark { color: #d8b06b; }

/* 主体区 */
.ghc-body {
  padding: 28rpx 28rpx 0;
  position: relative;
  z-index: 1;
}

/* 顶行 */
.ghc-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.ghc-game-id-wrap {
  display: flex;
  align-items: center;
}

.ghc-game-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 2rpx;
}
.ghc-game-id-num {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  font-weight: 700;
  letter-spacing: 2rpx;
}

.ghc-result-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.ghc-result-win .ghc-result-tag {
  background: rgba(50, 200, 100, 0.12);
  border: 1rpx solid rgba(50, 200, 100, 0.38);
  color: #60e8a0;
}
.ghc-result-lose .ghc-result-tag {
  background: rgba(220, 60, 60, 0.12);
  border: 1rpx solid rgba(220, 60, 60, 0.38);
  color: #ff8080;
}
.ghc-result-neutral .ghc-result-tag,
.ghc-spec .ghc-result-tag {
  background: rgba(216, 176, 107, 0.12);
  border: 1rpx solid rgba(216, 176, 107, 0.38);
  color: #f2ca88;
}

.ghc-result-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  animation: ghc-pulse 2s ease-in-out infinite;
}
.ghc-result-win .ghc-result-dot { background: #60e8a0; box-shadow: 0 0 12rpx #60e8a0; }
.ghc-result-lose .ghc-result-dot { background: #ff8080; box-shadow: 0 0 12rpx #ff8080; }
.ghc-result-neutral .ghc-result-dot,
.ghc-spec .ghc-result-dot { background: #f2ca88; box-shadow: 0 0 12rpx #f2ca88; }

@keyframes ghc-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.35; transform: scale(0.65); }
}

/* 主体行：头像 + 信息 */
.ghc-hero-row {
  display: flex;
  gap: 28rpx;
  align-items: flex-start;
}

/* 头像区 */
.ghc-portrait-wrap {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

/* 旋转光环：外层旋转 conic-gradient，内层盖住中心 */
.ghc-ring-outer {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  position: relative;
  animation: ghc-rotate 8s linear infinite;
}
.ghc-good .ghc-ring-outer {
  background: conic-gradient(transparent 0%, transparent 15%, rgba(78,158,255,0.85) 38%, rgba(160,220,255,0.95) 50%, rgba(78,158,255,0.85) 62%, transparent 85%, transparent 100%);
}
.ghc-evil .ghc-ring-outer {
  background: conic-gradient(transparent 0%, transparent 15%, rgba(220,60,60,0.85) 38%, rgba(255,130,130,0.95) 50%, rgba(220,60,60,0.85) 62%, transparent 85%, transparent 100%);
}
.ghc-spec .ghc-ring-outer {
  background: conic-gradient(transparent 0%, transparent 15%, rgba(140,100,220,0.8) 38%, rgba(200,160,255,0.9) 50%, rgba(140,100,220,0.8) 62%, transparent 85%, transparent 100%);
}

.ghc-ring-inner {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border-radius: 50%;
  overflow: hidden;
  animation: ghc-rotate-reverse 8s linear infinite;
}

@keyframes ghc-rotate-reverse {
  to { transform: rotate(-360deg); }
}
.ghc-result-win .ghc-ring-inner { background: rgba(4, 20, 10, 1); }
.ghc-result-lose .ghc-ring-inner { background: rgba(26, 5, 5, 1); }
.ghc-result-neutral .ghc-ring-inner,
.ghc-spec .ghc-ring-inner { background: rgba(22, 16, 6, 1); }

.ghc-portrait-img {
  width: 100%;
  height: 100%;
}

.ghc-portrait-emoji {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  text-align: center;
  line-height: 136rpx;
}

.ghc-spectator-name {
  color: #c0a0ff;
  font-size: 30rpx;
  font-weight: 700;
}

@keyframes ghc-rotate {
  to { transform: rotate(360deg); }
}

.ghc-role-pill {
  padding: 4rpx 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  white-space: nowrap;
}
.ghc-good .ghc-role-pill {
  background: rgba(78, 158, 255, 0.1);
  border: 1rpx solid rgba(78, 158, 255, 0.3);
  color: #93c8ff;
}
.ghc-evil .ghc-role-pill {
  background: rgba(220, 60, 60, 0.1);
  border: 1rpx solid rgba(220, 60, 60, 0.3);
  color: #ff9898;
}
.ghc-spec .ghc-role-pill {
  background: rgba(140, 100, 220, 0.1);
  border: 1rpx solid rgba(160, 120, 240, 0.28);
  color: #c0a0ff;
}

/* 信息区 */
.ghc-info-block {
  flex: 1;
  min-width: 0;
}

.ghc-player-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #eef2ff;
  letter-spacing: 1rpx;
  margin-bottom: 18rpx;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ghc-meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx 20rpx;
}

.ghc-meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ghc-meta-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  opacity: 0.85;
}

.ghc-meta-val {
  font-size: 22rpx;
  line-height: 30rpx;
  color: rgba(255, 255, 255, 0.5);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ghc-winner-winner-good { color: #6edea8; }
.ghc-winner-winner-evil { color: #ff8f8f; }

/* 分割线 */
.ghc-divider {
  height: 2rpx;
  margin: 24rpx 0 20rpx;
}
.ghc-result-win .ghc-divider {
  background: linear-gradient(90deg, transparent, rgba(50,200,100,0.2) 30%, rgba(50,200,100,0.2) 70%, transparent);
}
.ghc-result-lose .ghc-divider {
  background: linear-gradient(90deg, transparent, rgba(220,60,60,0.22) 30%, rgba(220,60,60,0.22) 70%, transparent);
}
.ghc-result-neutral .ghc-divider,
.ghc-spec .ghc-divider {
  background: linear-gradient(90deg, transparent, rgba(216,176,107,0.2) 30%, rgba(216,176,107,0.2) 70%, transparent);
}

/* 互评文字 */
.ghc-vote-text {
  display: block;
  font-size: 22rpx;
  color: rgba(216, 176, 107, 0.75);
  margin-bottom: 20rpx;
  padding: 10rpx 16rpx;
  background: rgba(216, 176, 107, 0.06);
  border-left: 4rpx solid rgba(216, 176, 107, 0.35);
  border-radius: 0 8rpx 8rpx 0;
  line-height: 1.5;
}


/* ─── MEDALS ────────────────────────────────────────── */
.medal-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 12rpx 18rpx 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.medal-chip {
  padding: 6rpx 14rpx 6rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(192, 145, 74, 0.18);
  border: 1rpx solid rgba(242, 202, 136, 0.4);
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.medal-chip-image {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.medal-chip-icon {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.medal-chip-name {
  font-size: 20rpx;
  color: #f8e8c2;
}

/* ─── PEER VOTE ─────────────────────────────────────── */
.peer-vote-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 14rpx 18rpx 18rpx;
}

.peer-vote-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.peer-vote-name {
  color: #c8d4e8;
  font-size: 22rpx;
}

.peer-vote-summary {
  color: #d8b06b;
  font-size: 20rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ─── ROUND TABLE ─── 共享样式从 styles/round-table.wxss 引入 ── */
@import '/styles/round-table.wxss';

/* 历史详情：取消游戏页的负 margin-bottom（游戏页用它拉起控制区），改为正常收底 */
.table-wrap {
  margin-bottom: 40rpx;
}

/* 历史详情专属：center-result 颜色变体 */
.center-result {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 200rpx;
  padding: 16rpx 22rpx;
  border-radius: 16rpx;
  text-align: center;
  z-index: 3;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  background: rgba(12, 16, 24, 0.82);
}

.winner-good {
  background: rgba(16, 55, 140, 0.88);
  box-shadow: 0 0 32rpx rgba(40, 100, 240, 0.22);
}

.winner-evil {
  background: rgba(110, 18, 24, 0.90);
  box-shadow: 0 0 32rpx rgba(200, 30, 30, 0.22);
}

.center-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  display: block;
}

.center-reason {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

/* 头像图片填满圆 */
.seat-role-avatar {
  width: 100%;
  height: 100%;
}

/* ─── MISSION TABLE ─────────────────────────────────── */
/* ── 任务详情表格已移入 /components/mission-table ── */

/* ─── 发言记录 ──────────────────────────────────────── */
.speak-title-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  flex: 1;
}

.speak-title-round {
  font-size: 22rpx;
  color: #d8b06b;
  flex-shrink: 0;
}

.speak-inline-pager {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.speak-inline-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(216, 176, 107, 0.1);
  border: 1rpx solid rgba(216, 176, 107, 0.3);
  color: #d8b06b;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.speak-inline-disabled { opacity: 0.3; }

/* 发言列表已移入 /components/speak-list */


.recap-card {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  overflow: hidden;
}

.recap-card:last-child { border-bottom: none; }

.recap-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  background: rgba(255, 255, 255, 0.02);
}

.recap-seat {
  color: #d8b06b;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.recap-role {
  color: #9090c0;
  font-size: 19rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  padding: 2rpx 10rpx;
}

.recap-nick {
  color: #c8d4e8;
  font-size: 22rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recap-toggle {
  flex-shrink: 0;
  font-size: 20rpx;
  color: rgba(216, 176, 107, 0.6);
}

.recap-section {
  padding: 10rpx 18rpx 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.recap-section-title {
  display: block;
  color: rgba(216, 176, 107, 0.7);
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.recap-body {
  display: block;
  color: #a8b8d0;
  font-size: 21rpx;
  line-height: 1.7;
}

/* ─── ASSASSINATION ─────────────────────────────────── */
.assass-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 14rpx 18rpx;
  padding: 20rpx;
  border-radius: 14rpx;
}

.assassination-hit {
  background: rgba(80, 8, 8, 0.50);
  border: 1rpx solid rgba(220, 60, 60, 0.38);
}

.assassination-miss {
  background: rgba(10, 40, 24, 0.50);
  border: 1rpx solid rgba(80, 180, 100, 0.38);
}

.assass-avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
}

.assass-avatar-hit { border: 3rpx solid rgba(220, 60, 60, 0.8); }
.assass-avatar-miss { border: 3rpx solid rgba(216, 176, 107, 0.65); }

.assass-avatar-img { width: 100%; height: 100%; }
.assass-avatar-text {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.assass-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.assass-result {
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.assass-hit {
  color: #ff5a5a;
  text-shadow: 0 0 20rpx rgba(255, 60, 60, 0.4);
}

.assass-miss {
  color: #60d890;
  text-shadow: 0 0 20rpx rgba(60, 200, 120, 0.4);
}

.assass-target-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #eedfc0;
}

.assass-role {
  font-size: 22rpx;
  font-weight: 600;
  color: #d8b06b;
}

.assass-by {
  font-size: 21rpx;
  color: rgba(200, 180, 140, 0.45);
}

/* ─── 复盘入口 ─── */
.replay-entry {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  margin: 16rpx 0; padding: 20rpx 0;
  background: rgba(216,176,107,0.06);
  border: 1rpx solid rgba(216,176,107,0.2);
  border-radius: 12rpx;
}
.replay-entry-icon { font-size: 28rpx; }
.replay-entry-text { font-size: 28rpx; color: rgba(216,176,107,0.85); font-weight: 600; letter-spacing: 2rpx; }
.replay-entry-arrow { font-size: 32rpx; color: rgba(216,176,107,0.5); }

