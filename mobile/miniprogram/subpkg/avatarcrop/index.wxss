.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #11161f, #090c12);
  color: #eef1f7;
}

.custom-nav {
  padding-top: env(safe-area-inset-top);
  background: rgba(12, 16, 24, 0.92);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.nav-inner {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.nav-title {
  font-size: 28rpx;
  font-weight: 700;
}

.content {
  padding: 20rpx 24rpx 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-text {
  font-size: 26rpx;
  color: #f2e5c8;
  margin-bottom: 10rpx;
}

.tip {
  font-size: 24rpx;
  color: #aeb6c7;
  margin-bottom: 16rpx;
}

.crop-frame {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  touch-action: none;
}

.crop-canvas {
  position: absolute;
  left: 0;
  top: 0;
  display: block;
}

.crop-mask {
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 0 9999rpx rgba(0, 0, 0, 0.18);
  pointer-events: none;
}

.crop-border {
  position: absolute;
  inset: 0;
  border: 2px solid rgba(228, 194, 129, 0.88);
  border-radius: 28rpx;
  pointer-events: none;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: linear-gradient(180deg, rgba(9, 12, 18, 0), rgba(9, 12, 18, 0.94) 28%, rgba(9, 12, 18, 0.98));
}

.bottom-back,
.bottom-confirm {
  flex: 1;
  min-height: 0;
  height: 64rpx;
  line-height: 1;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-back {
  color: #dbe3f0;
  background: rgba(255, 255, 255, 0.08);
}

.bottom-confirm {
  color: #20160c;
  background: linear-gradient(135deg, #e4c281, #c8964a);
}

.bottom-back::after,
.bottom-confirm::after {
  border: none;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 128px;
  height: 128px;
  opacity: 0;
}
