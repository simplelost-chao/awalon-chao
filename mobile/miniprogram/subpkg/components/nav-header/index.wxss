.nav-header {
  position: fixed;
  left: 0; right: 0; top: 0;
  z-index: 20;
  background: rgba(6, 8, 15, 0.92);
  border-bottom: 1rpx solid rgba(216, 176, 107, 0.14);
  backdrop-filter: blur(12px);
}

.nav-inner {
  position: relative;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

/* ── 返回按钮 ── */
.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(216, 176, 107, 0.35);
  background: rgba(216, 176, 107, 0.08);
  flex-shrink: 0;
}

.nav-back-arrow {
  font-size: 36rpx;
  color: rgba(216, 176, 107, 0.8);
  line-height: 1;
  margin-top: -2rpx;
}

/* ── 标题 ── */
.nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #f2e5c8;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  pointer-events: none;
}

/* ── 占位（平衡布局） ── */
.nav-placeholder {
  width: 100rpx;
  flex-shrink: 0;
}
