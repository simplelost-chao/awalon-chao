.mission-table {
  padding: 0 18rpx 16rpx;
}

/* 无 col-round 时：4列；有 col-round 时：5列 */
.table-head,
.table-row {
  display: grid;
  width: 100%;
  grid-template-columns: 1fr 1.4fr 3fr 1.5fr;
  gap: 8rpx;
  align-items: center;
  box-sizing: border-box;
}

.has-round .table-head,
.has-round .table-row {
  grid-template-columns: 1.1fr 1fr 1.4fr 3fr 1.5fr;
}

.table-head {
  margin-top: 6rpx;
  margin-bottom: 6rpx;
}

.table-head .col {
  color: rgba(216, 176, 107, 0.8);
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-align: center;
}

.table-row {
  min-height: 60rpx;
  border-top: 1rpx solid var(--aw-input-bg);
  padding-top: 12rpx;
  padding-bottom: 12rpx;
}

.row-rejected {
  opacity: 0.45;
}

.col {
  font-size: 26rpx;
  color: #b0bfd8;
  overflow: hidden;
  white-space: normal;
  word-break: break-all;
  line-height: 1.7;
  text-align: center;
}

.col-round {
  color: var(--aw-accent);
  font-weight: 600;
}

.col-leader {
  color: #e7cf95;
  font-size: 26rpx;
}

.col-reject { color: #ff8f8f; }

.vote-combo {
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
}

.vote-part { color: #6edea8; font-size: 26rpx; }
.vote-sep { color: rgba(255, 255, 255, 0.3); }
.vote-part.col-reject { color: #ff8f8f; }

.col-res-cell {
  display: flex;
  align-items: center;
  justify-content: center;
}

.res-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  height: 38rpx;
  border-radius: 20rpx;
}

.res-pill-text {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
}

.pill-ok {
  background: rgba(74, 210, 149, 0.15);
  color: #4ad295;
}

.pill-ng {
  background: rgba(255, 95, 95, 0.15);
  color: #ff5f5f;
}

.pill-wait {
  background: rgba(196, 168, 79, 0.15);
  color: #c4a84f;
}

.res-rejected-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.25);
}
