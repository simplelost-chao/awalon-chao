.emoji-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 8rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(10, 8, 16, 0.85);
  border-top: 1rpx solid rgba(212, 175, 55, 0.3);
  box-sizing: border-box;
}

.emoji-bar--cooldown .emoji-btn {
  opacity: 0.3;
  pointer-events: none;
}

.emoji-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: opacity 0.15s ease;
}

.emoji-btn--active {
  opacity: 0.5;
}

.emoji-img {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.emoji-label {
  font-size: 16rpx;
  color: rgba(212, 175, 55, 0.85);
  line-height: 1.2;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}
