/* ─── 触发按钮（右上角浮动） ─── */
.emoji-trigger {
  position: fixed;
  right: 20rpx;
  bottom: 420rpx;
  z-index: 45;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.emoji-trigger-icon { width: 80rpx; height: 80rpx; }

/* ─── 弹出面板 ─── */
.emoji-panel { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 60; }
.emoji-panel-mask { position: absolute; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.3); }
.emoji-panel-body {
  position: absolute;
  right: 20rpx;
  bottom: 500rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(16, 12, 24, 0.95);
  border: 1rpx solid rgba(216,176,107,0.25);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.5);
  max-width: 420rpx;
}
.emoji-panel-cooldown { opacity: 0.3; pointer-events: none; }
.emoji-panel-show { }

/* ─── 表情项 ─── */
.emoji-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  width: 110rpx;
  padding: 10rpx 0;
  border-radius: 12rpx;
}
.emoji-item:active { background: rgba(216,176,107,0.1); }
.emoji-item-img { width: 120rpx; height: 120rpx; }
.emoji-item-label { font-size: 18rpx; color: rgba(255,255,255,0.6); white-space: nowrap; }
