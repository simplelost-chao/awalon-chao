/* action-panel 组件样式（btn/btn-row 由页面 shared 继承） */

.vote-bottom-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 0;
  pointer-events: none;
}

.vote-bottom-card {
  pointer-events: auto;
  border-radius: 40rpx 40rpx 0 0;
  border: 1rpx solid var(--aw-nav-border);
  border-bottom: none;
  background: var(--aw-panel);
  padding: 20rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  box-shadow: 0 -16rpx 64rpx rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.vote-bottom-title {
  display: block;
  margin-bottom: 16rpx;
  color: var(--aw-subtext);
  font-size: 24rpx;
  text-align: center;
  width: 100%;
}

.vote-team-row {
  margin-bottom: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 36rpx;
  justify-content: center;
}

.vote-team-chip {
  position: relative;
  flex: 0 0 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.vote-team-name {
  font-size: 20rpx;
  color: var(--aw-subtext);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 96rpx;
  text-align: center;
}

.vote-action-divider {
  width: 100%;
  height: 1rpx;
  background: var(--aw-input-bg);
  margin: 16rpx 0;
}

.vote-team-av-wrap {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
}

.vote-team-avatar {
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(12, 10, 8, 0.5);
  border: 2rpx solid var(--aw-panel-border);
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.24);
}

.vote-team-avatar-img {
  width: 100%;
  height: 100%;
}

.vote-team-avatar-text {
  font-size: 34rpx;
  line-height: 1;
}

.vote-team-seat-badge {
  position: absolute;
  right: -6rpx;
  bottom: -4rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(236, 196, 118, 0.96);
  color: #20160d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  border: 2rpx solid rgba(16, 12, 8, 0.9);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.22);
}

.vote-action-row {
  gap: 16rpx;
  width: 100%;
}

.vote-action-btn {
  height: 80rpx;
  font-size: 26rpx;
}
