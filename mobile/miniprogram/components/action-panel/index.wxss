/* action-panel 组件样式（btn/btn-row 由页面 shared 继承） */


.vote-bottom-card {
  pointer-events: auto;
  border-radius: 40rpx 40rpx 0 0;
  border: var(--aw-panel-border-width, 1rpx) solid var(--aw-nav-border);
  border-bottom: none;
  background: linear-gradient(to bottom, rgba(32, 18, 4, 0.88) 0%, rgba(16, 9, 2, 0.97) 100%);
  padding: 20rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  box-shadow: 0 -16rpx 64rpx rgba(0, 0, 0, 0.5), var(--aw-panel-shadow, 0 0 0 transparent);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.vote-bottom-title {
  display: block;
  margin-bottom: 16rpx;
  color: var(--aw-subtext);
  font-size: 24rpx;
  text-align: center;
  width: 100%;
}

.lady-bottom-card {
  gap: 14rpx;
  padding-top: 22rpx;
}

.lady-bottom-head {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.lady-bottom-title {
  margin-bottom: 0;
  color: #f0ca84;
  font-weight: 800;
}

.lady-flow-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.lady-player-card {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 10rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  border: 1rpx solid rgba(80, 210, 230, 0.26);
  background: rgba(34, 116, 130, 0.18);
}

.lady-target-card {
  border-style: dashed;
  background: rgba(8,20,28,0.28);
}

.lady-target-selected {
  border-style: solid;
  border-color: rgba(108, 230, 164, 0.46);
  background: rgba(34, 130, 86, 0.18);
}

.lady-player-avatar {
  position: relative;
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(12, 10, 8, 0.5);
  border: 2rpx solid rgba(145, 226, 238, 0.4);
}

.lady-player-avatar-img {
  width: 100%;
  height: 100%;
}

.lady-player-avatar-text,
.lady-target-empty {
  font-size: 32rpx;
  line-height: 1;
}

.lady-player-seat {
  font-size: 20rpx;
  color: rgba(145,226,238,0.76);
}

.lady-player-name {
  max-width: 100%;
  font-size: 22rpx;
  color: #d8f7f2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lady-flow-arrow {
  flex: 0 0 auto;
  width: 74rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1rpx solid rgba(216,176,107,0.45);
  border-bottom: 1rpx solid rgba(216,176,107,0.18);
}

.lady-flow-arrow-text {
  font-size: 20rpx;
  color: rgba(216,176,107,0.72);
}

.lady-waiting {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  border: 1rpx solid rgba(80, 210, 230, 0.24);
  background: rgba(34, 116, 130, 0.16);
}

.lady-waiting-avatar {
  flex: 0 0 auto;
  width: 68rpx;
  height: 68rpx;
}

.lady-waiting-name {
  min-width: 0;
  flex: 1;
  font-size: 27rpx;
  line-height: 34rpx;
  color: #d8f7f2;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lady-waiting-text {
  flex: 0 0 auto;
  font-size: 23rpx;
  color: rgba(145, 226, 238, 0.72);
}

.lady-bottom-hint {
  width: 100%;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  border: 1rpx dashed rgba(145, 226, 238, 0.2);
  background: rgba(8, 20, 28, 0.34);
}

.lady-bottom-hint-text {
  display: block;
  font-size: 24rpx;
  line-height: 34rpx;
  color: rgba(205, 232, 236, 0.78);
  text-align: center;
}

.lady-confirm-frame {
  width: 100%;
}

.lady-confirm-disabled {
  opacity: 0.42;
}

.vote-team-row {
  margin-bottom: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 36rpx;
  justify-content: center;
}

.vote-team-chip {
  position: relative;
  flex: 0 0 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.vote-team-name {
  font-size: 20rpx;
  color: var(--aw-subtext);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 96rpx;
  text-align: center;
}

.vote-action-divider {
  width: 100%;
  height: 1rpx;
  background: var(--aw-input-bg);
  margin: 16rpx 0;
}

.vote-team-av-wrap {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
}

.vote-team-avatar {
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(12, 10, 8, 0.5);
  border: 2rpx solid var(--aw-panel-border);
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.24);
}

.vote-team-avatar-img {
  width: 100%;
  height: 100%;
}

.vote-team-avatar-text {
  font-size: 34rpx;
  line-height: 1;
}

.vote-team-seat-badge {
  position: absolute;
  right: -6rpx;
  bottom: -4rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(236, 196, 118, 0.96);
  color: #20160d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  border: 2rpx solid rgba(16, 12, 8, 0.9);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.22);
}

.vote-action-row,
.spk-host-row,
.spk-btn-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  width: 100%;
  margin-top: 8rpx;
}

/* btn-frame 在操作区里各占一半 */
.ap-btn {
  flex: 1;
  min-width: 0;
}

/* 按钮内容区：flex 让 icon + label 横排居中 */
.ap-btn-text {
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 16rpx;
  box-sizing: border-box;
}
.ap-btn-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.ap-btn-label {
  font-size: 28rpx;
  line-height: 1;
}

/* 裁掉四个斜切角的黑色背景（匹配 fb-* 的 10rpx ≈ 5px 偏移） */
.ap-btn-approve .ap-btn-text,
.ap-btn-reject .ap-btn-text {
  clip-path: polygon(5px 0%, calc(100% - 5px) 0%, 100% 5px, 100% calc(100% - 5px), calc(100% - 5px) 100%, 5px 100%, 0% calc(100% - 5px), 0% 5px);
}

/* ── 同意 / 任务成功：深绿底 ── */
.ap-btn-approve .ap-btn-text {
  background: rgba(22, 78, 46, 0.9);
  color: #a8e6c0;
}
.ap-btn-approve .ap-btn-icon { color: #5dcc8a; }
.ap-btn-approve .fb-top,
.ap-btn-approve .fb-bottom {
  background: linear-gradient(to right, #1a5c2e 0%, #3ab870 35%, #7eeaaa 50%, #3ab870 65%, #1a5c2e 100%);
}
.ap-btn-approve .fb-left,
.ap-btn-approve .fb-right {
  background: linear-gradient(to bottom, #1a5c2e, #3ab870 50%, #1a5c2e);
}
.ap-btn-approve .fb-ctl,
.ap-btn-approve .fb-ctr,
.ap-btn-approve .fb-cbl,
.ap-btn-approve .fb-cbr { background: #2e9458; }
.ap-btn-approve .fc-inner { background: rgba(100, 220, 150, 0.6); }

/* ── 反对 / 任务失败：深红底 ── */
.ap-btn-reject .ap-btn-text {
  background: rgba(72, 14, 14, 0.92);
  color: #f5a0a0;
}
.ap-btn-reject .ap-btn-icon { color: #ff6b6b; }
.ap-btn-reject .fb-top,
.ap-btn-reject .fb-bottom {
  background: linear-gradient(to right, #5a0e0e 0%, #c03030 35%, #ff7070 50%, #c03030 65%, #5a0e0e 100%);
}
.ap-btn-reject .fb-left,
.ap-btn-reject .fb-right {
  background: linear-gradient(to bottom, #5a0e0e, #c03030 50%, #5a0e0e);
}
.ap-btn-reject .fb-ctl,
.ap-btn-reject .fb-ctr,
.ap-btn-reject .fb-cbl,
.ap-btn-reject .fb-cbr { background: #922020; }

/* speak-panel 按钮保持原 ghost/primary 风格 */
.ap-btn-primary {
  color: #f0e8d0;
  background: var(--aw-panel);
  clip-path: polygon(5px 0%, calc(100% - 5px) 0%, 100% 5px, 100% calc(100% - 5px), calc(100% - 5px) 100%, 5px 100%, 0% calc(100% - 5px), 0% 5px);
}
.ap-btn-ghost {
  color: rgba(228, 194, 129, 0.8);
}
