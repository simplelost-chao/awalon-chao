.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(10, 8, 16, 0.92);
  border-top: 1rpx solid rgba(216, 176, 107, 0.15);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.5;
}
.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-label {
  font-size: 20rpx;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.4);
}

.tab-item.active .tab-label {
  color: rgba(216, 176, 107, 0.9);
}
