/* ─── 圆桌组件自包含样式 ─────────────────────────────── */
/* 基础布局（所有页面共用） */
@import '../../styles/round-table.wxss';

/* 以下样式之前只在 pages/index/index.wxss 定义，
   组件需要自包含以支持任何页面直接使用 */

/* 头像图片 */
.seat-avatar-img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
.seat-avatar-empty-text { font-size: 36rpx; font-weight: 200; color: rgba(255,255,255,0.3); line-height: 1; }

/* 身份模式标签 */
.seat-id-tag {
  display: flex; align-items: center; gap: 6rpx;
  padding: 4rpx 10rpx; border-radius: 999rpx;
  overflow: hidden; white-space: nowrap;
  font-size: 20rpx; color: #fff;
}
.seat-id-role-img { width: 28rpx; height: 28rpx; border-radius: 4rpx; flex: 0 0 24rpx; }
.seat-role-img { width: 28rpx; height: 28rpx; border-radius: 50%; }

/* 队长皇冠 */
.seat-leader-mark {
  position: absolute; top: -38rpx; left: 50%; transform: translateX(-50%);
  z-index: 8; width: 48rpx; height: 42rpx;
  display: flex; align-items: center; justify-content: center;
  filter: drop-shadow(0 2rpx 5rpx rgba(18,10,2,0.82)) drop-shadow(0 0 8rpx rgba(200,134,10,0.45));
}
.seat-leader-icon { width: 42rpx; height: 42rpx; filter: brightness(1.28); }

/* identity mode 阵营色（复盘等页面需要） */
.identity-mode .seat-card.id-evil .seat-avatar {
  border-color: rgba(248,113,113,0.9) !important;
  box-shadow: 0 0 0 4rpx rgba(248,113,113,0.2), 0 0 32rpx rgba(248,113,113,0.55) !important;
  background: rgba(127,29,29,0.4) !important;
}
.identity-mode .seat-card.id-evil .seat-id-tag { background: rgba(127,29,29,0.65); border-color: rgba(248,113,113,0.5); color: #fecaca; }
.identity-mode .seat-card.id-evil .seat-name { color: #fecaca; }
.identity-mode .seat-card.id-good .seat-avatar,
.identity-mode .seat-card.id-merlin .seat-avatar {
  border-color: rgba(78,158,255,0.85) !important;
  box-shadow: 0 0 0 4rpx rgba(78,158,255,0.18), 0 0 28rpx rgba(78,158,255,0.45) !important;
  background: rgba(7,50,120,0.35) !important;
}
.identity-mode .seat-card.id-good .seat-id-tag,
.identity-mode .seat-card.id-merlin .seat-id-tag { background: rgba(7,50,120,0.6); border-color: rgba(78,158,255,0.45); color: #bfdbfe; }
.identity-mode .seat-card.id-good .seat-name,
.identity-mode .seat-card.id-merlin .seat-name { color: #bfdbfe; }

/* 队伍选中（绿色发光）— 最高优先级 */
.seat-avatar.seat-av-team,
.identity-mode .seat-card .seat-avatar.seat-av-team,
.identity-mode .seat-card.id-good .seat-avatar.seat-av-team,
.identity-mode .seat-card.id-evil .seat-avatar.seat-av-team,
.identity-mode .seat-card.id-merlin .seat-avatar.seat-av-team {
  border-color: rgba(80,230,140,1) !important;
  box-shadow: 0 0 0 4rpx rgba(60,200,110,0.35), 0 0 20rpx rgba(60,200,110,0.7), 0 0 50rpx rgba(60,200,110,0.45) !important;
  background: rgba(10,50,22,0.92) !important;
}
.seat-name-team { color: #7df5aa !important; text-shadow: 0 0 12rpx rgba(60,200,110,0.9) !important; }
.seat-av-me { border-color: rgba(216,176,107,0.85) !important; }

/* 湖中仙女持有者 */
.seat-avatar-lady {
  border-color: rgba(125,255,226,1) !important;
  box-shadow: 0 0 0 6rpx rgba(91,240,216,0.26), 0 0 24rpx rgba(91,240,216,0.72), 0 0 54rpx rgba(123,159,255,0.38) !important;
  background: rgba(8,46,48,0.92) !important;
}

/* 被刺杀（半透明） */
.seat-av-assassinated { opacity: 0.72; }

/* 刺杀 kill 图标 */
.seat-killed-icon {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-32%, -62%) rotate(-20deg);
  width: 100rpx; height: 100rpx;
  pointer-events: none; opacity: 0.92; z-index: 10;
}

/* 动作文字（投票中/已投票等） */
.seat-action { font-size: 18rpx; }
.seat-action-done { color: #7fe1ac; }
.seat-action-pending { color: #d8c99b; }
.seat-offline { font-size: 18rpx; color: rgba(255,255,255,0.35); }

/* 下方区域 */
.seat-below-wrap { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }

/* 备注徽标 */
.seat-note-badge {
  position: absolute; left: -18rpx; bottom: -4rpx;
  height: 30rpx; padding: 0 8rpx; border-radius: 999rpx;
  display: flex; align-items: center; justify-content: center; z-index: 6;
}
.seat-note-badge-text { font-size: 18rpx; color: #e6c17d; font-weight: 600; line-height: 1; white-space: nowrap; }

/* 状态徽标 — 仅提供兜底样式，主页面可覆盖定位 */

/* 湖中仙女翅膀 */
.seat-fairy-wings { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; z-index: 1; }
.seat-wing { position: absolute; }
.seat-wing-ul { position: absolute; width: 44rpx; height: 58rpx; left: -36rpx; top: 6rpx; border-radius: 60% 40% 40% 60% / 55% 45% 55% 45%; background: radial-gradient(ellipse at 72% 40%, rgba(91,240,216,.44) 0%, rgba(123,159,255,.24) 55%, transparent 80%); border: 1rpx solid rgba(91,240,216,.62); box-shadow: 0 0 18rpx rgba(91,240,216,.34); transform-origin: right center; animation: fairy-wing-l 3.5s ease-in-out infinite; }
.seat-wing-ll { position: absolute; width: 31rpx; height: 40rpx; left: -28rpx; top: 50rpx; border-radius: 50% 40% 60% 40% / 40% 50% 50% 60%; background: radial-gradient(ellipse at 70% 30%, rgba(123,159,255,.32) 0%, rgba(192,132,252,.18) 60%, transparent 85%); border: 1rpx solid rgba(123,159,255,.46); transform-origin: right top; animation: fairy-wing-l 3.5s ease-in-out infinite .18s; }
.seat-wing-ur { position: absolute; width: 44rpx; height: 58rpx; right: -36rpx; top: 6rpx; border-radius: 40% 60% 60% 40% / 45% 55% 45% 55%; background: radial-gradient(ellipse at 28% 40%, rgba(91,240,216,.44) 0%, rgba(123,159,255,.24) 55%, transparent 80%); border: 1rpx solid rgba(91,240,216,.62); box-shadow: 0 0 18rpx rgba(91,240,216,.34); transform-origin: left center; animation: fairy-wing-r 3.5s ease-in-out infinite; }
.seat-wing-lr { position: absolute; width: 31rpx; height: 40rpx; right: -28rpx; top: 50rpx; border-radius: 40% 50% 40% 60% / 50% 40% 60% 50%; background: radial-gradient(ellipse at 30% 30%, rgba(123,159,255,.32) 0%, rgba(192,132,252,.18) 60%, transparent 85%); border: 1rpx solid rgba(123,159,255,.46); transform-origin: left top; animation: fairy-wing-r 3.5s ease-in-out infinite .18s; }
@keyframes fairy-wing-l { 0%, 100% { transform: scaleX(1) skewY(0deg); opacity: 1; } 30% { transform: scaleX(.58) skewY(5deg); opacity: .68; } 60% { transform: scaleX(.84) skewY(-2deg); opacity: .86; } }
@keyframes fairy-wing-r { 0%, 100% { transform: scaleX(1) skewY(0deg); opacity: 1; } 30% { transform: scaleX(.58) skewY(-5deg); opacity: .68; } 60% { transform: scaleX(.84) skewY(2deg); opacity: .86; } }
.wings-in-team .seat-wing { opacity: .25; animation-play-state: paused; }
.wings-dead .seat-wing { opacity: .08; animation-play-state: paused; }

/* 离线遮罩 */
.seat-offline-mask {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%; background: rgba(0,0,0,0.5); z-index: 3;
  display: flex; align-items: center; justify-content: center;
}
