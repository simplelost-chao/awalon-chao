.page {
  min-height: 100vh;
  position: relative;
}

.bg,
.mask {
  position: fixed;
  inset: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg, rgba(10, 12, 18, 0.58), rgba(10, 12, 18, 0.86));
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: rgba(12, 16, 24, 0.88);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.custom-nav-inner {
  position: relative;
  height: 40px;
  padding: 0 2rpx;
}

.custom-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #eef2fa;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-back-btn {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: auto;
  min-width: 0;
  height: 36rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  border: none;
  background: transparent;
  color: #dfe7f8;
  font-size: 26rpx;
  line-height: 1;
}

.nav-back-btn::after {
  border: none;
}

.content {
  position: relative;
  z-index: 2;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 0 24rpx 40rpx;
}

.panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(19, 23, 31, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title {
  color: #f2e5c8;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.meta {
  color: #9ba4b8;
  font-size: 22rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(0, 0, 0, 0.18);
}

.record-grid {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.avatar-col {
  width: 108rpx;
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}

.role-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-head-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.line {
  display: block;
  color: #cfd8ea;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.medal-row {
  margin-top: 8rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
}

.medal-chip {
  min-width: 0;
  padding: 10rpx 6rpx;
  border-radius: 14rpx;
  background: rgba(192, 145, 74, 0.24);
  border: 1rpx solid rgba(242, 202, 136, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.medal-chip-image {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.medal-chip-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.medal-chip-name {
  font-size: 20rpx;
  color: #f8e8c2;
  text-align: center;
  line-height: 1.3;
  word-break: break-word;
}

.strong {
  color: #f0d7a1;
  font-size: 26rpx;
  font-weight: 600;
  flex: 1;
}

.result-pill {
  flex-shrink: 0;
  min-width: 92rpx;
  height: 44rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 12rpx;
}

.result-win {
  color: #79e2a8;
  background: rgba(67, 137, 92, 0.28);
  border: 1rpx solid rgba(121, 226, 168, 0.5);
}

.result-lose {
  color: #ff8f8f;
  background: rgba(150, 56, 56, 0.3);
  border: 1rpx solid rgba(255, 143, 143, 0.52);
}

.btn-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.half {
  flex: 1;
}

.btn {
  height: 76rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
  padding: 0;
}

.btn::after {
  border: none;
}

.ghost {
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d3daea;
}
