}
.recap-section-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}
.recap-dots {
  display: flex;
  justify-content: center;
  padding: 12rpx 0 20rpx;
