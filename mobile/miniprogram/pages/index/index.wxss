}
.recap-think-label {
  font-size: 24rpx;
  color: #90a8ff;
  font-weight: 500;
}
.recap-think-arrow {
  font-size: 20rpx;
  color: #7080c8;
}
.recap-think-body {
  padding: 16rpx 24rpx 20rpx;
  background: rgba(20,30,100,0.15);
}
.recap-think-text {
  font-size: 22rpx;
  color: #8898cc;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}
.recap-section {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  border-left: 4rpx solid rgba(140,80,255,0.5);
}
.recap-section-label {
  display: block;
  font-size: 22rpx;
  color: #a080d8;
  font-weight: 600;
