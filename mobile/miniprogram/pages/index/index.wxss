/* ── Assassination Result ── */
@keyframes assassin-drop {
  0%   { opacity: 0; transform: translateY(-60rpx) rotate(-15deg) scale(0.7); }
  60%  { transform: translateY(10rpx) rotate(4deg) scale(1.05); }
  100% { opacity: 1; transform: translateY(0) rotate(0deg) scale(1); }
}
@keyframes assassin-fade-up {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes assassin-pulse-red {
  0%,100% { box-shadow: 0 0 0 0 rgba(220,40,40,0); }
  50%     { box-shadow: 0 0 0 16rpx rgba(220,40,40,0.35); }
}
@keyframes assassin-pulse-gold {
  0%,100% { box-shadow: 0 0 0 0 rgba(230,193,125,0); }
  50%     { box-shadow: 0 0 0 16rpx rgba(230,193,125,0.3); }
}
.assassin-overlay {
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 300;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 60rpx 40rpx;
}
.overlay-hit {
  background: radial-gradient(ellipse at center, rgba(80,8,8,0.97) 0%, rgba(8,2,2,0.98) 100%);
}
.overlay-miss {
  background: radial-gradient(ellipse at center, rgba(10,35,20,0.97) 0%, rgba(4,10,6,0.98) 100%);
}
.assassin-dagger-img {
  width: 260rpx;
  height: 260rpx;
  animation: assassin-drop 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.dagger-miss {
  opacity: 0.35;
  filter: grayscale(60%);
}
.assassin-result-text {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  text-align: center;
  animation: assassin-fade-up 0.4s ease 0.35s both;
}
.assassin-result-evil { color: #ff5a5a; text-shadow: 0 0 24rpx rgba(255,60,60,0.6); }
.assassin-result-good { color: #70e8a0; text-shadow: 0 0 24rpx rgba(80,220,140,0.5); }
.assassin-target-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  animation: assassin-fade-up 0.4s ease 0.5s both;
}
.assassin-avatar-wrap {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
}
.avatar-hit {
  border: 3rpx solid rgba(220,60,60,0.8);
  animation: assassin-pulse-red 1.2s ease 0.7s 3;
}
.avatar-miss {
  border: 3rpx solid rgba(230,193,125,0.7);
  animation: assassin-pulse-gold 1.2s ease 0.7s 3;
}
.assassin-target-avatar {
  width: 100%;
  height: 100%;
}
.assassin-avatar-text {
  width: 100%;
  height: 100%;
  background: rgba(40,20,60,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}
.assassin-target-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.assassin-target-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #eedfc0;
}
.assassin-role-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.assassin-role-img {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
}
.assassin-target-role {
  font-size: 26rpx;
  font-weight: 600;
  color: #e6c17d;
  letter-spacing: 1rpx;
}
.assassin-by {
  font-size: 22rpx;
  color: rgba(200,180,140,0.45);
  margin-top: 4rpx;
}
.assassin-close-hint {
  font-size: 20rpx;
  color: rgba(200,180,140,0.25);
  animation: assassin-fade-up 0.4s ease 1.2s both;
}
.mp-close-hint {
  position: fixed;
