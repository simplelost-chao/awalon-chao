  flex-direction: column;
  justify-content: flex-end;
}
.recap-modal {
  width: 100%;
  height: 85vh;
  z-index: 901;
  background: linear-gradient(160deg, #1a1430 0%, #0e1a2b 100%);
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1rpx solid rgba(140,100,255,0.3);
