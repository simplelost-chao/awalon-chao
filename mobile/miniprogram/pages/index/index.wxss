.page {
  position: relative;
  min-height: 100vh;
  overflow: auto;
}

.avatar-crop-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 128px;
  height: 128px;
  opacity: 0;
  pointer-events: none;
}

.share-invite-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 500px;
  height: 400px;
  opacity: 0;
  pointer-events: none;
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 80;
  background: rgba(12, 16, 24, 0.88);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.custom-nav-inner {
  position: relative;
  height: 40px;
  padding: 0 2rpx;
}

.custom-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 30rpx;
  font-weight: 700;
  color: #eef2fa;
  letter-spacing: 0.5rpx;
}

.nav-back-btn {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: auto;
  min-width: 0;
  height: 36rpx;
  line-height: 1;
  border-radius: 0;
  border: none;
  background: transparent;
  color: #dfe7f8;
  font-size: 26rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-btn::after {
  border: none;
}

.bg {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

.mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, rgba(10, 12, 18, 0.58), rgba(10, 12, 18, 0.86));
  z-index: 1;
}

.content {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 28rpx 48rpx;
  max-width: 760rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.resume-room {
  margin-bottom: 12rpx;
}

.panel {
  margin-top: 28rpx;
  background: rgba(19, 23, 31, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 24rpx;
  backdrop-filter: blur(6px);
}

.room-panel {
  position: relative;
  margin-left: -16rpx;
  margin-right: -16rpx;
  width: calc(100% + 32rpx);
  padding: 12rpx 6rpx 16rpx;
  background: rgba(10, 14, 22, 0.48);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(4px);
}

.status-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.on {
  background: #57db8f;
}

.dot.off {
  background: #d95d5d;
}

.status-text {
  color: #eef1f7;
  font-size: 28rpx;
}

.meta {
  margin-top: 12rpx;
  display: block;
  color: #9ba4b8;
  font-size: 22rpx;
}

.input {
  height: 84rpx;
  border-radius: 14rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: #eef1f7;
  background: rgba(0, 0, 0, 0.16);
  margin-bottom: 12rpx;
}

.input-placeholder {
  color: #8f99ad;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.picker-label {
  margin-top: 0;
}

.picker-value {
  min-width: 140rpx;
  text-align: center;
  padding: 12rpx 18rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: #eef1f7;
  background: rgba(0, 0, 0, 0.16);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.user-title-wrap {
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-left: 6rpx solid #d8b06b;
  border-radius: 10rpx;
  background: linear-gradient(90deg, rgba(216, 176, 107, 0.24), rgba(216, 176, 107, 0.04));
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.profile-avatar-wrap {
  position: relative;
  flex: 0 0 72rpx;
}

.profile-avatar-img,
.profile-avatar-fallback {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex: 0 0 72rpx;
}

.profile-avatar-img {
  border: 2rpx solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08);
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  font-size: 34rpx;
}

.profile-avatar-edit {
  position: absolute;
  right: -4rpx;
  bottom: -2rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(216, 176, 107, 0.95);
  border: 2rpx solid rgba(18, 14, 10, 0.9);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.22);
}

.profile-avatar-edit-icon {
  font-size: 16rpx;
  line-height: 1;
  color: #20160d;
}

.user-title-touch {
  min-width: 0;
  flex: 1;
  padding: 8rpx 0;
}

.user-title {
  display: block;
  color: #f2e5c8;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.profile-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: rgba(242, 229, 200, 0.72);
}

.home-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  overflow: hidden;
}

.home-action-grid .btn + .btn {
  margin-top: 0;
}

.home-action-btn {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
  margin-left: 0;
  margin-right: 0;
  height: 90rpx;
  margin-top: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.home-action-icon {
  width: 34rpx;
  height: 34rpx;
}

.home-action-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.home-action-text {
  font-size: 22rpx;
  color: #d9e1ef;
  white-space: nowrap;
}

.count-options-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.current-role-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.role-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  border: 1.5rpx solid;
  min-width: 56rpx;
}

.role-chip-good {
  border-color: rgba(46, 167, 255, 0.55);
  background: rgba(46, 100, 255, 0.1);
}

.role-chip-evil {
  border-color: rgba(255, 91, 91, 0.55);
  background: rgba(255, 60, 60, 0.1);
}

.role-chip-selected {
  border-color: rgba(228, 194, 129, 0.9);
  background: rgba(97, 67, 30, 0.5);
}

.role-chip-img {
  width: 44rpx;
  height: 44rpx;
  border-radius: 6rpx;
}

.role-chip-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.role-chip-name {
  font-size: 17rpx;
  color: #d3daea;
  text-align: center;
}

.role-chip-count {
  font-size: 15rpx;
  color: #aeb6c7;
  margin-left: 2rpx;
}

.count-options-row::-webkit-scrollbar {
  display: none;
}

.count-option {
  flex: 0 0 auto;
  min-width: 66rpx;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d3daea;
  font-size: 20rpx;
  background: rgba(0, 0, 0, 0.16);
  white-space: nowrap;
}

.count-option-on {
  color: #f9dfaa;
  border-color: rgba(228, 194, 129, 0.8);
  background: rgba(97, 67, 30, 0.44);
}

.role-mode-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 10rpx;
  flex-wrap: nowrap;
}

.role-mode-chip {
  min-width: 120rpx;
  text-align: center;
  padding: 10rpx 12rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d3daea;
  font-size: 22rpx;
  background: rgba(0, 0, 0, 0.16);
}

.role-mode-on {
  color: #f9dfaa;
  border-color: rgba(228, 194, 129, 0.8);
  background: rgba(97, 67, 30, 0.44);
}

.advanced-toggle {
  margin-top: 12rpx;
  margin-bottom: 10rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.advanced-toggle-title {
  color: #eef1f7;
  font-size: 24rpx;
  font-weight: 600;
}

.advanced-toggle-value {
  color: #e9c986;
  font-size: 22rpx;
}

.advanced-panel {
  margin-bottom: 12rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(233, 201, 134, 0.2);
  background: rgba(11, 15, 22, 0.5);
}

.advanced-section-label {
  display: block;
  color: #eef1f7;
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.advanced-selected-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.advanced-selected-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(233, 201, 134, 0.5);
  background: rgba(106, 74, 28, 0.42);
  color: #f6e4bc;
  font-size: 21rpx;
}

.advanced-role-grid {
  margin-top: 6rpx;
}

.role-selected-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.role-reset-btn {
  width: 148rpx;
  height: 58rpx;
  font-size: 22rpx;
}

.role-selected-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.role-selected-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 10rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(122, 212, 145, 0.72);
  background: rgba(52, 118, 74, 0.34);
}

.role-selected-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
}

.role-selected-text {
  font-size: 21rpx;
  color: #dff7e8;
}

.role-option-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.role-option-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 8rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(0, 0, 0, 0.16);
}

.role-option-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
}

.role-option-text {
  font-size: 20rpx;
  color: #d3daea;
}

.host-role-row {
  margin-top: 2rpx;
}

.host-role-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.host-role-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 8rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(0, 0, 0, 0.16);
}

.host-role-on {
  border-color: rgba(228, 194, 129, 0.82);
  background: rgba(97, 67, 30, 0.44);
}

.host-role-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
}

.host-role-fallback {
  width: 26rpx;
  text-align: center;
  font-size: 22rpx;
}

.host-role-text {
  font-size: 20rpx;
  color: #d3daea;
}

.btn-row {
  display: flex;
  gap: 14rpx;
}

.half {
  flex: 1;
}

.btn {
  margin-top: 0;
  height: 84rpx;
  line-height: 1;
  border-radius: 14rpx;
  font-size: 28rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn + .btn {
  margin-top: 16rpx;
}

.btn-row .btn + .btn {
  margin-top: 0;
}

.btn::after {
  border: none;
}

.primary {
  background: linear-gradient(180deg, #e4c281, #c89b52);
  color: #1a1510;
  border: none;
}

.ghost {
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d3daea;
}

.danger {
  background: linear-gradient(180deg, #ef8d8d, #b54444);
  border: 1rpx solid rgba(255, 200, 200, 0.35);
  color: #fff5f5;
}

.tips {
  margin-top: 20rpx;
  color: #8f99ad;
  font-size: 22rpx;
}

.table-wrap {
  position: relative;
  height: 780rpx;
  margin-top: 14rpx;
  margin-left: 4rpx;
  margin-right: 4rpx;
  width: auto;
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
}

.table-ring {
  position: absolute;
  width: 450rpx;
  height: 450rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 8rpx solid rgba(210, 155, 84, 0.45);
  box-shadow: 0 0 0 6rpx rgba(58, 30, 12, 0.34) inset;
}

.center-result {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 230rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(12, 16, 24, 0.82);
  text-align: center;
}

.force-round-banner {
  min-width: 248rpx;
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 122, 122, 0.55);
  background: linear-gradient(180deg, rgba(132, 20, 20, 0.92), rgba(84, 12, 12, 0.9));
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.28);
  text-align: center;
  z-index: 8;
}

.force-round-banner-block {
  margin: 12rpx 8rpx 6rpx;
}

.force-round-banner-main {
  display: block;
  color: #fff2f2;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.force-round-banner-sub {
  display: block;
  margin-top: 2rpx;
  color: rgba(255, 230, 230, 0.92);
  font-size: 18rpx;
}

.center-result-title {
  display: block;
  font-size: 26rpx;
  color: #f5d289;
  font-weight: 700;
}

.center-result-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #adb8cb;
}

.end-medal-wrap {
  margin-top: 10rpx;
}

.end-medal-title {
  display: block;
  font-size: 21rpx;
  color: #e7d6af;
}

.end-medal-row {
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: center;
}

.end-medal-chip {
  padding: 6rpx 10rpx 6rpx 6rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.end-medal-image {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.end-medal-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.end-medal-name {
  font-size: 20rpx;
}

.end-medal-good {
  color: #eaf2ff;
  background: rgba(74, 116, 188, 0.45);
}

.end-medal-evil {
  color: #fff1f1;
  background: rgba(171, 60, 60, 0.48);
}

.center-leader-panel {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 0;
  padding: 0;
  border: none;
  background: transparent;
  text-align: center;
}

.center-leader-title {
  display: block;
  font-size: 24rpx;
  color: #f5d289;
  font-weight: 700;
}

.center-leader-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #b9c4d8;
}

.center-leader-btn {
  margin-top: 10rpx;
  height: 72rpx;
  font-size: 24rpx;
}

.recap-btn-wrap {
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.recap-entry-btn {
  width: 100%;
  font-size: 26rpx;
  height: 72rpx;
  border-color: rgba(180, 160, 220, 0.5) !important;
  color: #c4a8e8 !important;
}

.player-vote-summary {
  display: inline-block;
  margin-top: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 214, 153, 0.3);
  background: rgba(89, 61, 22, 0.34);
  color: #f4ddb0;
  font-size: 20rpx;
  line-height: 1.3;
}

@keyframes mission-overlay-in {
  0%   { opacity: 0; }
  100% { opacity: 1; }
}
@keyframes mission-content-in {
  0%   { opacity: 0; transform: scale(0.88) translateY(30rpx); }
  60%  { transform: scale(1.03) translateY(-4rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes mission-success-glow {
  0%,100% { text-shadow: 0 0 20rpx rgba(120,230,160,0.4); }
  50%     { text-shadow: 0 0 50rpx rgba(120,230,160,0.9), 0 0 80rpx rgba(80,200,120,0.5); }
}
@keyframes mission-fail-shake {
  0%,100% { transform: translateX(0); }
  20%     { transform: translateX(-10rpx); }
  40%     { transform: translateX(10rpx); }
  60%     { transform: translateX(-6rpx); }
  80%     { transform: translateX(6rpx); }
}
@keyframes pip-pop {
  0%   { transform: scale(0); opacity: 0; }
  70%  { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}
.mission-overlay {
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: mission-overlay-in 0.25s ease both;
}
.mission-anim-success {
  background: radial-gradient(ellipse at center, rgba(10,50,25,0.96) 0%, rgba(4,12,8,0.97) 100%);
}
.mission-anim-fail {
  background: radial-gradient(ellipse at center, rgba(55,8,8,0.96) 0%, rgba(10,4,4,0.97) 100%);
}
.mission-overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  animation: mission-content-in 0.4s cubic-bezier(0.22,1,0.36,1) 0.05s both;
}
.mission-round-label {
  font-size: 26rpx;
  color: rgba(220,200,160,0.55);
  letter-spacing: 3rpx;
}
.mission-anim-image {
  width: 560rpx;
  border-radius: 16rpx;
}
.mission-anim-title {
  font-size: 52rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  text-align: center;
}
.mission-title-success {
  color: #88f0b0;
  animation: mission-success-glow 1.5s ease 0.4s infinite;
}
.mission-title-fail {
  color: #ff7070;
  animation: mission-fail-shake 0.45s ease 0.5s both;
}
.mission-fails-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}
.mission-fail-pip {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff5555;
  animation: pip-pop 0.3s cubic-bezier(0.22,1,0.36,1) 0.6s both;
}
.mission-fails-text {
  font-size: 24rpx;
  color: rgba(220,200,160,0.5);
  letter-spacing: 1rpx;
}

.seat-round {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 156rpx;
  height: 156rpx;
