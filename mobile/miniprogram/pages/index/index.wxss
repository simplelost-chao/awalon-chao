/* ── 帕西法尔蝴蝶翅膀 ──────────────────────────────── */
.seat-fairy-wings {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1; /* 低于 seat-avatar z:2，不遮边框 */
}

/* 上翼：左 */
.seat-wing-ul {
  position: absolute;
  width: 34rpx;
  height: 48rpx;
  left: -28rpx;
  top: 6rpx;
  border-radius: 60% 40% 40% 60% / 55% 45% 55% 45%;
  background: radial-gradient(ellipse at 72% 40%,
    rgba(91, 240, 216, .22) 0%,
    rgba(123, 159, 255, .13) 55%,
    transparent 80%);
  border: 1rpx solid rgba(91, 240, 216, .3);
  box-shadow: 0 0 12rpx rgba(91, 240, 216, .1);
  transform-origin: right center;
  animation: fairy-wing-l 3.5s ease-in-out infinite;
}

/* 하翼：左（下） */
.seat-wing-ll {
  position: absolute;
  width: 24rpx;
  height: 32rpx;
  left: -20rpx;
  top: 46rpx;
  border-radius: 50% 40% 60% 40% / 40% 50% 50% 60%;
  background: radial-gradient(ellipse at 70% 30%,
    rgba(123, 159, 255, .17) 0%,
    rgba(192, 132, 252, .09) 60%,
    transparent 85%);
  border: 1rpx solid rgba(123, 159, 255, .22);
  transform-origin: right top;
  animation: fairy-wing-l 3.5s ease-in-out infinite .18s;
}

/* 上翼：右 */
.seat-wing-ur {
  position: absolute;
  width: 34rpx;
  height: 48rpx;
  right: -28rpx;
  top: 6rpx;
  border-radius: 40% 60% 60% 40% / 45% 55% 45% 55%;
  background: radial-gradient(ellipse at 28% 40%,
    rgba(91, 240, 216, .22) 0%,
    rgba(123, 159, 255, .13) 55%,
    transparent 80%);
  border: 1rpx solid rgba(91, 240, 216, .3);
  box-shadow: 0 0 12rpx rgba(91, 240, 216, .1);
  transform-origin: left center;
  animation: fairy-wing-r 3.5s ease-in-out infinite;
}

/* 下翼：右 */
.seat-wing-lr {
  position: absolute;
  width: 24rpx;
  height: 32rpx;
  right: -20rpx;
  top: 46rpx;
  border-radius: 40% 50% 40% 60% / 50% 40% 60% 50%;
  background: radial-gradient(ellipse at 30% 30%,
    rgba(123, 159, 255, .17) 0%,
    rgba(192, 132, 252, .09) 60%,
    transparent 85%);
  border: 1rpx solid rgba(123, 159, 255, .22);
  transform-origin: left top;
  animation: fairy-wing-r 3.5s ease-in-out infinite .18s;
}

@keyframes fairy-wing-l {
  0%, 100% { transform: scaleX(1)    skewY(0deg);  opacity: .85; }
  30%       { transform: scaleX(.48) skewY(5deg);  opacity: .52; }
  60%       { transform: scaleX(.78) skewY(-2deg); opacity: .72; }
}

@keyframes fairy-wing-r {
  0%, 100% { transform: scaleX(1)    skewY(0deg);   opacity: .85; }
  30%       { transform: scaleX(.48) skewY(-5deg);  opacity: .52; }
  60%       { transform: scaleX(.78) skewY(2deg);   opacity: .72; }
}

/* 队伍选中时：翼降权，绿光视觉优先 */
.wings-in-team .seat-wing {
  opacity: .25;
  animation-play-state: paused;
}

/* 被刺杀时：翼消隐，停止动画 */
.wings-dead .seat-wing {
  opacity: .08;
  animation-play-state: paused;
}

