.page {
  position: relative;
  min-height: 100vh;
  overflow: auto;
  background-image: var(--aw-bg-image);
  background-size: cover;
  background-position: center;

  /* ── 身份阵营颜色系统 ────────────────────────── */
  --id-evil-main:   248, 113, 113;   /* 红 */
  --id-good-main:    78, 158, 255;   /* 蓝 */
  --id-merlin-main: 192, 132, 252;   /* 紫 */
  --id-evil-bg:     127,  29,  29;
  --id-good-bg:       7,  50, 120;
  --id-merlin-bg:    88,  28, 135;
  --id-evil-text:   #fecaca;
  --id-good-text:   #bfdbfe;
  --id-merlin-text: #e9d5ff;
}

.avatar-crop-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 128px;
  height: 128px;
  opacity: 0;
  pointer-events: none;
}

.share-invite-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 500px;
  height: 400px;
  opacity: 0;
  pointer-events: none;
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 80;
  background: var(--aw-nav-bg);
  border-bottom: 1rpx solid var(--aw-nav-border);
}

.custom-nav-inner {
  position: relative;
  height: 40px;
  padding: 0 2rpx;
}

.custom-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 30rpx;
  font-weight: 700;
  color: var(--aw-text);
  letter-spacing: 0.5rpx;
}

.nav-back-btn {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: auto;
  min-width: 0;
  height: 36rpx;
  line-height: 1;
  border-radius: 0;
  border: none;
  background: transparent;
  color: var(--aw-text);
  font-size: 26rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-btn::after {
  border: none;
}

.role-action-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
  padding: 8rpx 14rpx;
  border-left: 6rpx solid var(--aw-accent);
  border-radius: 8rpx;
  background: linear-gradient(90deg, rgba(216, 176, 107, 0.2), rgba(216, 176, 107, 0.04));
  color: #f2e5c8;
}

.section-title-row-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  position: relative;
  z-index: 5;
  flex-shrink: 0;
}
.resend-role-btn-active {
  color: var(--aw-accent);
  border-color: rgba(217,179,107,0.6);
}

.assassin-target-chip {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #ff9898;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(160, 30, 30, 0.22);
  border: 1rpx solid rgba(220, 80, 80, 0.5);
  line-height: 1.4;
}

.bg {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

.mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, rgba(10, 12, 18, 0.58), rgba(10, 12, 18, 0.86));
  z-index: 1;
}

.content {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 28rpx 48rpx;
  max-width: 760rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
}
.content-home {
  justify-content: center;
}
.content-game {
  justify-content: flex-start;
}

.resume-room {
  margin-bottom: 12rpx;
}

.panel {
  margin-top: 28rpx;
  background: var(--aw-panel);
  border: 1rpx solid var(--aw-panel-border);
  border-radius: 20rpx;
  padding: 24rpx;
  backdrop-filter: blur(6px);
}

.room-panel {
  position: relative;
  margin-left: -16rpx;
  margin-right: -16rpx;
  width: calc(100% + 32rpx);
  padding: 12rpx 6rpx 16rpx;
  background: rgba(10, 14, 22, 0.48);
  border: 1rpx solid var(--aw-panel-border);
  backdrop-filter: blur(4px);
}

.status-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.on {
  background: #57db8f;
}

.dot.off {
  background: #d95d5d;
}

.status-text {
  color: var(--aw-text);
  font-size: 28rpx;
}

.meta {
  margin-top: 12rpx;
  display: block;
  color: #9ba4b8;
  font-size: 22rpx;
}

.input {
  height: 84rpx;
  border-radius: 14rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--aw-panel-border);
  color: var(--aw-text);
  background: rgba(0, 0, 0, 0.16);
  margin-bottom: 12rpx;
}

.input-placeholder {
  color: #8f99ad;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.picker-label {
  margin-top: 0;
}

.picker-value {
  min-width: 140rpx;
  text-align: center;
  padding: 12rpx 18rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: var(--aw-text);
  background: rgba(0, 0, 0, 0.16);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.user-title-wrap {
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-left: 6rpx solid var(--aw-accent);
  border-radius: 10rpx;
  background: linear-gradient(90deg, rgba(216, 176, 107, 0.24), rgba(216, 176, 107, 0.04));
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.logout-btn {
  margin-left: auto;
  font-size: 22rpx;
  color: #6a7a9a;
  padding: 6rpx 12rpx;
  border: 1rpx solid rgba(106,122,154,0.3);
  border-radius: 999rpx;
  flex-shrink: 0;
}

.profile-avatar-wrap {
  position: relative;
  flex: 0 0 72rpx;
}

.profile-avatar-img,
.profile-avatar-fallback {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex: 0 0 72rpx;
}

.profile-avatar-img {
  border: 2rpx solid rgba(255, 255, 255, 0.16);
  background: var(--aw-nav-border);
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--aw-nav-border);
  font-size: 34rpx;
}

.profile-avatar-edit {
  position: absolute;
  right: -4rpx;
  bottom: -2rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(216, 176, 107, 0.95);
  border: 2rpx solid rgba(18, 14, 10, 0.9);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.22);
}

.profile-avatar-edit-icon {
  font-size: 16rpx;
  line-height: 1;
  color: #20160d;
}

.user-title-touch {
  min-width: 0;
  flex: 1;
  padding: 8rpx 0;
}

.user-title {
  display: block;
  color: #f2e5c8;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.profile-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: rgba(242, 229, 200, 0.72);
}

.guest-login-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(30, 90, 200, 0.15);
  border: 1rpx solid rgba(80, 160, 255, 0.3);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}
.guest-login-text {
  font-size: 26rpx;
  color: rgba(200, 220, 255, 0.85);
  flex: 1;
}
.guest-login-btn {
  font-size: 26rpx;
  font-weight: 700;
  color: #7eb8ff;
  margin-left: 16rpx;
  padding: 6rpx 20rpx;
  border: 1rpx solid rgba(80, 160, 255, 0.5);
  border-radius: 20rpx;
}

.home-action-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  overflow: hidden;
}

.home-action-grid .btn + .btn {
  margin-top: 0;
}

.home-action-btn {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
  margin-left: 0;
  margin-right: 0;
  height: 100rpx;
  margin-top: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 0 8rpx;
}

.home-action-icon {
  width: 34rpx;
  height: 34rpx;
}

.home-action-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.home-action-text {
  font-size: 22rpx;
  color: #d9e1ef;
  white-space: nowrap;
}

.count-options-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.current-role-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.role-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  border: 1.5rpx solid;
  min-width: 56rpx;
}

.role-chip-good {
  border-color: rgba(80, 160, 255, 0.55);
  background: rgba(30, 90, 200, 0.12);
}

.role-chip-evil {
  border-color: rgba(220, 80, 90, 0.55);
  background: rgba(160, 35, 45, 0.12);
}

.role-chip-selected {
  border-color: rgba(228, 194, 129, 0.9);
  background: rgba(97, 67, 30, 0.5);
}

.role-chip-img {
  width: 44rpx;
  height: 44rpx;
  border-radius: 6rpx;
}

.role-chip-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.role-chip-name {
  font-size: 17rpx;
  color: #d3daea;
  text-align: center;
}

.role-chip-count {
  font-size: 15rpx;
  color: var(--aw-subtext);
  margin-left: 2rpx;
}

.count-options-row::-webkit-scrollbar {
  display: none;
}

.count-option {
  flex: 0 0 auto;
  min-width: 66rpx;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d3daea;
  font-size: 20rpx;
  background: rgba(0, 0, 0, 0.16);
  white-space: nowrap;
}

.count-option-on {
  color: #f9dfaa;
  border-color: rgba(228, 194, 129, 0.8);
  background: rgba(97, 67, 30, 0.44);
}

.role-mode-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 10rpx;
  flex-wrap: nowrap;
}

.role-mode-chip {
  min-width: 120rpx;
  text-align: center;
  padding: 10rpx 12rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d3daea;
  font-size: 22rpx;
  background: rgba(0, 0, 0, 0.16);
}

.role-mode-on {
  color: #f9dfaa;
  border-color: rgba(228, 194, 129, 0.8);
  background: rgba(97, 67, 30, 0.44);
}

.advanced-toggle {
  margin-top: 12rpx;
  margin-bottom: 10rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--aw-input-border);
  background: rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.advanced-toggle-title {
  color: var(--aw-text);
  font-size: 24rpx;
  font-weight: 600;
}

.advanced-toggle-value {
  color: #e9c986;
  font-size: 22rpx;
}

.advanced-panel {
  margin-bottom: 12rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(233, 201, 134, 0.2);
  background: rgba(11, 15, 22, 0.5);
}

.advanced-section-label {
  display: block;
  color: var(--aw-text);
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.advanced-selected-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.advanced-selected-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(233, 201, 134, 0.5);
  background: rgba(106, 74, 28, 0.42);
  color: #f6e4bc;
  font-size: 21rpx;
}

.advanced-role-grid {
  margin-top: 6rpx;
}

.role-selected-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.role-reset-btn {
  width: 148rpx;
  height: 58rpx;
  font-size: 22rpx;
}

.role-selected-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.role-selected-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 10rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(122, 212, 145, 0.72);
  background: rgba(52, 118, 74, 0.34);
}

.role-selected-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
}

.role-selected-text {
  font-size: 21rpx;
  color: #dff7e8;
}

.role-option-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.role-option-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 8rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(0, 0, 0, 0.16);
}

.role-option-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
}

.role-option-text {
  font-size: 20rpx;
  color: #d3daea;
}

.host-role-row {
  margin-top: 2rpx;
}

.host-role-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.host-role-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 8rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(0, 0, 0, 0.16);
}

.host-role-on {
  border-color: rgba(228, 194, 129, 0.82);
  background: rgba(97, 67, 30, 0.44);
}

.host-role-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
}

.host-role-fallback {
  width: 26rpx;
  text-align: center;
  font-size: 22rpx;
}

.host-role-text {
  font-size: 20rpx;
  color: #d3daea;
}

.btn-row {
  display: flex;
  gap: 14rpx;
}

.room-toggle-btn,
.role-toggle-btn {
  gap: 8rpx;
}

.toggle-arrow {
  font-size: 20rpx;
  opacity: 0.7;
}

.btn-disabled {
  opacity: 0.38;
}

.role-info-loading {
  padding: 24rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.role-info-loading-text {
  font-size: 24rpx;
  color: #8a95aa;
}

.half {
  flex: 1;
}

.btn {
  margin-top: 0;
  height: 80rpx;
  line-height: 1;
  border-radius: 20rpx;
  font-size: 26rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn + .btn {
  margin-top: 16rpx;
}

.btn-row .btn + .btn {
  margin-top: 0;
}

.btn::after {
  border: none;
}

.primary {
  background: linear-gradient(180deg, #e4c281, #c89b52);
  color: #1a1510;
  border: none;
}

.ghost {
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d3daea;
}

.danger {
  background: linear-gradient(180deg, #ef8d8d, #b54444);
  border: 1rpx solid rgba(255, 200, 200, 0.35);
  color: #fff5f5;
}

/* ─── 圆桌共享样式 ── */
@import '/styles/round-table.wxss';

/* 游戏内圆桌：开始按钮移入中央后，取消负 margin-bottom */
.table-wrap {
  margin-bottom: 20rpx;
}

.table-ring {
  position: absolute;
  width: 450rpx;
  height: 450rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  /* border: 8rpx solid rgba(210, 155, 84, 0.45); */
  /* box-shadow: 0 0 0 6rpx rgba(58, 30, 12, 0.34) inset; */
  pointer-events: none;
}

.center-result {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 230rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: var(--aw-nav-bg);
  text-align: center;
}

.force-round-banner {
  min-width: 248rpx;
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 122, 122, 0.55);
  background: linear-gradient(180deg, rgba(132, 20, 20, 0.92), rgba(84, 12, 12, 0.9));
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.28);
  text-align: center;
  z-index: 8;
}

.force-round-banner-block {
  margin: 12rpx 8rpx 6rpx;
}

.force-round-banner-main {
  display: block;
  color: #fff2f2;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.force-round-banner-sub {
  display: block;
  margin-top: 2rpx;
  color: rgba(255, 230, 230, 0.92);
  font-size: 18rpx;
}

.center-result-title {
  display: block;
  font-size: 26rpx;
  color: #f5d289;
  font-weight: 700;
}

.center-result-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #adb8cb;
}

.end-medal-wrap {
  margin-top: 10rpx;
}

.end-medal-title {
  display: block;
  font-size: 21rpx;
  color: #e7d6af;
}

.end-medal-row {
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: center;
}

.end-medal-chip {
  padding: 6rpx 10rpx 6rpx 6rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.end-medal-image {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.end-medal-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.end-medal-name {
  font-size: 20rpx;
}

.end-medal-good {
  color: #eaf2ff;
  background: rgba(30, 90, 200, 0.45);
}

.end-medal-evil {
  color: #fff1f1;
  background: rgba(160, 35, 45, 0.45);
}

.center-leader-panel {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 0;
  padding: 0;
  border: none;
  background: transparent;
  text-align: center;
}

.center-leader-title {
  display: block;
  font-size: 24rpx;
  color: #f5d289;
  font-weight: 700;
}

.center-leader-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #b9c4d8;
}

.center-leader-btn {
  margin-top: 10rpx;
  height: 72rpx;
  font-size: 24rpx;
}

.center-assassin-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: auto;
  top: 46% !important;
}
.center-assassin-hint {
  font-size: 18rpx;
  color: rgba(248, 113, 113, 0.6);
  letter-spacing: 1rpx;
}
.center-assassin-btn {
  display: inline-block;
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  background: rgba(140, 30, 30, 0.6);
  border: 1rpx solid rgba(248, 113, 113, 0.35);
  border-radius: 14rpx;
  color: rgba(255, 200, 200, 0.9);
  font-weight: 500;
  text-align: center;
}

.recap-btn-wrap {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.recap-entry-btn {
  width: 100%;
  font-size: 26rpx;
  height: 72rpx;
  border-color: rgba(180, 160, 220, 0.5) !important;
  color: #c4a8e8 !important;
}

.recap-btn-pending {
  opacity: 0.5;
  border-color: rgba(150, 150, 170, 0.3) !important;
  color: #8890a8 !important;
}


/* ── Mission progress overlay (spectators view during mission phase) ── */
@keyframes mp-fade-in {
  0%   { opacity: 0; }
  100% { opacity: 1; }
}
@keyframes mp-card-in {
  0%   { opacity: 0; transform: translateY(20rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
@keyframes mp-title-glow {
  0%, 100% { text-shadow: 0 0 20rpx rgba(160,120,255,0.4), 0 0 60rpx rgba(120,80,220,0.2); }
  50%       { text-shadow: 0 0 40rpx rgba(180,140,255,0.9), 0 0 100rpx rgba(140,100,255,0.5); }
}
@keyframes mp-ring-pulse {
  0%, 100% { transform: scale(1);    box-shadow: 0 0 12rpx rgba(140,100,255,0.35); }
  50%       { transform: scale(1.08); box-shadow: 0 0 28rpx rgba(160,120,255,0.7); }
}
@keyframes mp-pip-pop {
  0%   { transform: scale(0); opacity: 0; }
  70%  { transform: scale(1.4); }
  100% { transform: scale(1); opacity: 1; }
}
.mp-overlay {
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 190;
  background: radial-gradient(ellipse at center, rgba(20,10,50,0.97) 0%, rgba(4,8,20,0.98) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: mp-fade-in 0.25s ease both;
}
.mp-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: mp-card-in 0.45s cubic-bezier(0.22,1,0.36,1) 0.05s both;
}
.mp-round-label {
  font-size: 26rpx;
  color: rgba(200,170,255,0.5);
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}
.mp-heading {
  font-size: 64rpx;
  font-weight: 900;
  color: #d8c0ff;
  letter-spacing: 12rpx;
  margin-bottom: 56rpx;
  animation: mp-title-glow 1.8s ease-in-out infinite;
}
.mp-heading-done {
  font-size: 64rpx;
  font-weight: 900;
  color: #f0c060;
  letter-spacing: 12rpx;
  animation: mp-gold-glow 1.6s ease-in-out infinite;
}
@keyframes mp-gold-glow {
  0%, 100% { text-shadow: 0 0 20rpx rgba(240,180,60,0.4), 0 0 60rpx rgba(200,140,20,0.2); }
  50%       { text-shadow: 0 0 40rpx rgba(255,200,80,0.9), 0 0 100rpx rgba(220,160,30,0.6); }
}
.mp-hint-text {
  font-size: 26rpx;
  color: rgba(200,180,255,0.45);
  letter-spacing: 2rpx;
  margin-top: -36rpx;
  margin-bottom: 56rpx;
}
.mp-hint-reveal {
  font-size: 26rpx;
  color: rgba(255,200,80,0.75);
  letter-spacing: 3rpx;
  margin-top: -36rpx;
  margin-bottom: 56rpx;
  animation: mp-hint-fade 1.2s ease-in-out infinite alternate;
}
@keyframes mp-hint-fade {
  from { opacity: 0.6; }
  to   { opacity: 1; }
}
.mp-avatars {
  display: flex;
  flex-direction: row;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 48rpx;
}
.mp-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 24rpx;
  position: relative;
}
.mp-av-img,
.mp-av-emoji {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
}
.mp-av-img {
  background: var(--aw-input-bg);
}
.mp-av-emoji {
  display: block;
  line-height: 110rpx;
  text-align: center;
  font-size: 52rpx;
  background: rgba(80,60,140,0.5);
}
.mp-av-pending .mp-av-img,
.mp-av-pending .mp-av-emoji {
  border: 3rpx solid rgba(160,120,255,0.7);
  animation: mp-ring-pulse 1.6s ease-in-out infinite;
  will-change: transform;
}
.mp-av-voted .mp-av-img,
.mp-av-voted .mp-av-emoji {
  border: 3rpx solid #40c870;
  box-shadow: 0 0 16rpx rgba(60,200,100,0.6);
  animation: none;
}
.mp-av-voted .mp-av-name {
  color: rgba(100,220,140,0.9);
}
.mp-av-check {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  background: #38c068;
  border-radius: 50%;
  color: #fff;
  border: 2rpx solid rgba(0,0,0,0.4);
  animation: mp-pip-pop 0.3s cubic-bezier(0.22,1,0.36,1) both;
}
.mp-av-name {
  display: block;
  font-size: 22rpx;
  color: rgba(220,200,255,0.7);
  margin-top: 12rpx;
  text-align: center;
  max-width: 140rpx;
}
.mp-av-seat {
  color: rgba(217,179,107,0.85);
  font-size: 20rpx;
  margin-right: 4rpx;
}
.mp-pips {
  display: flex;
  flex-direction: row;
  justify-content: center;
  margin-bottom: 20rpx;
}
.mp-pip {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin: 0 8rpx;
}
.mp-pip-wait {
  background: var(--aw-panel-border);
  border: 1rpx solid rgba(255,255,255,0.2);
}
.mp-pip-done {
  background: #9060e0;
  box-shadow: 0 0 12rpx rgba(140,80,255,0.7);
  animation: mp-pip-pop 0.35s cubic-bezier(0.22,1,0.36,1) both;
}
.mp-status-text {
  font-size: 26rpx;
  color: rgba(200,180,255,0.5);
  letter-spacing: 2rpx;
}

@keyframes mission-overlay-in {
  0%   { opacity: 0; }
  40%  { opacity: 0; }
  100% { opacity: 1; }
}
@keyframes mission-content-in {
  0%   { opacity: 0; transform: scale(0.9) translateY(24rpx); }
  60%  { transform: scale(1.02) translateY(-3rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes mission-success-glow {
  0%,100% { text-shadow: 0 0 20rpx rgba(120,230,160,0.4); }
  50%     { text-shadow: 0 0 50rpx rgba(120,230,160,0.9), 0 0 80rpx rgba(80,200,120,0.5); }
}
@keyframes mission-fail-shake {
  0%,100% { transform: translateX(0); }
  20%     { transform: translateX(-10rpx); }
  40%     { transform: translateX(10rpx); }
  60%     { transform: translateX(-6rpx); }
  80%     { transform: translateX(6rpx); }
}
@keyframes pip-pop {
  0%   { transform: scale(0); opacity: 0; }
  70%  { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}
.mission-overlay {
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 200;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  animation: mission-overlay-in 0.55s ease both;
}
.mission-anim-success {
  background: radial-gradient(ellipse at center, rgba(10,50,25,0.96) 0%, rgba(4,12,8,0.97) 100%);
}
.mission-anim-fail {
  background: radial-gradient(ellipse at center, rgba(55,8,8,0.96) 0%, rgba(10,4,4,0.97) 100%);
}
.mission-overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  animation: mission-content-in 0.4s cubic-bezier(0.22,1,0.36,1) 0.05s both;
}
.mission-round-label {
  font-size: 26rpx;
  color: rgba(220,200,160,0.55);
  letter-spacing: 3rpx;
}
.mission-anim-image {
  width: 560rpx;
  border-radius: 16rpx;
}
.mission-anim-title {
  font-size: 52rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  text-align: center;
}
.mission-title-success {
  color: #88f0b0;
  animation: mission-success-glow 1.5s ease 0.4s infinite;
}
.mission-title-fail {
  color: #ff7070;
  animation: mission-fail-shake 0.45s ease 0.5s both;
}
.mission-fails-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}
.mission-fail-pip {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff5555;
  animation: pip-pop 0.3s cubic-bezier(0.22,1,0.36,1) 0.6s both;
}
.mission-fails-text {
  font-size: 24rpx;
  color: rgba(220,200,160,0.5);
  letter-spacing: 1rpx;
}

/* 游戏内固定高度，防止 translate 因内容增减而跳动 */
.seat-card { height: 118rpx; }

/* ── 头像交互态 ── */
.seat-av-me {
  border-color: rgba(233, 191, 112, 0.95) !important;
  box-shadow: 0 0 0 4rpx rgba(233, 191, 112, 0.22) !important;
}

.seat-av-team {
  border-color: rgba(100, 220, 140, 0.92) !important;
  box-shadow: 0 0 28rpx rgba(80, 200, 120, 0.5), 0 0 0 4rpx rgba(80, 200, 120, 0.18) !important;
  background: rgba(10, 45, 20, 0.88) !important;
}

.seat-av-kill {
  border-color: rgba(239, 80, 80, 0.95) !important;
  box-shadow: 0 0 28rpx rgba(220, 50, 50, 0.5), 0 0 0 4rpx rgba(220, 50, 50, 0.2) !important;
  background: rgba(45, 8, 8, 0.9) !important;
}

.seat-av-assassinated {
  opacity: 0.5;
}

/* ── 圆桌身份模式 ── */

/* 光晕底层元素（始终存在，identity-mode 下按阵营显色） */
.seat-id-aura {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.5s ease;
  z-index: 0;
}

/* 身份标签内的角色图 */
.seat-id-role-img {
  width: 28rpx;
  height: 28rpx;
  border-radius: 4rpx;
  flex: 0 0 24rpx;
  margin-right: 6rpx;
}

/* 身份标签（初始隐藏，identity-mode 下按阵营显示） */
.seat-id-tag {
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  white-space: nowrap;
  opacity: 0;
  transform: translateY(-4rpx);
  transition: opacity 0.35s ease, transform 0.35s ease;
  pointer-events: none;
  /* 默认透明，后面 identity-mode 下按阵营设色 */
  background: transparent;
  border: 1rpx solid transparent;
  color: transparent;
}

/* 未知座位：身份模式下淡出隐藏 */
.seat-card { transition: opacity 0.3s ease; }
.identity-mode .seat-card.id-unknown { opacity: 0; pointer-events: none; }

/* 坏人 ── 红色系 (#f87171) */
.identity-mode .seat-card.id-evil .seat-avatar {
  border-color: rgba(248, 113, 113, 0.9) !important;
  box-shadow: 0 0 0 4rpx rgba(248, 113, 113, 0.2), 0 0 32rpx rgba(248, 113, 113, 0.55) !important;
  background: rgba(127, 29, 29, 0.4) !important;
}
.identity-mode .seat-card.id-evil .seat-id-aura {
  background: radial-gradient(circle, rgba(248, 113, 113, 0.22) 0%, transparent 70%);
  opacity: 1;
}
.identity-mode .seat-card.id-evil .seat-id-tag {
  opacity: 1;
  transform: translateY(0);
  background: rgba(127, 29, 29, 0.65);
  border-color: rgba(248, 113, 113, 0.5);
  color: #fecaca;
}
.identity-mode .seat-card.id-evil .seat-name { color: #fecaca; }

/* 好人（含梅林）── 蓝色系 (#4e9eff) */
.identity-mode .seat-card.id-good .seat-avatar,
.identity-mode .seat-card.id-merlin .seat-avatar {
  border-color: rgba(78, 158, 255, 0.85) !important;
  box-shadow: 0 0 0 4rpx rgba(78, 158, 255, 0.18), 0 0 28rpx rgba(78, 158, 255, 0.45) !important;
  background: rgba(7, 50, 120, 0.35) !important;
}
.identity-mode .seat-card.id-good .seat-id-aura,
.identity-mode .seat-card.id-merlin .seat-id-aura {
  background: radial-gradient(circle, rgba(78, 158, 255, 0.16) 0%, transparent 70%);
  opacity: 1;
}
.identity-mode .seat-card.id-good .seat-id-tag,
.identity-mode .seat-card.id-merlin .seat-id-tag {
  opacity: 1;
  transform: translateY(0);
  background: rgba(7, 50, 120, 0.6);
  border-color: rgba(78, 158, 255, 0.45);
  color: #bfdbfe;
}
.identity-mode .seat-card.id-good .seat-name,
.identity-mode .seat-card.id-merlin .seat-name { color: #bfdbfe; }

/* 身份模式下 role-pill 跟阵营色 */
.identity-mode .seat-card.id-good .seat-role-pill,
.identity-mode .seat-card.id-merlin .seat-role-pill {
  background: rgba(7, 50, 120, 0.55) !important;
  border-color: rgba(78, 158, 255, 0.45) !important;
}
.identity-mode .seat-card.id-good .seat-role,
.identity-mode .seat-card.id-merlin .seat-role { color: #bfdbfe !important; }

.identity-mode .seat-card.id-evil .seat-role-pill {
  background: rgba(127, 29, 29, 0.6) !important;
  border-color: rgba(248, 113, 113, 0.5) !important;
}
.identity-mode .seat-card.id-evil .seat-role { color: #fecaca !important; }

/* 自己（金色覆盖阵营色） */
.identity-mode .seat-card.id-evil .seat-av-me,
.identity-mode .seat-card.id-merlin .seat-av-me,
.identity-mode .seat-card.id-good .seat-av-me {
  border-color: rgba(226, 184, 74, 0.95) !important;
  box-shadow: 0 0 0 4rpx rgba(226, 184, 74, 0.28), 0 0 28rpx rgba(226, 184, 74, 0.55) !important;
}

/* 中心自己身份标识 */
.center-id-label {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  pointer-events: none;
}
.center-id-role {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(226, 184, 74, 0.85);
  letter-spacing: 2rpx;
}
.center-id-sub {
  font-size: 20rpx;
  color: rgba(226, 184, 74, 0.45);
  letter-spacing: 4rpx;
}

/* 组队选中时名字变色 */
.seat-name-team { color: rgba(140, 230, 170, 0.92) !important; }


.seat-crown {
  position: absolute;
  top: -40rpx;
  font-size: 30rpx;
  text-shadow: 0 2rpx 6rpx rgba(72, 42, 8, 0.55);
  z-index: 5;
}

/* ── 座位状态徽章 ── */
.seat-status-badge {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(8, 11, 18, 0.96);
  border: 3rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* 发言中 — 黄色声波 */
.seat-badge-speak {
  border-color: rgba(251, 191, 36, 0.8);
  box-shadow: 0 0 14rpx rgba(251, 191, 36, 0.45);
  gap: 4rpx;
}
.ssb-bar {
  width: 4rpx;
  border-radius: 4rpx;
  background: #fbbf24;
  animation: ssb-soundbar 0.7s ease-in-out infinite alternate;
  transform-origin: bottom;
}
.ssb-bar-1 { animation-delay: 0s;     animation-duration: 0.65s; }
.ssb-bar-2 { animation-delay: 0.18s;  animation-duration: 0.55s; }
.ssb-bar-3 { animation-delay: 0.35s;  animation-duration: 0.75s; }
@keyframes ssb-soundbar {
  0%   { height: 4rpx;  opacity: 0.5; }
  100% { height: 16rpx; opacity: 1;   }
}

/* 投票中 — 黄色纸片投入 */
.seat-badge-voting {
  border-color: rgba(251, 191, 36, 0.8);
  box-shadow: 0 0 14rpx rgba(251, 191, 36, 0.4);
  overflow: hidden;
}
.ssb-ballot-box {
  position: relative;
  width: 16rpx;
  height: 18rpx;
  overflow: hidden;
}
.ssb-ballot-slip {
  position: absolute;
  top: 0; left: 50%;
  width: 11rpx; height: 7rpx;
  background: #fbbf24;
  border-radius: 2rpx;
  transform: translateX(-50%) rotate(-8deg);
  animation: ssb-ballot-fall 1.6s cubic-bezier(0.4,0,0.6,1) infinite;
}
.ssb-ballot-slot {
  position: absolute;
  bottom: 2rpx; left: 0; right: 0;
  height: 2rpx;
  background: rgba(251, 191, 36, 0.5);
  border-radius: 2rpx;
}
@keyframes ssb-ballot-fall {
  0%   { top: -10rpx; opacity: 0; transform: translateX(-50%) rotate(-8deg); }
  20%  { opacity: 1; }
  70%  { top: 9rpx;  opacity: 1; transform: translateX(-50%) rotate(-3deg); }
  85%  { top: 14rpx; opacity: 0; transform: translateX(-50%) rotate(0deg); }
  100% { top: 14rpx; opacity: 0; }
}

/* 已投票 — 绿色信封 */
.seat-badge-voted {
  border-color: rgba(52, 211, 153, 0.8);
  box-shadow: 0 0 12rpx rgba(52, 211, 153, 0.3);
}
.ssb-envelope {
  position: relative;
  width: 18rpx; height: 13rpx;
  border: 2rpx solid rgba(52, 211, 153, 0.7);
  border-radius: 2rpx;
  background: rgba(52, 211, 153, 0.08);
  overflow: hidden;
}
.ssb-env-v-left {
  position: absolute;
  top: 0; left: 0;
  width: 10rpx; height: 2rpx;
  background: rgba(52, 211, 153, 0.65);
  transform: rotate(32deg);
  transform-origin: left top;
}
.ssb-env-v-right {
  position: absolute;
  top: 0; right: 0;
  width: 10rpx; height: 2rpx;
  background: rgba(52, 211, 153, 0.65);
  transform: rotate(-32deg);
  transform-origin: right top;
}

/* 出征中 — 黄色旋转环 */
.seat-badge-mission {
  border-color: rgba(251, 191, 36, 0.8);
  box-shadow: 0 0 16rpx rgba(251, 191, 36, 0.4);
  overflow: visible;
}
.ssb-mission-ring {
  position: absolute;
  inset: -8rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  border-top-color: #fbbf24;
  border-right-color: rgba(251, 191, 36, 0.3);
  animation: ssb-spin 1.2s linear infinite;
}
.ssb-mission-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: #fbbf24;
  animation: ssb-mission-pulse 1.2s ease-in-out infinite;
}
@keyframes ssb-spin { to { transform: rotate(360deg); } }
@keyframes ssb-mission-pulse {
  0%, 100% { opacity: 0.7; transform: scale(0.85); }
  50%       { opacity: 1;   transform: scale(1.1);  }
}

/* 出征完毕 — 绿色同心双圆 */
.seat-badge-mission-done {
  border-color: rgba(52, 211, 153, 0.75);
  box-shadow: 0 0 12rpx rgba(52, 211, 153, 0.25);
}
.ssb-seal-outer {
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(52, 211, 153, 0.6);
  display: flex; align-items: center; justify-content: center;
}
.ssb-seal-inner {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: #34d399;
  box-shadow: 0 0 8rpx rgba(52, 211, 153, 0.9);
}


/* 托管中 — 双环联动 ∞ 无限循环 */
.seat-badge-autoplay {
  border-color: rgba(99, 179, 237, 0.75);
  box-shadow: 0 0 14rpx rgba(99, 179, 237, 0.4);
  overflow: hidden;
}
.ssb-auto-infinity {
  position: relative;
  width: 26rpx;
  height: 13rpx;
}
.ssb-auto-left,
.ssb-auto-right {
  position: absolute;
  width: 13rpx;
  height: 13rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
}
.ssb-auto-left {
  left: 0;
  border-top-color: #63b3ed;
  border-left-color: #63b3ed;
  border-bottom-color: rgba(99, 179, 237, 0.3);
  animation: ssb-spin 1.6s linear infinite;
}
.ssb-auto-right {
  right: 0;
  border-bottom-color: #63b3ed;
  border-right-color: #63b3ed;
  border-top-color: rgba(99, 179, 237, 0.3);
  animation: ssb-spin 1.6s linear infinite reverse;
}
/* 旋转臂：占满容器宽度，绕中心旋转，dot 挂在末端 */
.ssb-auto-dot-arm {
  position: absolute;
  left: 0;
  top: calc(50% - 2rpx);
  width: 26rpx;
  height: 4rpx;
  transform-origin: 50% 50%;
  animation: ssb-spin 1.6s linear infinite;
}
.ssb-auto-dot {
  position: absolute;
  left: 0;
  top: 0;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #63b3ed;
  box-shadow: 0 0 6rpx rgba(99, 179, 237, 0.9);
}


.seat-avatar-lady {
