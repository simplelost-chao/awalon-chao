.hint-card {
  width: 690rpx;
  background: linear-gradient(145deg, rgba(18, 14, 38, 0.98), rgba(28, 20, 52, 0.98));
  border: 1rpx solid rgba(210, 170, 90, 0.45);
  border-radius: 28rpx;
  padding: 40rpx 44rpx 36rpx;
  box-shadow: 0 12rpx 60rpx rgba(0, 0, 0, 0.7);
}
.hint-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}
.hint-icon { font-size: 38rpx; line-height: 1; }
.hint-title { font-size: 34rpx; font-weight: bold; color: var(--aw-accent); letter-spacing: 1rpx; }
.hint-text { display: block; font-size: 27rpx; color: #c0cce0; line-height: 1.7; margin-bottom: 32rpx; }
.hint-footer { display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.hint-step-tip { font-size: 22rpx; color: rgba(160, 170, 195, 0.55); }
.hint-dismiss-btn {
  background: rgba(210, 170, 90, 0.15);
  border: 1rpx solid rgba(210, 170, 90, 0.5);
  border-radius: 999rpx;
  padding: 10rpx 32rpx;
}
.hint-dismiss-text { font-size: 26rpx; color: var(--aw-accent); font-weight: 500; }
