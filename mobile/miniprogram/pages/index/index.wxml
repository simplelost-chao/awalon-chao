          <view class="config-help-role-chip {{item.isEvil ? 'config-help-role-evil' : 'config-help-role-good'}} {{item.isHostRole ? 'config-help-role-host' : ''}}" wx:for="{{roomRoleCards}}" wx:key="role" data-role="{{item.role}}" bindtap="onTapConfigRole">
