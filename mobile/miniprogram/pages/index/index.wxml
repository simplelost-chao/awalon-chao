<view class="page theme-{{skinId}}">
  <canvas id="avatarCropCanvas" type="2d" canvas-id="avatarCropCanvas" class="avatar-crop-canvas"></canvas>
  <canvas id="shareInviteCanvas" type="2d" canvas-id="shareInviteCanvas" class="share-invite-canvas"></canvas>

  <!-- ===== 审核模式：阿瓦隆发牌工具介绍 ===== -->
  <review-page wx:if="{{reviewMode}}"
    statusBarHeight="{{statusBarHeight}}"
    navBarHeight="{{navBarHeight}}"
    navTotalHeight="{{navTotalHeight}}"
    bind:exitreview="onExitReviewMode">
  </review-page>
  <!-- ===== 审核模式结束 ===== -->

  <image class="bg" wx:if="{{!reviewMode}}" src="{{room && !atHome ? skinInGameBg : skinHomeBg}}" mode="aspectFill" />
  <view class="mask" wx:if="{{!reviewMode}}"></view>

  <!-- 首页 nav -->
  <view class="custom-nav" wx:if="{{!reviewMode && (!room || atHome)}}" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="custom-nav-inner">
      <text class="custom-nav-title">Avalon</text>
    </view>
  </view>
  <!-- 游戏内 nav -->
  <nav-header wx:elif="{{!reviewMode}}"
    title="{{room && room.code ? room.code + ' 号房' : 'Avalon'}}"
    statusBarHeight="{{statusBarHeight}}"
    navBarHeight="{{navBarHeight}}"
    showBack="{{true}}"
    bind:back="onBackHome">
  </nav-header>

  <view wx:if="{{!reviewMode}}" class="content {{room && !atHome ? 'content-game' : 'content-home'}}" style="padding-top: {{navTotalHeight + 20}}px;">
    <panel-frame wx:if="{{!room || atHome}}" extraClass="panel-home">
      <!-- 未登录时显示轻提示条，不强制弹窗 -->
      <view class="guest-login-bar" wx:if="{{!loggedIn}}" bindtap="onWxLogin">
        <text class="guest-login-text">登录后可创建房间、查看历史战绩</text>
        <text class="guest-login-btn">登录</text>
      </view>

      <!-- 已登录显示用户信息 -->
      <view class="pf user-title-wrap" wx:if="{{loggedIn}}">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
        <view class="profile-head">
          <view class="profile-avatar-wrap" bindtap="onChangeAvatar">
            <image class="profile-avatar-img" wx:if="{{avatarImage}}" src="{{avatarImage}}" mode="aspectFill" />
            <view class="profile-avatar-fallback" wx:else>{{avatarText}}</view>
            <view class="profile-avatar-edit">
              <text class="profile-avatar-edit-icon">✎</text>
            </view>
          </view>
          <view class="user-title-touch" bindtap="onChangeNickname">
            <text class="user-title">你好：{{nickname || '未设置昵称'}}</text>
            <text class="profile-tip">点击头像或用户名即可修改</text>
          </view>
          <view class="logout-btn" bindtap="onLogout">登出</view>
        </view>
      </view>
      <!-- 在房间时：重新进入 / 退出 -->
      <view class="home-cta-wrap" wx:if="{{atHome && room}}">
        <view class="btn-frame">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
          <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
          <text class="btn-diamond btn-diamond-l">◆</text>
          <text class="btn-diamond btn-diamond-r">◆</text>
          <view class="home-btn-create" bindtap="onResumeRoom">重新进入：{{room.code}}</view>
        </view>
        <view class="btn-frame btn-frame-ghost">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="home-btn-join" bindtap="onLeaveRoomFromList">退出房间</view>
        </view>
      </view>

      <!-- 配置区域（无房间时才显示） -->
      <block wx:if="{{atHome && !room}}">
      <view class="panel-divider" wx:if="{{loggedIn}}"></view>
      <!-- 人数选择 -->
      <view class="count-options-row">
        <view
          class="cf cf-sm {{maxPlayersIndex===index ? 'cf-bright' : 'cf-subtle'}}"
          wx:for="{{maxPlayersOptions}}"
          wx:key="*this"
          data-idx="{{index}}"
          bindtap="onSelectMaxPlayers"
        >
          <view class="count-option cf-in-sm {{maxPlayersIndex===index ? 'count-option-on' : ''}}">{{item}}</view>
        </view>
      </view>

      <!-- 板子预设 -->
      <view class="preset-row" wx:if="{{rolePresets.length > 1}}">
        <view
          class="cf cf-sm preset-opt-wrap {{selectedPresetIndex===index ? 'cf-bright' : 'cf-subtle'}}"
          wx:for="{{rolePresets}}" wx:key="name"
          data-idx="{{index}}" bindtap="onSelectPreset">
          <view class="preset-opt cf-in-sm {{selectedPresetIndex===index ? 'preset-opt-on' : ''}}">{{item.name}}</view>
        </view>
      </view>

      <!-- 阵容配置 -->
      <view class="cfg-section-hdr">
        <view class="cfg-section-line"></view>
        <text class="cfg-section-deco">◆</text>
        <text class="cfg-section-title">阵容配置（{{maxPlayersOptions[maxPlayersIndex]}}）</text>
        <text class="cfg-section-deco">◆</text>
        <view class="cfg-section-line"></view>
      </view>

      <!-- 阵营区域 -->
      <view class="faction-area">

      <!-- 正义阵营 -->
      <view class="faction-frame faction-frame-good">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
      <view class="faction-group faction-group-good">
        <view class="faction-hdr faction-hdr-good">
          <image class="faction-hdr-icon-img" src="https://www.awalon.top/mp-assets/icons/faction-good.svg" mode="aspectFit" />
          <text class="faction-hdr-title">正义阵营</text>
          <text class="faction-hdr-count {{goodChipCount===neededGood ? 'faction-hdr-count-ok' : ''}}">{{goodChipCount}}/{{neededGood}}</text>
        </view>
        <view class="faction-chips-row">
          <block wx:for="{{currentRoleChips}}" wx:key="role">
            <view wx:if="{{!item.isEvil}}" class="role-chip-sm role-chip-sm-good {{hostRole===item.role ? 'role-chip-sm-selected' : ''}}"
              data-role="{{item.role}}" bindtap="onPickRoleChip">
              <image class="role-chip-sm-img" src="{{item.image}}" mode="aspectFill" />
              <text class="role-chip-tip" wx:if="{{item.roleBadgeText}}">{{item.roleBadgeText}}</text>
              <text class="role-chip-sm-name">{{item.role}}</text>
              <text class="role-chip-sm-cnt" wx:if="{{item.count > 1}}">×{{item.count}}</text>
            </view>
          </block>
        </view>
      </view>
      </view><!-- end faction-frame good -->

      <!-- 邪恶阵营 -->
      <view class="faction-frame faction-frame-evil">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
      <view class="faction-group faction-group-evil">
        <view class="faction-hdr faction-hdr-evil">
          <image class="faction-hdr-icon-img" src="https://www.awalon.top/mp-assets/icons/faction-evil.svg" mode="aspectFit" />
          <text class="faction-hdr-title">邪恶阵营</text>
          <text class="faction-hdr-count {{evilChipCount===neededEvil ? 'faction-hdr-count-ok' : ''}}">{{evilChipCount}}/{{neededEvil}}</text>
        </view>
        <view class="faction-chips-row">
          <block wx:for="{{currentRoleChips}}" wx:key="role">
            <view wx:if="{{item.isEvil}}" class="role-chip-sm role-chip-sm-evil {{hostRole===item.role ? 'role-chip-sm-selected' : ''}}"
              data-role="{{item.role}}" bindtap="onPickRoleChip">
              <image class="role-chip-sm-img" src="{{item.image}}" mode="aspectFill" />
              <text class="role-chip-tip" wx:if="{{item.roleBadgeText}}">{{item.roleBadgeText}}</text>
              <text class="role-chip-sm-name">{{item.role}}</text>
              <text class="role-chip-sm-cnt" wx:if="{{item.count > 1}}">×{{item.count}}</text>
            </view>
          </block>
        </view>
      </view>
      </view><!-- end faction-frame evil -->

      </view><!-- end faction-area -->

      <!-- 游戏规则 -->
      <view class="cfg-section-hdr">
        <view class="cfg-section-line"></view>
        <text class="cfg-section-deco">◆</text>
        <text class="cfg-section-title">游戏规则</text>
        <text class="cfg-section-deco">◆</text>
        <view class="cfg-section-line"></view>
      </view>

      <view class="rules-list">
        <!-- 湖中仙女 -->
        <view class="rule-row">
          <view class="rule-row-left">
            <image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-lady.svg" mode="aspectFit" />
            <text class="rule-name">湖中仙女</text>
          </view>
          <view class="rule-opts">
            <view class="rule-opt {{!ladyOfLakeEnabled ? 'rule-opt-on' : ''}}"
              data-enabled="0" bindtap="onToggleLadyDirect">关闭</view>
            <view class="rule-opt {{ladyOfLakeEnabled ? 'rule-opt-on' : ''}}"
              data-enabled="1" bindtap="onToggleLadyDirect">开启</view>
          </view>
        </view>

        <!-- 强制失败 -->
        <view class="rule-row">
          <view class="rule-row-left">
            <image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-force.svg" mode="aspectFit" />
            <text class="rule-name">强制失败</text>
          </view>
          <view class="rule-opts">
            <view class="rule-opt {{forceRoundMode==='fixed5' ? 'rule-opt-on' : ''}}"
              data-value="fixed5" bindtap="onPickForceRoundDirect">第5次</view>
            <view class="rule-opt {{forceRoundMode==='evil_plus_one' ? 'rule-opt-on' : ''}}"
              data-value="evil_plus_one" bindtap="onPickForceRoundDirect">邪恶+1</view>
          </view>
        </view>

        <!-- 邪恶互认 -->
        <view class="rule-row">
          <view class="rule-row-left">
            <image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-evil.svg" mode="aspectFit" />
            <text class="rule-name">邪恶互认</text>
          </view>
          <view class="rule-opts">
            <view class="rule-opt {{!evilRoleVisibleEnabled ? 'rule-opt-on' : ''}}"
              data-value="false" bindtap="onPickEvilVisibleDirect">隐藏</view>
            <view class="rule-opt {{evilRoleVisibleEnabled ? 'rule-opt-on' : ''}}"
              data-value="true" bindtap="onPickEvilVisibleDirect">显示</view>
          </view>
        </view>

        <!-- 发言时长 -->
        <view class="rule-row">
          <view class="rule-row-left">
            <image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-timer.svg" mode="aspectFit" />
            <text class="rule-name">发言时长</text>
          </view>
          <view class="rule-opts">
            <view class="rule-opt {{speakingSeconds===60 ? 'rule-opt-on' : ''}}"
              data-value="60" bindtap="onPickSpeakingSecondsDirect">60s</view>
            <view class="rule-opt {{speakingSeconds===90 ? 'rule-opt-on' : ''}}"
              data-value="90" bindtap="onPickSpeakingSecondsDirect">90s</view>
            <view class="rule-opt {{speakingSeconds===120 ? 'rule-opt-on' : ''}}"
              data-value="120" bindtap="onPickSpeakingSecondsDirect">120s</view>
            <view class="rule-opt {{speakingSeconds===180 ? 'rule-opt-on' : ''}}"
              data-value="180" bindtap="onPickSpeakingSecondsDirect">180s</view>
          </view>
        </view>

        <!-- AI语音 -->
        <view class="rule-row">
          <view class="rule-row-left">
            <image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-voice.svg" mode="aspectFit" />
            <text class="rule-name">AI语音</text>
          </view>
          <view class="rule-opts">
            <view class="rule-opt {{!aiVoiceEnabled ? 'rule-opt-on' : ''}}"
              data-enabled="0" bindtap="onToggleAiVoiceDirect">关闭</view>
            <view class="rule-opt {{aiVoiceEnabled ? 'rule-opt-on' : ''}}"
              data-enabled="1" bindtap="onToggleAiVoiceDirect">开启</view>
          </view>
        </view>
      </view>

      <view class="config-hint-wrap" wx:if="{{goodChipCount!==neededGood || evilChipCount!==neededEvil}}">
        <text class="config-hint-text config-hint-err">⚠ 配置有误，{{goodChipCount}} 正义 / {{evilChipCount}} 邪恶</text>
      </view>

      <view class="home-cta-wrap">
        <view class="btn-frame">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
          <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
          <text class="btn-diamond btn-diamond-l">◆</text>
          <text class="btn-diamond btn-diamond-r">◆</text>
          <view class="home-btn-create" bindtap="onCreateRoom">创建房间</view>
        </view>
        <view class="btn-frame btn-frame-ghost">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="home-btn-join" bindtap="onJoinRoomPrompt">加入房间</view>
        </view>
      </view>

      </block><!-- end: atHome && !room -->

    </panel-frame>


    <!-- 当前活跃房间列表：首页始终显示 -->
    <panel-frame wx:if="{{atHome}}" extraClass="rl-panel">

      <!-- 装饰标题行 -->
      <view class="rl-title-row">
        <view class="rl-title-line"></view>
        <text class="rl-title-deco">◆</text>
        <text class="rl-title-text">当前房间</text>
        <text class="rl-title-deco">◆</text>
        <view class="rl-title-line"></view>
        <view class="speak-inline-btn {{activeRoomsLoading ? 'speak-inline-disabled' : ''}}" bindtap="onRefreshRooms">
          <text class="rl-refresh-icon {{activeRoomsLoading ? 'rl-spinning' : ''}}">↻</text>
        </view>
      </view>

      <view class="rl-cards" wx:if="{{activeRooms.length}}">
        <room-card wx:for="{{activeRooms}}" wx:key="code"
          roomData="{{item}}"
          isCurrentRoom="{{item.isCurrentRoom}}"
          bind:resume="onResumeRoom"
          bind:join="onJoinPublicRoom">
        </room-card>
      </view>

      <view wx:else class="rl-empty">
        <image class="rl-empty-icon-img" src="https://www.awalon.top/mp-assets/icons/room-empty.svg" mode="aspectFit" />
        <text class="rl-empty-title">暂无房间</text>
        <text class="rl-empty-sub">快去创建一局吧</text>
      </view>
    </panel-frame>

    <panel-frame wx:if="{{room && !atHome}}" extraClass="room-panel" extraStyle="{{phase==='speaking' && !isSpectator ? 'padding-bottom:420rpx;' : ((['team','voting','mission'].indexOf(phase)>=0 && !isSpectator) ? 'padding-bottom:240rpx;' : '')}}">

      <view class="control-wrap">
        <view class="btn-row">

          <!-- 房间详情按钮 -->
          <view class="pf top-btn-frame" bindtap="togglePlayerList">
            <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
            <view class="fb fb-left"></view><view class="fb fb-right"></view>
            <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
            <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
            <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
            <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
            <view class="top-btn-inner">
              <text class="top-btn-icon">◈</text>
              <text class="top-btn-label">{{showPlayerList ? ('收起 · ' + room.code) : ('房间 · ' + room.code)}}</text>
              <text class="top-btn-arrow">{{showPlayerList ? '▲' : '▼'}}</text>
            </view>
          </view>

          <!-- 查看身份/视野按钮 -->
          <view class="pf top-btn-frame {{!canViewIdentity ? 'top-btn-disabled' : ''}} {{identityMode ? 'top-btn-open' : ''}}" bindtap="toggleRolePanel">
            <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
            <view class="fb fb-left"></view><view class="fb fb-right"></view>
            <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
            <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
            <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
            <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
            <view class="top-btn-inner">
              <text class="top-btn-icon">{{canViewIdentity ? (identityRevealSeen ? '◈' : '◉') : '◌'}}</text>
              <text class="top-btn-label">{{canViewIdentity ? (identityMode ? '收起' : (identityRevealSeen ? '视野' : '查看身份')) : '无身份'}}</text>
            </view>
          </view>

        </view>
      </view>

      <view class="identity-modal-mask" wx:if="{{showRolePanel}}" bindtap="onCloseRolePanel">
        <view class="identity-modal-sheet" catchtap="onNoop">
          <view class="identity-modal-head">
            <view class="identity-modal-title-wrap">
              <text class="identity-modal-title">身份信息</text>
              <text class="identity-modal-sub">圆桌身份显示</text>
            </view>
            <text class="identity-modal-close" bindtap="onCloseRolePanel">✕</text>
          </view>
          <scroll-view class="identity-modal-body" scroll-y>
            <identity-panel
              roleInfo="{{roleInfo}}"
              roleInfoLoading="{{roleInfoLoading}}"
              roleVisibleSeats="{{roleVisibleSeats}}"
              isAssassin="{{isAssassin}}"
              assassinSeatNo="{{assassinSeatNo}}"
              phase="{{phase}}"
              bind:startassassination="onStartAssassination">
            </identity-panel>
          </scroll-view>
        </view>
      </view>

      <room-players-panel wx:if="{{showPlayerList}}"
        roomRoleCards="{{roomRoleCards}}"
        playerCards="{{playerCards}}"
        roomConfigLines="{{roomConfigLines}}"
        isHost="{{isHost}}"
        isSuperPlayer="{{isSuperPlayer}}"
        isAssassin="{{isAssassin}}"
        myAutoplay="{{myAutoplay}}"
        autoplayAssassinTarget="{{autoplayAssassinTarget}}"
        roomStarted="{{room.started}}"
        phase="{{phase}}"
        cheatRevealPlayerId="{{cheatRevealPlayerId}}"
        cheatRoles="{{cheatRoles}}"
        bind:startgame="onStartGame"
        bind:redeal="onRedealIdentities"
        bind:settings="onOpenRoomSettings"
        bind:toggleautoplay="onAutoplayToggle"
        bind:taprolecard="onTapRoomRoleCard"
        bind:addfriend="onAddFriend"
        bind:kickplayer="onKickFromList"
        bind:playerpressstart="onPlayerNamePressStart"
        bind:playerpressend="onPlayerNamePressEnd">
      </room-players-panel>

      <round-table
        tableUrl="{{skinTableUrl}}"
        seats="{{roundSeats}}"
        identityMode="{{identityMode}}"
        seatNotes="{{seatNotes}}"
        emojiBubbles="{{emojiBubbles}}"
        showCenterResult="{{showCenterResult}}"
        centerResultText="{{centerResultText}}"
        centerResultSub="{{centerResultSub}}"
        endMedals="{{endMedals}}"
        isHost="{{isHost}}"
        roomStarted="{{room.started}}"
        isLeader="{{isLeader}}"
        isAssassin="{{isAssassin}}"
        phase="{{phase}}"
        leaderActionText="{{leaderActionText}}"
        leaderActionClass="{{leaderActionClass}}"
        leaderActionDisabled="{{leaderActionDisabled}}"
        selectedAssassinate="{{selectedAssassinate}}"
        bind:chooseseat="onChooseSeat"
        bind:seattouchstart="onSeatTouchStart"
        bind:seattouchend="onSeatTouchEnd"
        bind:seattouchcancel="onSeatTouchCancel"
        bind:tapmedal="onTapMedal"
        bind:leaderaction="onLeaderTeamAction"
        bind:startassassination="onStartAssassination"
        bind:confirmassassinate="onConfirmAssassinate">
      </round-table>

      <game-config-panel wx:if="{{!room.started || phase==='end'}}"
        title="当前配置"
        role-cards="{{roomRoleCards}}"
        config-lines="{{roomConfigLines}}"
        is-host="{{isHost}}"
        started="{{room.started}}"
        phase="{{phase}}"
        my-autoplay="{{myAutoplay}}"
        bind:taprole="onTapConfigRole"
        bind:taphelp="onOpenConfigHelp"
        bind:startgame="onStartGame"
        bind:redeal="onRedealIdentities"
        bind:settings="onOpenRoomSettings"
        bind:toggleautoplay="onAutoplayToggle"
      />

      <view class="control-wrap" wx:if="{{room.game}}">
        <mission-pills pills="{{missionPills}}" />
      </view>

      <view class="control-wrap" wx:if="{{room.game && phase==='lady' && ladyHistory.length}}">
        <view class="phase-panel pf">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
          <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
          <view class="phase-panel-head mt-title-row">
            <view class="mt-title-line"></view>
            <text class="mt-title-deco">◆</text>
            <text class="mt-title">验人记录</text>
            <text class="mt-title-deco">◆</text>
            <view class="mt-title-line"></view>
          </view>
          <view class="phase-panel-body">
            <view class="lady-history-list">
              <view class="lady-history-item" wx:for="{{ladyHistory}}" wx:key="key">
                <text class="lady-history-round">第{{item.round}}轮</text>
                <text class="lady-history-text">{{item.holderName}} 验了 {{item.targetName}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="control-wrap" wx:if="{{isCurrentForcedAttempt && !showCenterResult}}">
        <view class="phase-panel phase-force-panel pf">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
          <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
          <view class="phase-panel-head mt-title-row">
            <view class="mt-title-line"></view>
            <text class="mt-title-deco">◆</text>
            <text class="mt-title">强制组队轮</text>
            <text class="mt-title-deco">◆</text>
            <view class="mt-title-line"></view>
          </view>
          <view class="phase-force-body">
            <text class="phase-force-main">本轮继续失败，正义直接判负</text>
            <text class="phase-force-sub">请谨慎选择队伍，别让本轮发车失败</text>
          </view>
        </view>
      </view>

      <view class="control-wrap" wx:if="{{missionRows.length}}">
        <mission-table rows="{{missionRows}}" maxPlayers="{{room.players.length}}" />
      </view>

      <view class="control-wrap pf spk-rec-panel" wx:if="{{room.game}}">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="fc-inner fc-tl"></view><view class="fc-inner fc-tr"></view>
        <view class="fc-inner fc-bl"></view><view class="fc-inner fc-br"></view>
        <!-- 标题行 + 翻页 -->
        <view class="spk-rec-title-row">
          <view class="mt-title-line"></view>
          <text class="mt-title-deco">◆</text>
          <text class="mt-title">发言记录</text>
          <view class="spk-rec-pager">
            <view class="spk-rec-btn {{!speakKeys.length || speakRoundView===speakKeys[0] ? 'spk-rec-disabled' : ''}}" bindtap="prevSpeakRound">‹</view>
            <text class="spk-rec-round" wx:if="{{speakRoundView}}">第 {{speakRoundView}} 轮</text>
            <view class="spk-rec-btn {{!speakKeys.length || speakRoundView===speakKeys[speakKeys.length-1] ? 'spk-rec-disabled' : ''}}" bindtap="nextSpeakRound">›</view>
          </view>
          <text class="mt-title-deco">◆</text>
          <view class="mt-title-line"></view>
        </view>
        <speak-list messages="{{speakMessages}}" wx:if="{{speakRoundView}}" />
      </view>

      <view class="bottom-spacer" wx:if="{{phase==='speaking' || phase==='lady' || (phase==='voting' && !myVoted) || (phase==='mission' && inTeam && !myMissionDone)}}"></view>

    </panel-frame>

  </view>

  <action-panel
    wx:if="{{room && !atHome && !isSpectator && (phase==='voting' && !myVoted)}}"
    mode="vote"
    team="{{currentVoteTeam}}"
    bind:approve="onVoteApprove"
    bind:reject="onVoteReject">
  </action-panel>

  <action-panel
    wx:if="{{room && !atHome && !isSpectator && phase==='mission' && inTeam && !myMissionDone}}"
    mode="mission"
    team="{{currentVoteTeam}}"
    bind:success="onMissionSuccess"
    bind:fail="onMissionFail">
  </action-panel>

  <action-panel
    wx:if="{{room && !atHome && !isSpectator && phase==='lady' && phasePrompt}}"
    mode="lady"
    prompt="{{phasePrompt}}"
    bind:confirmlady="onConfirmLadyOfLake">
  </action-panel>

  <speak-panel
    wx:if="{{room && !atHome && !isSpectator && phase==='speaking'}}"
    isMyTurn="{{isMyTurn}}"
    isHost="{{isHost}}"
    isLeader="{{isLeader}}"
    speakingSeat="{{speakingSeat}}"
    speakingAvatarImage="{{speakingAvatarImage}}"
    speakingAvatarText="{{speakingAvatarText}}"
    speakingProgress="{{speakingProgress}}"
    speakingUrgent="{{speakingUrgent}}"
    speakingTimerText="{{speakingTimerText}}"
    speakText="{{speakText}}"
    speakTextLen="{{speakTextLen}}"
    bind:input="onSpeakInput"
    bind:send="onSendSpeak"
    bind:end="onEndSpeak"
    bind:skipspeak="onHostSkipSpeak"
    bind:directvote="onHostDirectVote">
  </speak-panel>

  <tab-bar wx:if="{{atHome || !room}}" active="home" />

</view>

<!-- 快捷表情栏（固定底部） -->
<emoji-bar
  wx:if="{{room && room.started && phase !== 'end' && !isSpectator && !atHome}}"
  bind:send="onSendEmoji"
/>

<!-- 断线重连横幅 -->

<!-- 座位标注弹窗 -->
<view class="note-modal-mask" wx:if="{{noteModal.show}}" bindtap="onCloseNoteModal">
  <view class="note-sheet" catchtap="noteModalNoop">
    <view class="note-sheet-accent"></view>
    <view class="note-drag-handle"></view>

    <!-- 玩家信息 -->
    <view class="note-player-row">
      <view class="note-avatar-ring" style="{{noteModal.ringStyle}}">
        <image wx:if="{{noteModal.avatarImage}}" class="note-avatar-img" src="{{noteModal.avatarImage}}" mode="aspectFill" />
        <text wx:else class="note-avatar-seat">{{noteModal.avatarText}}</text>
      </view>
      <view class="note-player-info">
        <text class="note-player-name">{{noteModal.name}}</text>
        <text class="note-player-sub">{{noteModal.seat}} 号位 · 长按修改标注</text>
        <view class="note-current-label" wx:if="{{noteModal.label}}" style="background:{{noteModal.labelBg}};border-color:{{noteModal.labelBorder}};">
          <view class="note-current-dot" style="background:{{noteModal.labelColor}};box-shadow:0 0 6rpx {{noteModal.labelColor}};"></view>
          <text class="note-current-text" style="color:{{noteModal.labelColor}};">{{noteModal.label}}</text>
        </view>
      </view>
    </view>

    <view class="note-divider"></view>

    <!-- 正义组 -->
    <view class="note-section">
      <text class="note-section-title">倾向正义</text>
      <view class="note-chip-grid">
        <view
          wx:for="{{noteChipsGood}}"
          wx:key="label"
          class="note-chip {{item.on ? 'note-chip-on' : ''}}"
          style="{{item.on ? 'background:' + item.bg + ';border-color:' + item.border + ';' : ''}}"
          data-label="{{item.label}}"
          bindtap="onPickNoteLabel"
        >
          <text class="note-chip-icon">{{item.icon}}</text>
          <text class="note-chip-text" style="{{item.on ? 'color:' + item.color + ';font-weight:600;' : ''}}">{{item.label}}</text>
          <text class="note-chip-check" wx:if="{{item.on}}">✓</text>
        </view>
      </view>
    </view>

    <!-- 邪恶组 -->
    <view class="note-section">
      <text class="note-section-title">倾向邪恶</text>
      <view class="note-chip-grid">
        <view
          wx:for="{{noteChipsEvil}}"
          wx:key="label"
          class="note-chip {{item.on ? 'note-chip-on' : ''}}"
          style="{{item.on ? 'background:' + item.bg + ';border-color:' + item.border + ';' : ''}}"
          data-label="{{item.label}}"
          bindtap="onPickNoteLabel"
        >
          <text class="note-chip-icon">{{item.icon}}</text>
          <text class="note-chip-text" style="{{item.on ? 'color:' + item.color + ';font-weight:600;' : ''}}">{{item.label}}</text>
          <text class="note-chip-check" wx:if="{{item.on}}">✓</text>
        </view>
      </view>
    </view>

    <!-- 清除 -->
    <view class="note-clear-btn" data-label="" bindtap="onPickNoteLabel">✕  清除标注</view>
  </view>
</view>

<view class="mp-overlay" wx:if="{{showMissionProgress}}" bindtap="onCloseMissionProgress">
  <view class="mp-overlay-card">
    <text class="mp-round-label">第 {{missionProgressRound}} 轮任务</text>
    <text class="mp-heading">出  征  中</text>
    <text class="mp-hint-text">队员正在秘密提交任务结果</text>
    <view class="mp-avatars">
      <view class="mp-avatar-wrap {{item.voted ? 'mp-av-voted' : 'mp-av-pending'}}" wx:for="{{missionProgressTeam}}" wx:key="id">
        <image class="mp-av-img" wx:if="{{item.avatarImage}}" src="{{item.avatarImage}}" mode="aspectFill" />
        <text class="mp-av-emoji" wx:else>{{item.avatarText}}</text>
        <view class="mp-av-check" wx:if="{{item.voted}}">✓</view>
        <text class="mp-av-name"><text class="mp-av-seat">{{item.seat}}·</text>{{item.nickname}}</text>
      </view>
    </view>
    <view class="mp-pips">
      <view class="mp-pip {{idx < missionVotedCount ? 'mp-pip-done' : 'mp-pip-wait'}}" wx:for="{{missionProgressTeam}}" wx:for-index="idx" wx:key="idx"></view>
