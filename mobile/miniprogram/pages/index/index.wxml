<view class="page theme-{{skinId}}">
  <canvas id="avatarCropCanvas" type="2d" canvas-id="avatarCropCanvas" class="avatar-crop-canvas"></canvas>
  <canvas id="shareInviteCanvas" type="2d" canvas-id="shareInviteCanvas" class="share-invite-canvas"></canvas>

  <!-- ===== 审核模式：阿瓦隆发牌工具介绍 ===== -->
  <review-page wx:if="{{reviewMode}}"
    statusBarHeight="{{statusBarHeight}}"
    navBarHeight="{{navBarHeight}}"
    navTotalHeight="{{navTotalHeight}}"
    bind:exitreview="onExitReviewMode">
  </review-page>
  <!-- ===== 审核模式结束 ===== -->

  <image class="bg" wx:if="{{!reviewMode}}" src="{{room && !atHome ? skinInGameBg : skinHomeBg}}" mode="aspectFill" />
  <view class="mask" wx:if="{{!reviewMode}}"></view>

  <!-- 首页 nav -->
  <view class="custom-nav" wx:if="{{!reviewMode && (!room || atHome)}}" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="custom-nav-inner">
      <text class="custom-nav-title">Avalon</text>
    </view>
  </view>
  <!-- 游戏内 nav -->
  <nav-header wx:elif="{{!reviewMode}}"
    title="{{room && room.code ? room.code + ' 号房' : 'Avalon'}}"
    statusBarHeight="{{statusBarHeight}}"
    navBarHeight="{{navBarHeight}}"
    showBack="{{true}}"
    bind:back="onBackHome">
  </nav-header>

  <view wx:if="{{!reviewMode}}" class="content {{room && !atHome ? 'content-game' : 'content-home'}}" style="padding-top: {{navTotalHeight + 20}}px;">
    <view class="panel" wx:if="{{!room || atHome}}">
      <!-- 未登录时显示轻提示条，不强制弹窗 -->
      <view class="guest-login-bar" wx:if="{{!loggedIn}}" bindtap="onWxLogin">
        <text class="guest-login-text">登录后可创建房间、查看历史战绩</text>
        <text class="guest-login-btn">登录</text>
      </view>

      <!-- 已登录显示用户信息 -->
      <view class="user-title-wrap" wx:if="{{loggedIn}}">
        <view class="profile-head">
          <view class="profile-avatar-wrap" bindtap="onChangeAvatar">
            <image class="profile-avatar-img" wx:if="{{avatarImage}}" src="{{avatarImage}}" mode="aspectFill" />
            <view class="profile-avatar-fallback" wx:else>{{avatarText}}</view>
            <view class="profile-avatar-edit">
              <text class="profile-avatar-edit-icon">✎</text>
            </view>
          </view>
          <view class="user-title-touch" bindtap="onChangeNickname">
            <text class="user-title">你好：{{nickname || '未设置昵称'}}</text>
            <text class="profile-tip">点击头像或用户名即可修改</text>
          </view>
          <view class="logout-btn" bindtap="onLogout">登出</view>
        </view>
      </view>
      <view class="home-action-grid" wx:if="{{loggedIn}}">
        <button class="btn ghost home-action-btn" bindtap="openHistory">
          <image class="home-action-icon" src="https://www.awalon.top/mp-assets/ui-icons/history_scroll.png" mode="aspectFill" />
          <text class="home-action-text">历史对战</text>
        </button>
        <button class="btn ghost home-action-btn" bindtap="openRoleStats">
          <image class="home-action-icon" src="https://www.awalon.top/mp-assets/ui-icons/stats_bars.png" mode="aspectFill" />
          <text class="home-action-text">角色统计</text>
        </button>
        <button class="btn ghost home-action-btn" bindtap="openRules">
          <text class="home-action-emoji">📖</text>
          <text class="home-action-text">游戏规则</text>
        </button>
      </view>
    </view>


    <view class="panel" wx:if="{{atHome && !room}}">
      <view class="count-options-row">
        <view
          class="count-option {{maxPlayersIndex===index ? 'count-option-on' : ''}}"
          wx:for="{{maxPlayersOptions}}"
          wx:key="*this"
          data-idx="{{index}}"
          bindtap="onSelectMaxPlayers"
        >
          {{item}}
        </view>
      </view>
      <view class="current-role-chips">
        <view
          class="role-chip {{item.isEvil ? 'role-chip-evil' : 'role-chip-good'}} {{item.role === hostRole ? 'role-chip-selected' : ''}}"
          wx:for="{{currentRoleChips}}"
          wx:key="role"
          data-role="{{item.role}}"
          bindtap="onPickRoleChip"
        >
          <image class="role-chip-img" src="{{item.image}}" mode="aspectFill" />
          <view class="role-chip-label">
            <text class="role-chip-name">{{item.role}}</text>
            <text class="role-chip-count" wx:if="{{item.count > 1}}">×{{item.count}}</text>
          </view>
        </view>
      </view>

      <view class="advanced-toggle" bindtap="onToggleAdvancedSettings">
        <text class="advanced-toggle-title">高级设置</text>
        <text class="advanced-toggle-value">{{showAdvancedSettings ? '收起' : '展开'}}</text>
      </view>
      <advanced-settings wx:if="{{showAdvancedSettings}}"
        selectedRoles="{{selectedRoles}}"
        allRoleOptions="{{allRoleOptions}}"
        ladyOfLakeEnabled="{{ladyOfLakeEnabled}}"
        forceRoundMode="{{forceRoundMode}}"
        forceRoundOptions="{{forceRoundOptions}}"
        evilRoleVisibleEnabled="{{evilRoleVisibleEnabled}}"
        oberonVisibleEnabled="{{oberonVisibleEnabled}}"
        aiVoiceEnabled="{{aiVoiceEnabled}}"
        speakingSeconds="{{speakingSeconds}}"
        speakingSecondsOptions="{{speakingSecondsOptions}}"
        maxPlayersIndex="{{maxPlayersIndex}}"
        advancedRoleSummary="{{advancedRoleSummary}}"
        advancedQuotaText="{{advancedQuotaText}}"
        bind:addrole="onAddAdvancedRole"
        bind:removerole="onRemoveAdvancedRole"
        bind:resetroles="onResetAdvancedRoles"
        bind:togglelady="onToggleLadyMode"
        bind:pickforceround="onPickForceRoundMode"
        bind:pickevilvision="onPickEvilRoleVisible"
        bind:pickoberonvisible="onPickOberonVisible"
        bind:pickseconds="onPickSpeakingSeconds"
        bind:toggleaivoice="onToggleAiVoice">
      </advanced-settings>

      <view class="btn-row" wx:if="{{!room}}">
        <button class="btn primary half" bindtap="onCreateRoom">创建房间</button>
        <button class="btn ghost half" bindtap="onJoinRoomPrompt">加入房间</button>
      </view>

    </view>


    <view class="panel" wx:if="{{atHome && room}}">
      <view class="btn-row">
        <button class="btn primary half" bindtap="onResumeRoom">重新进入：{{room.code}}</button>
        <button class="btn ghost half" bindtap="onLeaveRoomFromList">退出房间</button>
      </view>
    </view>

    <!-- 当前活跃房间列表：首页始终显示 -->
    <view class="rl-wrap" wx:if="{{atHome}}">
      <view class="section-title-row rl-header">
        <text class="section-title section-title-small">当前房间</text>
        <view class="speak-inline-btn {{activeRoomsLoading ? 'speak-inline-disabled' : ''}}" bindtap="onRefreshRooms">
          <text class="rl-refresh-icon {{activeRoomsLoading ? 'rl-spinning' : ''}}">↻</text>
        </view>
      </view>

      <view class="rl-cards" wx:if="{{activeRooms.length}}">
        <room-card wx:for="{{activeRooms}}" wx:key="code"
          roomData="{{item}}"
          isCurrentRoom="{{room && item.code === room.code}}"
          bind:resume="onResumeRoom"
          bind:join="onJoinPublicRoom">
        </room-card>
      </view>

      <view wx:else class="rl-empty">
        <text class="rl-empty-title">暂无房间</text>
        <text class="rl-empty-sub">快去创建一局吧</text>
      </view>
    </view>

    <view class="panel room-panel" wx:if="{{room && !atHome}}" style="{{phase==='speaking' && !isSpectator ? 'padding-bottom:420rpx;' : ((['team','voting','mission'].indexOf(phase)>=0 && !isSpectator) ? 'padding-bottom:240rpx;' : '')}}">

      <view class="control-wrap">
        <view class="btn-row">
          <button class="btn ghost half room-toggle-btn" bindtap="togglePlayerList">
            <text>{{showPlayerList ? ('收起 · ' + room.code) : ('房间 ' + room.code)}}</text>
            <text class="toggle-arrow">{{showPlayerList ? '▲' : '▼'}}</text>
          </button>
          <button class="btn ghost half role-toggle-btn {{!room.started ? 'btn-disabled' : ''}} {{identityMode ? 'role-toggle-open' : ''}}" bindtap="toggleRolePanel" disabled="{{!room.started}}">
            <text>{{identityMode ? '收起身份' : '查看身份'}}</text>
            <text class="toggle-arrow" wx:if="{{room.started}}">{{identityMode ? '▲' : '▼'}}</text>
          </button>
        </view>
      </view>

      <identity-panel wx:if="{{showRolePanel}}"
        roleInfo="{{roleInfo}}"
        roleInfoLoading="{{roleInfoLoading}}"
        roleVisibleSeats="{{roleVisibleSeats}}"
        isAssassin="{{isAssassin}}"
        assassinSeatNo="{{assassinSeatNo}}"
        phase="{{phase}}"
        bind:startassassination="onStartAssassination">
      </identity-panel>

      <room-players-panel wx:if="{{showPlayerList}}"
        roomRoleCards="{{roomRoleCards}}"
        playerCards="{{playerCards}}"
        roomConfigLines="{{roomConfigLines}}"
        isHost="{{isHost}}"
        isAssassin="{{isAssassin}}"
        myAutoplay="{{myAutoplay}}"
        autoplayAssassinTarget="{{autoplayAssassinTarget}}"
        roomStarted="{{room.started}}"
        phase="{{phase}}"
        cheatRevealPlayerId="{{cheatRevealPlayerId}}"
        cheatRoles="{{cheatRoles}}"
        bind:redeal="onRedealIdentities"
        bind:toggleautoplay="onAutoplayToggle"
        bind:taprolecard="onTapRoomRoleCard"
        bind:kickplayer="onKickFromList"
        bind:playerpressstart="onPlayerNamePressStart"
        bind:playerpressend="onPlayerNamePressEnd">
      </room-players-panel>

      <round-table
        seats="{{roundSeats}}"
        identityMode="{{identityMode}}"
        seatNotes="{{seatNotes}}"
        showCenterResult="{{showCenterResult}}"
        centerResultText="{{centerResultText}}"
        centerResultSub="{{centerResultSub}}"
        endMedals="{{endMedals}}"
        isHost="{{isHost}}"
        roomStarted="{{room.started}}"
        isLeader="{{isLeader}}"
        isAssassin="{{isAssassin}}"
        phase="{{phase}}"
        leaderActionText="{{leaderActionText}}"
        leaderActionClass="{{leaderActionClass}}"
        leaderActionDisabled="{{leaderActionDisabled}}"
        selectedAssassinate="{{selectedAssassinate}}"
        bind:chooseseat="onChooseSeat"
        bind:seattouchstart="onSeatTouchStart"
        bind:seattouchend="onSeatTouchEnd"
        bind:seattouchcancel="onSeatTouchCancel"
        bind:tapmedal="onTapMedal"
        bind:redeal="onRedealIdentities"
        bind:leaderaction="onLeaderTeamAction"
        bind:startassassination="onStartAssassination"
        bind:confirmassassinate="onConfirmAssassinate"
        bind:startgame="onStartGame">
      </round-table>


      <view class="control-wrap" wx:if="{{room.game}}">
        <text class="section-title section-title-small section-chip">任务进度</text>
        <mission-pills pills="{{missionPills}}" />
      </view>

      <view class="force-round-banner force-round-banner-block" wx:if="{{isCurrentForcedAttempt && !showCenterResult}}">
        <text class="force-round-banner-main">强制组队轮</text>
        <text class="force-round-banner-sub">本次未发车则正义直接判负</text>
      </view>

      <view class="control-wrap" wx:if="{{room.game && phase==='lady'}}">
        <text class="section-title section-title-small section-chip">验人阶段</text>
        <view class="lady-current-player">
          <text class="lady-current-label">当前验人</text>
          <text class="lady-current-name">{{ladyHolderName || '未知玩家'}}</text>
        </view>
        <view class="lady-history-list" wx:if="{{ladyHistory.length}}">
          <view class="lady-history-item" wx:for="{{ladyHistory}}" wx:key="key">
            <text class="lady-history-round">第{{item.round}}轮</text>
            <text class="lady-history-text">{{item.holderName}} 验了 {{item.targetName}}</text>
          </view>
        </view>
        <view class="lady-action-hint lady-action-mine" wx:if="{{isLadyHolder}}">
          <text class="lady-action-text">点击圆桌上的目标玩家进行验人</text>
        </view>
        <view class="lady-action-hint" wx:else>
          <text class="lady-action-text">等待 {{ladyHolderName}} 选择目标…</text>
        </view>
      </view>

      <view class="control-wrap" wx:if="{{missionRows.length}}">
        <text class="section-title section-title-small section-chip">任务详情</text>
        <mission-table rows="{{missionRows}}" />
      </view>

      <view class="control-wrap" wx:if="{{room.game}}">
        <view class="speak-title-wrap">
          <text class="section-title section-title-small section-chip">发言记录</text>
          <view class="speak-inline-pager">
            <view class="speak-inline-btn {{!speakKeys.length || speakRoundView===speakKeys[0] ? 'speak-inline-disabled' : ''}}" bindtap="prevSpeakRound">‹</view>
            <text class="speak-title-round" wx:if="{{speakRoundView}}">第 {{speakRoundView}} 轮</text>
            <view class="speak-inline-btn {{!speakKeys.length || speakRoundView===speakKeys[speakKeys.length-1] ? 'speak-inline-disabled' : ''}}" bindtap="nextSpeakRound">›</view>
          </view>
        </view>
        <view wx:if="{{speakRoundView}}">
          <speak-list messages="{{speakMessages}}" />
        </view>
      </view>

      <view class="bottom-spacer" wx:if="{{phase==='speaking' || (phase==='voting' && !myVoted) || (phase==='mission' && inTeam && !myMissionDone)}}"></view>

    </view>

  </view>

  <action-panel
    wx:if="{{room && !atHome && !isSpectator && (phase==='voting' && !myVoted)}}"
    mode="vote"
    team="{{currentVoteTeam}}"
    bind:approve="onVoteApprove"
    bind:reject="onVoteReject">
  </action-panel>

  <action-panel
    wx:if="{{room && !atHome && !isSpectator && phase==='mission' && inTeam && !myMissionDone}}"
    mode="mission"
    team="{{currentVoteTeam}}"
    bind:success="onMissionSuccess"
    bind:fail="onMissionFail">
  </action-panel>

  <speak-panel
    wx:if="{{room && !atHome && !isSpectator && phase==='speaking'}}"
    isMyTurn="{{isMyTurn}}"
    isHost="{{isHost}}"
    isLeader="{{isLeader}}"
    speakingSeat="{{speakingSeat}}"
    speakingAvatarImage="{{speakingAvatarImage}}"
    speakingAvatarText="{{speakingAvatarText}}"
    speakingProgress="{{speakingProgress}}"
    speakingUrgent="{{speakingUrgent}}"
    speakingTimerText="{{speakingTimerText}}"
    speakText="{{speakText}}"
    speakTextLen="{{speakTextLen}}"
    bind:input="onSpeakInput"
    bind:send="onSendSpeak"
    bind:end="onEndSpeak"
    bind:skipspeak="onHostSkipSpeak"
    bind:directvote="onHostDirectVote">
  </speak-panel>

</view>

<!-- 断线重连横幅 -->

<!-- 座位标注弹窗 -->
<view class="note-modal-mask" wx:if="{{noteModal.show}}" bindtap="onCloseNoteModal">
  <view class="note-sheet" catchtap="noteModalNoop">
    <view class="note-sheet-accent"></view>
    <view class="note-drag-handle"></view>

    <!-- 玩家信息 -->
    <view class="note-player-row">
      <view class="note-avatar-ring" style="{{noteModal.ringStyle}}">
        <text class="note-avatar-seat">{{noteModal.seat}}</text>
      </view>
      <view class="note-player-info">
        <text class="note-player-name">{{noteModal.name}}</text>
        <text class="note-player-sub">{{noteModal.seat}} 号位 · 长按修改标注</text>
        <view class="note-current-label" wx:if="{{noteModal.label}}" style="background:{{noteModal.labelBg}};border-color:{{noteModal.labelBorder}};">
          <view class="note-current-dot" style="background:{{noteModal.labelColor}};box-shadow:0 0 6rpx {{noteModal.labelColor}};"></view>
          <text class="note-current-text" style="color:{{noteModal.labelColor}};">{{noteModal.label}}</text>
        </view>
      </view>
    </view>

    <view class="note-divider"></view>

    <!-- 正义组 -->
    <view class="note-section">
      <text class="note-section-title">倾向正义</text>
      <view class="note-chip-grid">
        <view
          wx:for="{{noteChipsGood}}"
          wx:key="label"
          class="note-chip {{item.on ? 'note-chip-on' : ''}}"
          style="{{item.on ? 'background:' + item.bg + ';border-color:' + item.border + ';' : ''}}"
          data-label="{{item.label}}"
          bindtap="onPickNoteLabel"
        >
          <text class="note-chip-icon">{{item.icon}}</text>
          <text class="note-chip-text" style="{{item.on ? 'color:' + item.color + ';font-weight:600;' : ''}}">{{item.label}}</text>
          <text class="note-chip-check" wx:if="{{item.on}}">✓</text>
        </view>
      </view>
    </view>

    <!-- 邪恶组 -->
    <view class="note-section">
      <text class="note-section-title">倾向邪恶</text>
      <view class="note-chip-grid">
        <view
          wx:for="{{noteChipsEvil}}"
          wx:key="label"
          class="note-chip {{item.on ? 'note-chip-on' : ''}}"
          style="{{item.on ? 'background:' + item.bg + ';border-color:' + item.border + ';' : ''}}"
          data-label="{{item.label}}"
          bindtap="onPickNoteLabel"
        >
          <text class="note-chip-icon">{{item.icon}}</text>
          <text class="note-chip-text" style="{{item.on ? 'color:' + item.color + ';font-weight:600;' : ''}}">{{item.label}}</text>
          <text class="note-chip-check" wx:if="{{item.on}}">✓</text>
        </view>
      </view>
    </view>

    <!-- 清除 -->
    <view class="note-clear-btn" data-label="" bindtap="onPickNoteLabel">✕  清除标注</view>
  </view>
</view>

<view class="mp-overlay" wx:if="{{showMissionProgress}}" bindtap="onCloseMissionProgress">
  <view class="mp-card">
    <text class="mp-round-label">第 {{missionProgressRound}} 轮任务</text>
    <text class="mp-heading">出  征  中</text>
    <text class="mp-hint-text">队员正在秘密提交任务结果</text>
    <view class="mp-avatars">
      <view class="mp-avatar-wrap {{item.voted ? 'mp-av-voted' : 'mp-av-pending'}}" wx:for="{{missionProgressTeam}}" wx:key="id">
        <image class="mp-av-img" wx:if="{{item.avatarImage}}" src="{{item.avatarImage}}" mode="aspectFill" />
        <text class="mp-av-emoji" wx:else>{{item.avatarText}}</text>
        <view class="mp-av-check" wx:if="{{item.voted}}">✓</view>
        <text class="mp-av-name"><text class="mp-av-seat">{{item.seat}}·</text>{{item.nickname}}</text>
      </view>
    </view>
    <view class="mp-pips">
      <view class="mp-pip {{idx < missionVotedCount ? 'mp-pip-done' : 'mp-pip-wait'}}" wx:for="{{missionProgressTeam}}" wx:for-index="idx" wx:key="idx"></view>
    </view>
    <text class="mp-status-text">{{missionVotedCount}} / {{missionProgressTeam.length}} 已提交</text>
  </view>
  <text class="mp-close-hint">点击任意处关闭</text>
</view>

<view class="mission-overlay {{missionAnimClass}}" wx:if="{{showMissionAnim}}" bindtap="onCloseMissionAnim">
  <view class="mission-overlay-content">
    <text class="mission-round-label">第 {{missionAnimRound}} 轮任务</text>
    <image class="mission-anim-image" src="{{missionAnimImage}}" mode="widthFix" />
    <text class="mission-anim-title {{missionAnimSuccess ? 'mission-title-success' : 'mission-title-fail'}}">{{missionAnimText}}</text>
    <view class="mission-fails-row">
      <view class="mission-fail-pip {{missionAnimSuccess ? 'pip-zero' : 'pip-red'}}" wx:for="{{missionAnimFails}}" wx:key="*this"></view>
      <text class="mission-fails-text">{{missionAnimFailsText}}</text>
    </view>
  </view>
  <text class="mp-close-hint">点击任意处关闭</text>
</view>

<!-- 刺客托管选人面板 -->
<view class="ap-mask" wx:if="{{showAutoplayPicker}}" bindtap="onAutoplayPickerCancel">
  <view class="ap-sheet" catchtap="onNoop">
    <text class="ap-title">选择预定刺杀目标</text>
    <text class="ap-sub">托管后进入刺杀阶段将自动刺杀此人</text>
    <view class="ap-list">
      <view class="ap-item" wx:for="{{autoplayPickerSlots}}" wx:key="playerId" data-idx="{{index}}" bindtap="onAutoplayPickerSelect">
        <text class="ap-seat">{{item.seat}}号</text>
        <image wx:if="{{item.avatarImage}}" class="ap-avatar" src="{{item.avatarImage}}" mode="aspectFill"/>
        <text wx:else class="ap-avatar-text">{{item.avatarText}}</text>
        <text class="ap-name">{{item.name}}</text>
      </view>
    </view>
    <view class="ap-cancel" bindtap="onAutoplayPickerCancel">取消</view>
  </view>
</view>

<view class="recap-modal-mask" wx:if="{{showRecapModal && recapList.length}}" bindtap="onCloseRecap">
  <view class="recap-modal" catchtap="onNoop">
    <view class="recap-header">
      <text class="recap-title">AI 复盘</text>
      <text class="recap-close" bindtap="onCloseRecap">✕</text>
    </view>
    <view class="recap-nav">
      <text class="recap-nav-btn {{recapIndex === 0 ? 'disabled' : ''}}" bindtap="onRecapPrev">‹ 上一位</text>
      <text class="recap-who">{{recapList[recapIndex].seat}}号 · {{recapList[recapIndex].nickname}}{{recapList[recapIndex].role ? ' · ' + recapList[recapIndex].role : ''}}</text>
      <text class="recap-nav-btn {{recapIndex === recapList.length - 1 ? 'disabled' : ''}}" bindtap="onRecapNext">下一位 ›</text>
    </view>
    <scroll-view class="recap-sections" scroll-y>
      <view class="recap-inner">
      <view class="recap-known" wx:if="{{recapList[recapIndex].knownInfo}}">
        <text class="recap-known-text">{{recapList[recapIndex].knownInfo}}</text>
      </view>
      <view class="recap-think-wrap" wx:if="{{recapList[recapIndex].think}}">
        <view class="recap-think-toggle" bindtap="onToggleThink">
          <text class="recap-think-label">推理过程</text>
          <text class="recap-think-arrow">{{recapList[recapIndex].showThink ? '▲' : '▼'}}</text>
        </view>
        <view class="recap-think-body" wx:if="{{recapList[recapIndex].showThink}}">
          <text class="recap-think-text">{{recapList[recapIndex].think}}</text>
        </view>
      </view>
      <view class="recap-section" wx:for="{{recapList[recapIndex].sections}}" wx:key="label">
        <text class="recap-section-label">{{item.label}}</text>
        <text class="recap-section-text">{{item.text}}</text>
      </view>
      </view>
    </scroll-view>
    <view class="recap-dots" wx:if="{{recapList.length > 1}}">
      <view class="recap-dot {{idx === recapIndex ? 'active' : ''}}" wx:for="{{recapList}}" wx:for-index="idx" wx:key="idx"></view>
    </view>
  </view>
</view>

<view class="assassin-overlay {{assassinAnim.hit ? 'overlay-hit' : 'overlay-miss'}}" wx:if="{{assassinAnim && assassinAnim.show}}" bindtap="onCloseAssassinAnim">
  <image class="assassin-dagger-img {{assassinAnim.hit ? '' : 'dagger-miss'}}" src="https://www.awalon.top/mp-assets/ui-icons/kill.png" mode="aspectFit" />
  <view class="assassin-result-text {{assassinAnim.resultClass}}">{{assassinAnim.resultText}}</view>
  <view class="assassin-target-row">
    <view class="assassin-avatar-wrap {{assassinAnim.hit ? 'avatar-hit' : 'avatar-miss'}}">
      <image class="assassin-target-avatar" wx:if="{{assassinAnim.targetAvatar}}" src="{{assassinAnim.targetAvatar}}" mode="aspectFill" />
      <view class="assassin-avatar-text" wx:else>{{assassinAnim.targetAvatarText}}</view>
    </view>
    <view class="assassin-target-info">
      <text class="assassin-target-name">{{assassinAnim.targetName}}</text>
      <view class="assassin-role-row">
        <image class="assassin-role-img" wx:if="{{assassinAnim.targetRoleImage}}" src="{{assassinAnim.targetRoleImage}}" mode="aspectFill" />
        <text class="assassin-target-role">{{assassinAnim.targetRole}}</text>
      </view>
      <text class="assassin-by">刺客：{{assassinAnim.assassinName}}</text>
    </view>
  </view>
  <text class="assassin-close-hint">点击任意处关闭</text>
</view>

<!-- ===== 新手引导提示卡片 ===== -->
<view class="hint-overlay" wx:if="{{hintVisible}}" bindtap="onDismissHint">
  <view class="hint-card">
    <view class="hint-header">
      <text class="hint-icon">💡</text>
      <text class="hint-title">{{hintTitle}}</text>
    </view>
    <text class="hint-text">{{hintText}}</text>
    <view class="hint-footer">
      <text class="hint-step-tip">新手引导 · 只出现一次</text>
      <view class="hint-dismiss-btn" bindtap="onDismissHint">
        <text class="hint-dismiss-text">知道了</text>
      </view>
    </view>
  </view>
</view>
