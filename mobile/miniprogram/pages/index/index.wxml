  </view>
  <text class="mp-close-hint">点击任意处关闭</text>
</view>

<view class="settings-mask" wx:if="{{showRoomSettings}}" bindtap="onCloseRoomSettings">
  <view class="settings-sheet" catchtap="onNoop">
    <view class="note-sheet-accent"></view>
    <view class="note-drag-handle"></view>
    <view class="settings-head">
      <text class="settings-title">修改当前配置</text>
      <text class="settings-close" bindtap="onCloseRoomSettings">✕</text>
    </view>
    <scroll-view class="settings-scroll" scroll-y>
      <view class="count-options-row settings-count-row">
        <view
          class="cf cf-sm {{maxPlayersIndex===index ? 'cf-bright' : 'cf-subtle'}}"
          wx:for="{{maxPlayersOptions}}"
          wx:key="*this"
          data-idx="{{index}}"
          bindtap="onSelectMaxPlayers"
        >
          <view class="count-option cf-in-sm {{maxPlayersIndex===index ? 'count-option-on' : ''}}">{{item}}</view>
        </view>
      </view>

      <view class="preset-row" wx:if="{{rolePresets.length > 1}}">
        <view
          class="cf cf-sm preset-opt-wrap {{selectedPresetIndex===index ? 'cf-bright' : 'cf-subtle'}}"
          wx:for="{{rolePresets}}" wx:key="name"
          data-idx="{{index}}" bindtap="onSelectPreset">
          <view class="preset-opt cf-in-sm {{selectedPresetIndex===index ? 'preset-opt-on' : ''}}">{{item.name}}</view>
        </view>
      </view>

      <view class="cfg-section-hdr">
        <view class="cfg-section-line"></view>
        <text class="cfg-section-deco">◆</text>
        <text class="cfg-section-title">阵容配置</text>
        <text class="cfg-section-deco">◆</text>
        <view class="cfg-section-line"></view>
      </view>

      <view class="faction-area">
        <view class="faction-frame faction-frame-good">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="faction-group faction-group-good">
            <view class="faction-hdr faction-hdr-good">
              <image class="faction-hdr-icon-img" src="https://www.awalon.top/mp-assets/icons/faction-good.svg" mode="aspectFit" />
              <text class="faction-hdr-title">正义阵营</text>
              <text class="faction-hdr-count {{goodChipCount===neededGood ? 'faction-hdr-count-ok' : ''}}">{{goodChipCount}}/{{neededGood}}</text>
            </view>
            <view class="faction-chips-row">
              <block wx:for="{{currentRoleChips}}" wx:key="role">
                <view wx:if="{{!item.isEvil}}" class="role-chip-sm role-chip-sm-good {{hostRole===item.role ? 'role-chip-sm-selected' : ''}}"
                  data-role="{{item.role}}" bindtap="onPickRoleChip">
                  <image class="role-chip-sm-img" src="{{item.image}}" mode="aspectFill" />
                  <text class="role-chip-tip" wx:if="{{item.roleBadgeText}}">{{item.roleBadgeText}}</text>
                  <text class="role-chip-sm-name">{{item.role}}</text>
                  <text class="role-chip-sm-cnt" wx:if="{{item.count > 1}}">×{{item.count}}</text>
                </view>
              </block>
            </view>
          </view>
        </view>
        <view class="faction-frame faction-frame-evil">
          <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
          <view class="fb fb-left"></view><view class="fb fb-right"></view>
          <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
          <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
          <view class="faction-group faction-group-evil">
            <view class="faction-hdr faction-hdr-evil">
              <image class="faction-hdr-icon-img" src="https://www.awalon.top/mp-assets/icons/faction-evil.svg" mode="aspectFit" />
              <text class="faction-hdr-title">邪恶阵营</text>
              <text class="faction-hdr-count {{evilChipCount===neededEvil ? 'faction-hdr-count-ok' : ''}}">{{evilChipCount}}/{{neededEvil}}</text>
            </view>
            <view class="faction-chips-row">
              <block wx:for="{{currentRoleChips}}" wx:key="role">
                <view wx:if="{{item.isEvil}}" class="role-chip-sm role-chip-sm-evil {{hostRole===item.role ? 'role-chip-sm-selected' : ''}}"
                  data-role="{{item.role}}" bindtap="onPickRoleChip">
                  <image class="role-chip-sm-img" src="{{item.image}}" mode="aspectFill" />
                  <text class="role-chip-tip" wx:if="{{item.roleBadgeText}}">{{item.roleBadgeText}}</text>
                  <text class="role-chip-sm-name">{{item.role}}</text>
                  <text class="role-chip-sm-cnt" wx:if="{{item.count > 1}}">×{{item.count}}</text>
                </view>
              </block>
            </view>
          </view>
        </view>
      </view>

      <view class="rules-list">
        <view class="rule-row">
          <view class="rule-row-left"><image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-lady.svg" mode="aspectFit" /><text class="rule-name">湖中仙女</text></view>
          <view class="rule-opts"><view class="rule-opt {{!ladyOfLakeEnabled ? 'rule-opt-on' : ''}}" data-enabled="0" bindtap="onToggleLadyDirect">关闭</view><view class="rule-opt {{ladyOfLakeEnabled ? 'rule-opt-on' : ''}}" data-enabled="1" bindtap="onToggleLadyDirect">开启</view></view>
        </view>
        <view class="rule-row">
          <view class="rule-row-left"><image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-force.svg" mode="aspectFit" /><text class="rule-name">强制失败</text></view>
          <view class="rule-opts"><view class="rule-opt {{forceRoundMode==='fixed5' ? 'rule-opt-on' : ''}}" data-value="fixed5" bindtap="onPickForceRoundDirect">第5次</view><view class="rule-opt {{forceRoundMode==='evil_plus_one' ? 'rule-opt-on' : ''}}" data-value="evil_plus_one" bindtap="onPickForceRoundDirect">邪恶+1</view></view>
        </view>
        <view class="rule-row">
          <view class="rule-row-left"><image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-evil.svg" mode="aspectFit" /><text class="rule-name">邪恶互认</text></view>
          <view class="rule-opts"><view class="rule-opt {{!evilRoleVisibleEnabled ? 'rule-opt-on' : ''}}" data-value="false" bindtap="onPickEvilVisibleDirect">隐藏</view><view class="rule-opt {{evilRoleVisibleEnabled ? 'rule-opt-on' : ''}}" data-value="true" bindtap="onPickEvilVisibleDirect">显示</view></view>
        </view>
        <view class="rule-row">
          <view class="rule-row-left"><image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-timer.svg" mode="aspectFit" /><text class="rule-name">发言时长</text></view>
          <view class="rule-opts"><view class="rule-opt {{speakingSeconds===60 ? 'rule-opt-on' : ''}}" data-value="60" bindtap="onPickSpeakingSecondsDirect">60s</view><view class="rule-opt {{speakingSeconds===90 ? 'rule-opt-on' : ''}}" data-value="90" bindtap="onPickSpeakingSecondsDirect">90s</view><view class="rule-opt {{speakingSeconds===120 ? 'rule-opt-on' : ''}}" data-value="120" bindtap="onPickSpeakingSecondsDirect">120s</view><view class="rule-opt {{speakingSeconds===180 ? 'rule-opt-on' : ''}}" data-value="180" bindtap="onPickSpeakingSecondsDirect">180s</view></view>
        </view>
        <view class="rule-row">
          <view class="rule-row-left"><image class="rule-icon" src="https://www.awalon.top/mp-assets/icons/rule-voice.svg" mode="aspectFit" /><text class="rule-name">AI语音</text></view>
          <view class="rule-opts"><view class="rule-opt {{!aiVoiceEnabled ? 'rule-opt-on' : ''}}" data-enabled="0" bindtap="onToggleAiVoiceDirect">关闭</view><view class="rule-opt {{aiVoiceEnabled ? 'rule-opt-on' : ''}}" data-enabled="1" bindtap="onToggleAiVoiceDirect">开启</view></view>
        </view>
      </view>
    </scroll-view>
    <view class="settings-actions">
      <view class="btn-frame settings-btn-frame" bindtap="onApplyRoomSettings">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="settings-btn-new settings-btn-save">保存配置</view>
      </view>
      <view class="btn-frame btn-frame-ghost settings-btn-frame" bindtap="onCloseRoomSettings">
        <view class="fb fb-top"></view><view class="fb fb-bottom"></view>
        <view class="fb fb-left"></view><view class="fb fb-right"></view>
        <view class="fb fb-ctl"></view><view class="fb fb-ctr"></view>
        <view class="fb fb-cbl"></view><view class="fb fb-cbr"></view>
        <view class="settings-btn-new settings-btn-cancel">取消</view>
      </view>
    </view>
  </view>
</view>

<view class="config-help-mask" wx:if="{{showConfigHelp}}" bindtap="onCloseConfigHelp">
