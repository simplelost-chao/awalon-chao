.page {
  min-height: 100vh;
  position: relative;
}

.bg,
.mask {
  position: fixed;
  inset: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg, rgba(10, 12, 18, 0.58), rgba(10, 12, 18, 0.86));
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: rgba(12, 16, 24, 0.88);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.custom-nav-inner {
  position: relative;
  height: 40px;
  padding: 0 2rpx;
}

.custom-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #eef2fa;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-back-btn {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: auto;
  min-width: 0;
  height: 36rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  border: none;
  background: transparent;
  color: #dfe7f8;
  font-size: 26rpx;
  line-height: 1;
}

.nav-back-btn::after {
  border: none;
}

.content {
  position: relative;
  z-index: 2;
  height: 100vh;
  box-sizing: border-box;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 0 24rpx 40rpx;
}

.panel {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(19, 23, 31, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* ── Section title ── */

.section-title {
  display: block;
  color: #f2e5c8;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

/* ── Journey steps ── */

.journey-card {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, rgba(38, 46, 62, 0.72), rgba(13, 16, 22, 0.92));
  border: 1rpx solid rgba(242, 229, 200, 0.14);
}

.journey-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.journey-step {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f1320;
  font-size: 24rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f6deb0, #d7a45f);
  flex-shrink: 0;
}

.journey-meta {
  display: flex;
  flex-direction: column;
}

.journey-title {
  color: #f5ead0;
  font-size: 25rpx;
  font-weight: 700;
}

.journey-scene {
  margin-top: 4rpx;
  color: #9eb6df;
  font-size: 20rpx;
}

.journey-point {
  margin-top: 10rpx;
  padding-left: 12rpx;
  color: #d6dfef;
  font-size: 22rpx;
  line-height: 1.55;
}

/* ── Bullet list ── */

.bullet {
  margin-top: 8rpx;
  color: #d2dbeb;
  font-size: 22rpx;
  line-height: 1.55;
}

/* ── Phase cards ── */

.phase-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.phase-card {
  padding: 10rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(0, 0, 0, 0.18);
}

.phase-tag {
  display: inline-block;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #f2e5c8;
  background: rgba(216, 176, 107, 0.32);
}

.phase-name {
  display: block;
  margin-top: 6rpx;
  color: #f3d89e;
  font-size: 24rpx;
  font-weight: 700;
}

.phase-desc {
  display: block;
  margin-top: 5rpx;
  color: #ccd6e9;
  font-size: 21rpx;
  line-height: 1.4;
}

/* ── Feature tip rows ── */

.feature-tip-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.feature-icon {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.feature-tip-body {
  flex: 1;
}

/* ── Peer vote tags ── */

.peer-tag-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.peer-tag {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.peer-tag-c {
  color: #fff2f2;
  background: rgba(196, 79, 79, 0.72);
  border: 1rpx solid rgba(220, 100, 100, 0.5);
}

.peer-tag-b {
  color: #fff8e8;
  background: rgba(176, 130, 50, 0.72);
  border: 1rpx solid rgba(210, 165, 80, 0.5);
}

.peer-tag-e {
  color: #efffef;
  background: rgba(60, 160, 100, 0.72);
  border: 1rpx solid rgba(80, 190, 120, 0.5);
}

/* ── AI recap section list ── */

.recap-section-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recap-section-item {
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.recap-section-label {
  display: block;
  color: #9ab4cc;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.recap-section-desc {
  display: block;
  color: #b8c3d7;
  font-size: 21rpx;
  line-height: 1.5;
}

/* ── Win conditions ── */

.win-row {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.good-win {
  background: rgba(40, 90, 70, 0.52);
  border: 1rpx solid rgba(80, 180, 120, 0.3);
}

.evil-win {
  background: rgba(80, 20, 20, 0.52);
  border: 1rpx solid rgba(200, 70, 70, 0.3);
}

.win-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #f2e5c8;
}

.win-desc {
  font-size: 21rpx;
  color: #d0d8ea;
  line-height: 1.5;
}

/* ── Roles ── */

.role-item {
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(0, 0, 0, 0.16);
}

.role-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.role-avatar {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.role-name {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.role-name.good {
  color: #eaf2ff;
  background: rgba(84, 130, 224, 0.64);
}

.role-name.evil {
  color: #fff;
  background: rgba(212, 84, 84, 0.72);
}

.role-desc {
  display: block;
  margin-top: 8rpx;
  color: #d2dbeb;
  font-size: 22rpx;
  line-height: 1.5;
}

/* ── Tip panel ── */

.tip-panel {
  margin-bottom: 24rpx;
}

.tip-title {
  display: block;
  color: #f0d7a1;
  font-size: 26rpx;
  font-weight: 700;
}

.tip-text {
  display: block;
  margin-top: 8rpx;
  color: #c9d3e7;
  font-size: 22rpx;
  line-height: 1.6;
}
