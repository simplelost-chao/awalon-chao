.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #11161f, #090c12);
  color: #eef1f7;
}

.custom-nav {
  padding-top: env(safe-area-inset-top);
  background: rgba(12, 16, 24, 0.92);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 700;
}

.nav-back,
.nav-confirm {
  min-width: 108rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.nav-back {
  background: rgba(255, 255, 255, 0.08);
  color: #dbe3f0;
}

.nav-confirm {
  background: linear-gradient(135deg, #e4c281, #c8964a);
  color: #20160c;
}

.content {
  padding: 36rpx 24rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-text {
  font-size: 26rpx;
  color: #f2e5c8;
  margin-bottom: 16rpx;
}

.tip {
  font-size: 24rpx;
  color: #aeb6c7;
  margin-bottom: 28rpx;
}

.crop-frame {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  touch-action: none;
}

.crop-canvas {
  position: absolute;
  left: 0;
  top: 0;
  display: block;
}

.crop-mask {
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 0 9999rpx rgba(0, 0, 0, 0.18);
  pointer-events: none;
}

.crop-border {
  position: absolute;
  inset: 0;
  border: 2px solid rgba(228, 194, 129, 0.88);
  border-radius: 28rpx;
  pointer-events: none;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 128px;
  height: 128px;
  opacity: 0;
}
