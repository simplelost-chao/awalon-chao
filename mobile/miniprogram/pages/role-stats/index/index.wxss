.page {
  min-height: 100vh;
  position: relative;
}

.bg,
.mask {
  position: fixed;
  inset: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg, rgba(10, 12, 18, 0.58), rgba(10, 12, 18, 0.86));
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: rgba(12, 16, 24, 0.88);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.custom-nav-inner {
  position: relative;
  height: 40px;
  padding: 0 2rpx;
}

.custom-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #eef2fa;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-back-btn {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: auto;
  min-width: 0;
  height: 36rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  border: none;
  background: transparent;
  color: #dfe7f8;
  font-size: 26rpx;
  line-height: 1;
}

.nav-back-btn::after {
  border: none;
}

.content {
  position: relative;
  z-index: 2;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 0 24rpx 40rpx;
}

.panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(19, 23, 31, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title {
  color: #f2e5c8;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.meta {
  display: block;
  margin-top: 8rpx;
  color: #cfd8ea;
  font-size: 22rpx;
}

.summary-row {
  display: flex;
  gap: 12rpx;
}

.summary-box {
  flex: 1;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(0, 0, 0, 0.2);
  padding: 14rpx 10rpx;
  align-items: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.1;
}

.summary-blue {
  color: #85b2ff;
}

.summary-green {
  color: #79e2a8;
}

.summary-label {
  margin-top: 6rpx;
  color: #cfd8ea;
  font-size: 21rpx;
}

.faction-row {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
}

.faction-box {
  flex: 1;
  border-radius: 12rpx;
  padding: 10rpx 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.faction-good {
  background: rgba(66, 125, 84, 0.24);
  border-color: rgba(121, 226, 168, 0.5);
}

.faction-evil {
  background: rgba(145, 54, 54, 0.24);
  border-color: rgba(255, 143, 143, 0.5);
}

.faction-title {
  display: block;
  font-size: 23rpx;
  font-weight: 700;
  color: #f2e5c8;
}

.faction-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #d5deef;
}

.stats-grid {
  margin-top: 4rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.stats-card {
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(0, 0, 0, 0.22);
  padding: 14rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.role-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
}

.role-name {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.role-name-good {
  color: #79e2a8;
}

.role-name-evil {
  color: #ff8f8f;
}

.role-meta {
  margin-top: 3rpx;
  color: #cfd8ea;
  font-size: 21rpx;
}

.rate-good {
  color: #79e2a8;
  font-weight: 700;
}

.rate-bad {
  color: #ff8f8f;
  font-weight: 700;
}

.medal-section {
  margin-top: 12rpx;
}

.medal-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.medal-title-good {
  color: #79e2a8;
}

.medal-title-evil {
  color: #ff8f8f;
}

.medal-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
}

.medal-card {
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(0, 0, 0, 0.2);
  padding: 8rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.medal-image {
  width: 32px;
  height: 32px;
  margin-bottom: 6rpx;
}

.medal-icon {
  width: 32px;
  height: 32px;
  line-height: 32px;
  text-align: center;
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.medal-name {
  display: block;
  font-size: 18rpx;
  color: #f8e8c2;
  line-height: 1.3;
  word-break: break-word;
}

.medal-count {
  display: block;
  margin-top: 2rpx;
  font-size: 18rpx;
  color: #cfd8ea;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(0, 0, 0, 0.18);
}

.line {
  display: block;
  color: #cfd8ea;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.strong {
  color: #f0d7a1;
  font-size: 24rpx;
  font-weight: 600;
}
