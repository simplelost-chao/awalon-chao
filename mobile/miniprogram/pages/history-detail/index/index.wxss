.page {
  min-height: 100vh;
  position: relative;
}

.bg,
.mask {
  position: fixed;
  inset: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg, rgba(10, 12, 18, 0.58), rgba(10, 12, 18, 0.86));
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: rgba(12, 16, 24, 0.88);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.custom-nav-inner {
  position: relative;
  height: 40px;
  padding: 0 2rpx;
}

.custom-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #eef2fa;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-back-btn {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: auto;
  min-width: 0;
  height: 36rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  border: none;
  background: transparent;
  color: #dfe7f8;
  font-size: 26rpx;
  line-height: 1;
}

.nav-back-btn::after {
  border: none;
}

.content {
  position: relative;
  z-index: 2;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 0 24rpx 40rpx;
}

.panel {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(19, 23, 31, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title {
  display: block;
  color: #f2e5c8;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.meta {
  display: block;
  margin-top: 8rpx;
  color: #cfd8ea;
  font-size: 22rpx;
}

.medal-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.medal-chip {
  padding: 6rpx 10rpx 6rpx 6rpx;
  border-radius: 999rpx;
  background: rgba(192, 145, 74, 0.24);
  border: 1rpx solid rgba(242, 202, 136, 0.45);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.medal-chip-image {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.medal-chip-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.medal-chip-name {
  font-size: 20rpx;
  color: #f8e8c2;
}

.assassination-banner {
  margin-top: 8rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.assassination-hit {
  background: rgba(163, 44, 44, 0.42);
  border-color: rgba(255, 132, 132, 0.55);
}

.assassination-miss {
  background: rgba(64, 96, 150, 0.42);
  border-color: rgba(141, 181, 255, 0.55);
}

.assassination-main {
  display: block;
  color: #fff4f4;
  font-size: 30rpx;
  font-weight: 700;
}

.assassination-sub {
  display: block;
  margin-top: 6rpx;
  color: #e6edf9;
  font-size: 22rpx;
}

.my-role-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.my-role-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.table-wrap {
  position: relative;
  height: 720rpx;
  margin-top: 10rpx;
}

.table-ring {
  position: absolute;
  width: 430rpx;
  height: 430rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 8rpx solid rgba(210, 155, 84, 0.45);
  box-shadow: 0 0 0 6rpx rgba(58, 30, 12, 0.34) inset;
}

.center-result {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 210rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  z-index: 3;
}

.center-title {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.center-sub {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 20rpx;
}

.winner-good {
  background: rgba(70, 120, 212, 0.7);
}

.winner-evil {
  background: rgba(196, 66, 66, 0.75);
}

.seat-round {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 146rpx;
  height: 146rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  background: rgba(66, 44, 24, 0.52);
  display: grid;
  align-content: center;
  justify-items: center;
  padding: 8rpx;
}

.seat-assassinated {
  border-color: rgba(255, 118, 118, 0.95);
  box-shadow: 0 0 0 3rpx rgba(120, 20, 20, 0.45) inset;
}

.seat-no {
  font-size: 24rpx;
  color: #e6c17d;
}

.seat-name {
  font-size: 22rpx;
  color: #d0d8e8;
  max-width: 126rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seat-role-pill {
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.seat-role-img {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.seat-role {
  font-size: 18rpx;
  color: #fff;
}

.seat-mark-killed {
  margin-top: 4rpx;
  color: #ff9d9d;
  font-size: 26rpx;
  line-height: 1;
}

.seat-mark-assassin {
  margin-top: 4rpx;
  color: #ffd38f;
  font-size: 24rpx;
  line-height: 1;
}

.role-good {
  background: rgba(84, 130, 224, 0.48);
}

.role-evil {
  background: rgba(212, 84, 84, 0.52);
}

.table-head,
.table-row {
  display: grid;
  width: 100%;
  grid-template-columns: 1.05fr 1.1fr 1.45fr 3.2fr 1.2fr;
  gap: 8rpx;
  align-items: start;
}

.table-head {
  margin-top: 8rpx;
  margin-bottom: 6rpx;
}

.table-row {
  min-height: 44rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding-top: 6rpx;
}

.col {
  font-size: 22rpx;
  color: #b8c3d7;
  overflow: hidden;
  white-space: normal;
  word-break: break-all;
}

.col-round {
  color: #e7cf95;
}

.res-ok {
  color: #83deab;
}

.res-fail {
  color: #ff9c9c;
}

.res-pending {
  color: #e0c98d;
}

.col-reject {
  color: #ff8f8f;
}
