.page {
  min-height: 100vh;
  position: relative;
}

.bg,
.mask {
  position: fixed;
  inset: 0;
}

.bg {
  width: 100vw;
  height: 100vh;
}

.mask {
  background: linear-gradient(180deg, rgba(10, 12, 18, 0.58), rgba(10, 12, 18, 0.86));
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: rgba(12, 16, 24, 0.88);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.custom-nav-inner {
  position: relative;
  height: 40px;
  padding: 0 2rpx;
}

.custom-nav-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #eef2fa;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-back-btn {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: auto;
  min-width: 0;
  height: 36rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  border: none;
  background: transparent;
  color: #dfe7f8;
  font-size: 26rpx;
  line-height: 1;
}

.nav-back-btn::after {
  border: none;
}

.content {
  position: relative;
  z-index: 2;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 0 24rpx 40rpx;
}

.panel {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(19, 23, 31, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title {
  display: block;
  color: #f2e5c8;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.section-chip {
  padding: 8rpx 14rpx;
  border-left: 6rpx solid #d8b06b;
  border-radius: 8rpx;
  background: linear-gradient(90deg, rgba(216, 176, 107, 0.2), rgba(216, 176, 107, 0.04));
  color: #f2e5c8;
  letter-spacing: 1rpx;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 0;
}

.meta {
  display: block;
  margin-top: 8rpx;
  color: #cfd8ea;
  font-size: 22rpx;
}

.peer-vote-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 8rpx;
}

.peer-vote-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(0, 0, 0, 0.18);
}

.peer-vote-name {
  color: #eef2fa;
  font-size: 22rpx;
}

.peer-vote-summary {
  color: #f2d79d;
  font-size: 21rpx;
  text-align: right;
}

.medal-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.medal-chip {
  padding: 6rpx 10rpx 6rpx 6rpx;
  border-radius: 999rpx;
  background: rgba(192, 145, 74, 0.24);
  border: 1rpx solid rgba(242, 202, 136, 0.45);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.medal-chip-image {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.medal-chip-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.medal-chip-name {
  font-size: 20rpx;
  color: #f8e8c2;
}

.assass-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 10rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.assassination-hit {
  background: rgba(80, 8, 8, 0.52);
  border: 1rpx solid rgba(220, 60, 60, 0.4);
}

.assassination-miss {
  background: rgba(10, 40, 24, 0.52);
  border: 1rpx solid rgba(80, 180, 100, 0.4);
}


.assass-avatar-wrap {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
}

.assass-avatar-hit {
  border: 3rpx solid rgba(220, 60, 60, 0.8);
}

.assass-avatar-miss {
  border: 3rpx solid rgba(230, 193, 125, 0.7);
}

.assass-avatar-img {
  width: 100%;
  height: 100%;
}

.assass-avatar-text {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.assass-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.assass-result {
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.assass-hit {
  color: #ff5a5a;
  text-shadow: 0 0 20rpx rgba(255, 60, 60, 0.5);
}

.assass-miss {
  color: #70e8a0;
  text-shadow: 0 0 20rpx rgba(80, 220, 140, 0.5);
}

.assass-target-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #eedfc0;
}

.assass-role {
  font-size: 24rpx;
  font-weight: 600;
  color: #e6c17d;
}

.assass-by {
  font-size: 22rpx;
  color: rgba(200, 180, 140, 0.5);
  margin-top: 2rpx;
}

.game-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 4rpx;
}

.game-role-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.game-role-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(216, 176, 107, 0.5);
}

.game-role-label {
  font-size: 20rpx;
  color: #e6c17d;
  font-weight: 600;
  max-width: 110rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-info-block {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  padding-top: 4rpx;
}

.game-id-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #f2e5c8;
}

.game-meta-line {
  font-size: 22rpx;
  color: #cfd8ea;
  line-height: 1.5;
}

.table-wrap {
  position: relative;
  height: 720rpx;
  margin-top: 10rpx;
}

.table-ring {
  position: absolute;
  width: 430rpx;
  height: 430rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 8rpx solid rgba(210, 155, 84, 0.45);
  box-shadow: 0 0 0 6rpx rgba(58, 30, 12, 0.34) inset;
}

.center-result {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 210rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  z-index: 3;
}

.center-title {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.center-sub {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 20rpx;
}

.winner-good {
  background: rgba(30, 90, 200, 0.7);
}

.winner-evil {
  background: rgba(160, 35, 45, 0.75);
}

.seat-round {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 146rpx;
  height: 146rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  background: rgba(66, 44, 24, 0.52);
  display: grid;
  align-content: center;
  justify-items: center;
  padding: 8rpx;
  overflow: visible;
}

.seat-assassinated {
  border-color: rgba(255, 118, 118, 0.95);
  box-shadow: 0 0 0 3rpx rgba(120, 20, 20, 0.45) inset;
}

.seat-no {
  font-size: 24rpx;
  color: #e6c17d;
}

.seat-name {
  font-size: 22rpx;
  color: #d0d8e8;
  max-width: 126rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seat-role-pill {
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.seat-role-img {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.seat-role {
  font-size: 18rpx;
  color: #fff;
}

.seat-killed-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-25%, -72%) rotate(-20deg);
  width: 180rpx;
  height: 180rpx;
  opacity: 0.92;
  z-index: 10;
}

.role-good {
  background: rgba(84, 130, 224, 0.48);
}

.role-evil {
  background: rgba(212, 84, 84, 0.52);
}

.table-head,
.table-row {
  display: grid;
  width: 100%;
  grid-template-columns: 1.05fr 1.1fr 1.45fr 3.2fr 1.2fr;
  gap: 8rpx;
  align-items: start;
}

.table-head {
  margin-top: 8rpx;
  margin-bottom: 6rpx;
}

.table-row {
  min-height: 44rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding-top: 6rpx;
}

.col {
  font-size: 22rpx;
  color: #b8c3d7;
  overflow: hidden;
  white-space: normal;
  word-break: break-all;
}

.col-round {
  color: #e7cf95;
}

.res-ok {
  color: #83deab;
}

.res-fail {
  color: #ff9c9c;
}

.res-pending {
  color: #e0c98d;
}

.col-reject {
  color: #ff8f8f;
}

/* 发言记录 */
.speak-title-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.speak-title-round {
  font-size: 22rpx;
  color: #d8b06b;
}

.speak-inline-pager {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.speak-inline-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #dfe7f8;
  font-size: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.speak-inline-disabled {
  opacity: 0.3;
}

.speak-chat {
  max-height: 560rpx;
  padding: 4rpx 0;
}

.speak-bubble {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.speak-bubble:last-child {
  margin-bottom: 0;
}

.bubble-name {
  font-size: 20rpx;
  color: #8bbeea;
  margin-bottom: 5rpx;
  padding-left: 4rpx;
}

.bubble-body {
  max-width: 88%;
  background: rgba(50, 72, 116, 0.48);
  border: 1rpx solid rgba(120, 160, 220, 0.28);
  border-radius: 4rpx 16rpx 16rpx 16rpx;
  padding: 10rpx 16rpx;
}

.bubble-text {
  font-size: 22rpx;
  color: #dde6f5;
  line-height: 1.65;
}

/* AI 复盘 */
.recap-card {
  margin-top: 10rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
}

.recap-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 16rpx;
}

.recap-seat {
  color: #e6c17d;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.recap-role {
  color: #a89fc8;
  font-size: 20rpx;
  flex-shrink: 0;
}

.recap-nick {
  color: #d0d8e8;
  font-size: 22rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recap-toggle {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8bbeea;
}

.recap-overview {
  display: block;
  color: #cfd8ea;
  font-size: 22rpx;
  line-height: 1.6;
  padding: 0 16rpx 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.07);
  padding-top: 12rpx;
}

.recap-section {
  padding: 8rpx 16rpx 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.recap-section-title {
  display: block;
  color: #9ab4cc;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 5rpx;
}

.recap-body {
  display: block;
  color: #b8c3d7;
  font-size: 21rpx;
  line-height: 1.65;
}
